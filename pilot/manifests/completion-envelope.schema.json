{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "qq delegated completion envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "checks",
    "filesChanged",
    "openQuestions",
    "unresolvedRisks"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["complete", "blocked", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "result"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "result": { "type": "string", "enum": ["pass", "fail", "inconclusive-under-substrate"] }
        }
      }
    },
    "filesChanged": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unresolvedRisks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
