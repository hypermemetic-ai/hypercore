#!/usr/bin/env python3
"""Build, inspect, install, and execute qq's pinned patched Pi runtime."""

from __future__ import annotations

import argparse
import contextlib
import ctypes
import dataclasses
import fcntl
import errno
import gzip
import hashlib
import io
import json
import os
from pathlib import Path, PurePosixPath
import platform
import re
import shutil
import stat
import subprocess
import sys
import tarfile
import tempfile
import urllib.request
import uuid
import zipfile
from collections.abc import Callable, Iterator, Mapping, Sequence
from typing import Any, BinaryIO


ENGINE_VERSION = 2
ARTIFACT_SCHEMA_VERSION = 1
CACHE_SCHEMA_VERSION = 2
ARTIFACT_WRAPPER = "qq-pi-runtime"
BUILD_WORKSPACE_NAME = ".build-workspace-v1"
MANIFEST_RELATIVE_PATH = Path("patches/pi/v0.81.1/manifest.json")
EXPECTED_REPORTED_IDENTITY = "0.81.1+qq.execution-profile.1"
EXPECTED_PLATFORM = "linux-x64"
_SHA256_LENGTH = 64


class RuntimeFailure(Exception):
    """An expected fail-closed refusal."""


@dataclasses.dataclass(frozen=True)
class RuntimeSpec:
    repository_root: Path
    manifest_path: Path
    manifest: Mapping[str, Any]
    cache_root: Path
    data_root: Path
    opener: Callable[[str], BinaryIO] | None = None

    @classmethod
    def production(cls) -> "RuntimeSpec":
        repository_root = Path(__file__).resolve().parent.parent
        manifest_path = repository_root / MANIFEST_RELATIVE_PATH
        try:
            manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as error:
            raise RuntimeFailure(f"cannot read the durable Pi manifest: {error}") from error
        home = Path.home()
        cache_home = _xdg_home("XDG_CACHE_HOME", home / ".cache")
        data_home = _xdg_home("XDG_DATA_HOME", home / ".local" / "share")
        return cls(
            repository_root=repository_root,
            manifest_path=manifest_path,
            manifest=manifest,
            cache_root=cache_home / "qq" / "pi-runtime",
            data_root=data_home / "qq" / "pi-runtime",
        )


def _xdg_home(variable: str, fallback: Path) -> Path:
    value = os.environ.get(variable)
    if not value:
        return fallback
    path = Path(value)
    return path if path.is_absolute() else fallback


def _canonical_json(value: Any) -> bytes:
    return (json.dumps(value, sort_keys=True, separators=(",", ":"), ensure_ascii=False) + "\n").encode()


def _sha256_bytes(value: bytes) -> str:
    return hashlib.sha256(value).hexdigest()


def _sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as source:
        for chunk in iter(lambda: source.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def _require_object(value: Any, label: str, keys: set[str]) -> Mapping[str, Any]:
    if not isinstance(value, dict) or set(value) != keys:
        raise RuntimeFailure(f"{label} must contain exactly: {', '.join(sorted(keys))}")
    return value


def _require_string(value: Any, label: str) -> str:
    if not isinstance(value, str) or not value or value != value.strip() or not value.isprintable():
        raise RuntimeFailure(f"{label} must be a non-empty printable string")
    return value


def _require_sha256(value: Any, label: str) -> str:
    digest = _require_string(value, label)
    if len(digest) != _SHA256_LENGTH or any(character not in "0123456789abcdef" for character in digest):
        raise RuntimeFailure(f"{label} must be a lowercase SHA-256 digest")
    return digest


def _require_https_url(value: Any, label: str) -> str:
    url = _require_string(value, label)
    if not url.startswith("https://") or "#" in url or "?" in url:
        raise RuntimeFailure(f"{label} must be an exact HTTPS asset URL")
    return url


def _safe_leaf(value: Any, label: str) -> str:
    leaf = _require_string(value, label)
    if leaf in {".", ".."} or "/" in leaf or "\\" in leaf or "\0" in leaf:
        raise RuntimeFailure(f"{label} must be one safe path component")
    return leaf


def _validate_manifest(manifest: Mapping[str, Any], manifest_path: Path, repository_root: Path) -> None:
    root = _require_object(
        manifest,
        "Pi manifest",
        {
            "schemaVersion",
            "manifestVersion",
            "upstream",
            "stockPiVersion",
            "patchedIdentity",
            "patch",
            "supportedPlatforms",
            "offlineModelData",
            "buildToolchain",
            "changedUpstreamPaths",
        },
    )
    if root["schemaVersion"] != 1 or root["manifestVersion"] != 2:
        raise RuntimeFailure("unsupported Pi manifest schema or version")
    upstream = _require_object(
        root["upstream"],
        "manifest upstream",
        {"repository", "releaseTag", "commit", "sourceArchive"},
    )
    _require_https_url(upstream["repository"], "upstream repository")
    _require_string(upstream["releaseTag"], "upstream release tag")
    commit = _require_string(upstream["commit"], "upstream commit")
    if len(commit) != 40 or any(character not in "0123456789abcdef" for character in commit):
        raise RuntimeFailure("upstream commit must be a lowercase 40-character Git identity")
    source = _require_object(
        upstream["sourceArchive"],
        "source archive",
        {"url", "sha256", "topLevelDirectory"},
    )
    _require_https_url(source["url"], "source archive URL")
    _require_sha256(source["sha256"], "source archive digest")
    _safe_leaf(source["topLevelDirectory"], "source archive top-level directory")

    stock_version = _require_string(root["stockPiVersion"], "stock Pi version")
    identity = _require_object(
        root["patchedIdentity"],
        "patched identity",
        {"packageVersion", "buildIdentity", "reportedVersion"},
    )
    package_version = _require_string(identity["packageVersion"], "patched package version")
    build_identity = _require_string(identity["buildIdentity"], "patched build identity")
    reported_version = _require_string(identity["reportedVersion"], "patched reported version")
    if package_version != stock_version or reported_version != f"{package_version}+{build_identity}":
        raise RuntimeFailure("patched identity is inconsistent with the stock package version")
    if reported_version != EXPECTED_REPORTED_IDENTITY:
        raise RuntimeFailure(f"patched identity must be exactly {EXPECTED_REPORTED_IDENTITY}")

    patch = _require_object(root["patch"], "patch", {"path", "sha256", "stripComponents"})
    patch_leaf = _safe_leaf(patch["path"], "patch path")
    patch_digest = _require_sha256(patch["sha256"], "patch digest")
    if not isinstance(patch["stripComponents"], int) or patch["stripComponents"] < 0:
        raise RuntimeFailure("patch stripComponents must be a non-negative integer")
    patch_path = manifest_path.parent / patch_leaf
    try:
        patch_path.resolve(strict=True).relative_to(repository_root.resolve(strict=True))
    except (OSError, ValueError) as error:
        raise RuntimeFailure("manifest patch is unavailable or outside the Repository") from error
    if not patch_path.is_file() or patch_path.is_symlink():
        raise RuntimeFailure("manifest patch must be a regular Repository file")
    if _sha256_file(patch_path) != patch_digest:
        raise RuntimeFailure("durable Pi patch digest mismatch")

    platforms = root["supportedPlatforms"]
    if platforms != [EXPECTED_PLATFORM]:
        raise RuntimeFailure("this Pi manifest must support exactly linux-x64")
    model_data = _require_object(
        root["offlineModelData"],
        "offline model data",
        {"package", "version", "lockfilePath", "resolvedUrl", "archiveSha256", "dataPath"},
    )
    _require_string(model_data["package"], "offline model-data package")
    _require_string(model_data["version"], "offline model-data package version")
    _safe_relative_path(model_data["lockfilePath"], "offline model-data lockfile path")
    _require_https_url(model_data["resolvedUrl"], "offline model-data resolved URL")
    _require_sha256(model_data["archiveSha256"], "offline model-data archive digest")
    _safe_relative_path(model_data["dataPath"], "offline model-data package path")
    toolchain = _require_object(root["buildToolchain"], "build toolchain", {"platform", "node", "bun"})
    if toolchain["platform"] != EXPECTED_PLATFORM:
        raise RuntimeFailure("build toolchain platform does not match linux-x64")
    node = _require_object(
        toolchain["node"],
        "Node toolchain",
        {"version", "npmVersion", "url", "sha256", "topLevelDirectory"},
    )
    _require_string(node["version"], "Node version")
    _require_string(node["npmVersion"], "npm version")
    _require_https_url(node["url"], "Node URL")
    _require_sha256(node["sha256"], "Node digest")
    _safe_leaf(node["topLevelDirectory"], "Node top-level directory")
    bun = _require_object(
        toolchain["bun"],
        "Bun toolchain",
        {"version", "url", "sha256", "topLevelDirectory"},
    )
    _require_string(bun["version"], "Bun version")
    _require_https_url(bun["url"], "Bun URL")
    _require_sha256(bun["sha256"], "Bun digest")
    _safe_leaf(bun["topLevelDirectory"], "Bun top-level directory")

    changed_paths = root["changedUpstreamPaths"]
    if not isinstance(changed_paths, list) or not changed_paths or changed_paths != sorted(set(changed_paths)):
        raise RuntimeFailure("changedUpstreamPaths must be a non-empty sorted unique list")
    for index, value in enumerate(changed_paths):
        _safe_relative_path(value, f"changedUpstreamPaths[{index}]")


def _safe_relative_path(value: Any, label: str = "archive path") -> PurePosixPath:
    raw = _require_string(value, label)
    raw_parts = raw.split("/")
    if (
        "\\" in raw
        or "\0" in raw
        or raw.startswith("/")
        or raw.endswith("/")
        or any(part in {"", ".", ".."} for part in raw_parts)
    ):
        raise RuntimeFailure(f"unsafe {label}: {raw!r}")
    return PurePosixPath(*raw_parts)


def _archive_member_path(name: str) -> PurePosixPath:
    raw = name[:-1] if name.endswith("/") else name
    return _safe_relative_path(raw, "archive member path")


def _set_mode(path: Path, mode: int) -> None:
    os.chmod(path, mode & 0o777, follow_symlinks=False)


def _safe_extract_tar(
    archive: Path,
    destination: Path,
    *,
    omit_symlinks: bool = False,
) -> set[str]:
    destination.mkdir(parents=True, exist_ok=False)
    seen: set[str] = set()
    directory_modes: list[tuple[Path, int]] = []
    try:
        with tarfile.open(archive, "r:*") as source:
            for member in source:
                relative = _archive_member_path(member.name)
                name = relative.as_posix()
                if name in seen:
                    raise RuntimeFailure(f"duplicate archive member: {name}")
                seen.add(name)
                target = destination.joinpath(*relative.parts)
                if member.isdir():
                    if target.exists() and not target.is_dir():
                        raise RuntimeFailure(f"archive member overwrites a non-directory: {name}")
                    target.mkdir(parents=True, exist_ok=True)
                    directory_modes.append((target, member.mode))
                    continue
                if member.issym() and omit_symlinks:
                    continue
                if not member.isfile():
                    raise RuntimeFailure(f"archive member is not a regular file or directory: {name}")
                target.parent.mkdir(parents=True, exist_ok=True)
                if target.exists() or target.is_symlink():
                    raise RuntimeFailure(f"archive member overwrites an existing path: {name}")
                extracted = source.extractfile(member)
                if extracted is None:
                    raise RuntimeFailure(f"cannot read archive member: {name}")
                with target.open("xb") as output:
                    shutil.copyfileobj(extracted, output)
                _set_mode(target, member.mode)
        for directory, mode in reversed(directory_modes):
            _set_mode(directory, mode)
        return seen
    except (OSError, tarfile.TarError) as error:
        raise RuntimeFailure(f"unsafe or unreadable tar archive: {error}") from error


def _safe_extract_zip(archive: Path, destination: Path) -> set[str]:
    destination.mkdir(parents=True, exist_ok=False)
    seen: set[str] = set()
    directory_modes: list[tuple[Path, int]] = []
    try:
        with zipfile.ZipFile(archive) as source:
            for member in source.infolist():
                relative = _archive_member_path(member.filename)
                name = relative.as_posix()
                if name in seen:
                    raise RuntimeFailure(f"duplicate archive member: {name}")
                seen.add(name)
                target = destination.joinpath(*relative.parts)
                archived_mode = (member.external_attr >> 16) & 0xFFFF
                file_type = stat.S_IFMT(archived_mode)
                is_directory = member.is_dir() or file_type == stat.S_IFDIR
                if file_type not in {0, stat.S_IFREG, stat.S_IFDIR}:
                    raise RuntimeFailure(f"zip member is not a regular file or directory: {name}")
                if is_directory:
                    if target.exists() and not target.is_dir():
                        raise RuntimeFailure(f"zip member overwrites a non-directory: {name}")
                    target.mkdir(parents=True, exist_ok=True)
                    directory_modes.append((target, archived_mode or 0o755))
                    continue
                target.parent.mkdir(parents=True, exist_ok=True)
                if target.exists() or target.is_symlink():
                    raise RuntimeFailure(f"zip member overwrites an existing path: {name}")
                with source.open(member) as extracted, target.open("xb") as output:
                    shutil.copyfileobj(extracted, output)
                _set_mode(target, archived_mode or 0o644)
        for directory, mode in reversed(directory_modes):
            _set_mode(directory, mode)
        return seen
    except (OSError, zipfile.BadZipFile) as error:
        raise RuntimeFailure(f"unsafe or unreadable zip archive: {error}") from error


def _exact_wrapper(destination: Path, expected: str, label: str) -> Path:
    children = list(destination.iterdir())
    if len(children) != 1 or children[0].name != expected or not children[0].is_dir() or children[0].is_symlink():
        raise RuntimeFailure(f"{label} does not have the exact {expected!r} wrapper directory")
    return children[0]


def _inventory(root: Path, *, excluded: set[str] | None = None) -> list[dict[str, Any]]:
    if not root.is_dir() or root.is_symlink():
        raise RuntimeFailure(f"inventory root is not a regular directory: {root}")
    excluded = excluded or set()
    records: list[dict[str, Any]] = []
    for path in sorted(root.rglob("*"), key=lambda item: item.relative_to(root).as_posix()):
        relative = path.relative_to(root).as_posix()
        if relative in excluded:
            continue
        info = path.lstat()
        mode = stat.S_IMODE(info.st_mode)
        if stat.S_ISDIR(info.st_mode):
            records.append({"path": relative, "type": "directory", "mode": mode})
        elif stat.S_ISREG(info.st_mode):
            records.append(
                {
                    "path": relative,
                    "type": "file",
                    "mode": mode,
                    "size": info.st_size,
                    "sha256": _sha256_file(path),
                }
            )
        else:
            raise RuntimeFailure(f"inventory rejects non-regular path: {relative}")
    return records


def _normalize_bundle_modes(bundle: Path) -> None:
    for path in sorted(bundle.rglob("*"), key=lambda item: len(item.parts), reverse=True):
        info = path.lstat()
        if stat.S_ISDIR(info.st_mode):
            _set_mode(path, 0o755)
        elif stat.S_ISREG(info.st_mode):
            _set_mode(path, 0o755 if path.relative_to(bundle).as_posix() == "pi" else 0o644)
        else:
            raise RuntimeFailure(f"standalone bundle contains a link or special file: {path}")
    _set_mode(bundle, 0o755)


def _tar_info(name: str, mode: int, *, directory: bool = False, size: int = 0) -> tarfile.TarInfo:
    info = tarfile.TarInfo(name + ("/" if directory and not name.endswith("/") else ""))
    info.type = tarfile.DIRTYPE if directory else tarfile.REGTYPE
    info.mode = mode
    info.size = 0 if directory else size
    info.mtime = 0
    info.uid = 0
    info.gid = 0
    info.uname = ""
    info.gname = ""
    return info


def _write_deterministic_artifact(output: Path, manifest_bytes: bytes, bundle: Path) -> None:
    output.parent.mkdir(parents=True, exist_ok=True)
    temporary = output.parent / f".{output.name}.tmp-{uuid.uuid4().hex}"
    try:
        with temporary.open("xb") as raw:
            with gzip.GzipFile(filename="", mode="wb", fileobj=raw, mtime=0, compresslevel=9) as compressed:
                with tarfile.open(fileobj=compressed, mode="w", format=tarfile.USTAR_FORMAT) as archive:
                    archive.addfile(_tar_info(ARTIFACT_WRAPPER, 0o755, directory=True))
                    manifest_name = f"{ARTIFACT_WRAPPER}/manifest.json"
                    archive.addfile(_tar_info(manifest_name, 0o644, size=len(manifest_bytes)), io.BytesIO(manifest_bytes))
                    bundle_name = f"{ARTIFACT_WRAPPER}/bundle"
                    archive.addfile(_tar_info(bundle_name, 0o755, directory=True))
                    for record in _inventory(bundle):
                        source = bundle / record["path"]
                        name = f"{bundle_name}/{record['path']}"
                        if record["type"] == "directory":
                            archive.addfile(_tar_info(name, record["mode"], directory=True))
                        else:
                            info = _tar_info(name, record["mode"], size=record["size"])
                            with source.open("rb") as content:
                                archive.addfile(info, content)
            raw.flush()
            os.fsync(raw.fileno())
        os.replace(temporary, output)
        _fsync_directory(output.parent)
    finally:
        temporary.unlink(missing_ok=True)


def _fsync_directory(path: Path) -> None:
    descriptor = os.open(path, os.O_RDONLY | os.O_DIRECTORY)
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def _ensure_private_directory(path: Path) -> None:
    path.mkdir(parents=True, mode=0o700, exist_ok=True)
    info = path.lstat()
    if not stat.S_ISDIR(info.st_mode) or stat.S_ISLNK(info.st_mode):
        raise RuntimeFailure(f"runtime parent is not a real directory: {path}")
    if info.st_uid != os.geteuid() or stat.S_IMODE(info.st_mode) & 0o022:
        raise RuntimeFailure(f"runtime parent is foreign-owned or group/world-writable: {path}")


MOUNTINFO_PATH = Path("/proc/self/mountinfo")


def _unescape_mountinfo_path(field: bytes) -> bytes:
    if re.search(rb"\\(?!(?:040|011|012|134))", field):
        raise RuntimeFailure("Linux mount topology contains a malformed path escape")
    return re.sub(rb"\\(040|011|012|134)", lambda match: bytes((int(match[1], 8),)), field)


def _parse_mountinfo_mount_points(content: bytes) -> frozenset[bytes]:
    if not content:
        raise RuntimeFailure("Linux mount topology is empty")
    mount_points: set[bytes] = set()
    for line in content.splitlines():
        fields = line.split(b" ")
        try:
            separator = fields.index(b"-", 6)
            major, minor = fields[2].split(b":", 1)
        except (ValueError, IndexError) as error:
            raise RuntimeFailure("Linux mount topology is malformed") from error
        if (
            b"" in fields
            or not fields[0].isdigit()
            or not fields[1].isdigit()
            or not major.isdigit()
            or not minor.isdigit()
            or separator + 4 != len(fields)
        ):
            raise RuntimeFailure("Linux mount topology is malformed")
        _unescape_mountinfo_path(fields[3])
        mount_point = _unescape_mountinfo_path(fields[4])
        if not mount_point.startswith(b"/"):
            raise RuntimeFailure("Linux mount topology contains a non-absolute mount point")
        mount_points.add(mount_point)
    return frozenset(mount_points)


def _mountinfo_mount_points() -> frozenset[bytes]:
    try:
        return _parse_mountinfo_mount_points(MOUNTINFO_PATH.read_bytes())
    except OSError as error:
        raise RuntimeFailure(f"cannot read Linux mount topology: {error}") from error


def _require_mount_free_tree(path: Path, label: str) -> None:
    try:
        encoded = os.fsencode(path.resolve(strict=False))
    except OSError as error:
        raise RuntimeFailure(f"cannot resolve {label} for mount validation: {error}") from error
    prefix = encoded + b"/"
    if any(point == encoded or point.startswith(prefix) for point in _mountinfo_mount_points()):
        raise RuntimeFailure(f"{label} is or contains a mount point")


def _private_child_directory(parent: Path, name: str, label: str, *, create: bool) -> Path:
    _ensure_private_directory(parent)
    child = parent.resolve(strict=True) / name
    if not create and not os.path.lexists(child):
        raise RuntimeFailure(f"{label} is missing")
    try:
        _ensure_private_directory(child)
        if child.resolve(strict=True) != child:
            raise RuntimeFailure(f"{label} escapes its owning root")
        _require_mount_free_tree(child, label)
    except OSError as error:
        raise RuntimeFailure(f"cannot create or inspect {label}: {error}") from error
    return child


@contextlib.contextmanager
def _exclusive_lock(parent: Path) -> Iterator[None]:
    _ensure_private_directory(parent)
    lock_path = parent / ".lock"
    descriptor = os.open(lock_path, os.O_RDWR | os.O_CREAT | os.O_CLOEXEC, 0o600)
    try:
        fcntl.flock(descriptor, fcntl.LOCK_EX)
        yield
    finally:
        fcntl.flock(descriptor, fcntl.LOCK_UN)
        os.close(descriptor)


def _validate_build_workspace(workspace: Path, cache_root: Path) -> None:
    try:
        cache = cache_root.resolve(strict=True)
    except OSError as error:
        raise RuntimeFailure(f"cannot resolve the build cache root: {error}") from error
    if workspace.parent != cache or workspace.name != BUILD_WORKSPACE_NAME:
        raise RuntimeFailure("deterministic build workspace is not the fixed cache child")
    try:
        info = workspace.lstat()
    except OSError as error:
        raise RuntimeFailure(f"cannot inspect the deterministic build workspace: {error}") from error
    if not stat.S_ISDIR(info.st_mode) or stat.S_ISLNK(info.st_mode):
        raise RuntimeFailure("deterministic build workspace is not a real directory")
    if info.st_uid != os.geteuid() or stat.S_IMODE(info.st_mode) & 0o022:
        raise RuntimeFailure("deterministic build workspace is foreign-owned or group/world-writable")
    try:
        if workspace.resolve(strict=True) != workspace:
            raise RuntimeFailure("deterministic build workspace is linked")
        _require_mount_free_tree(workspace, "deterministic build workspace")
    except OSError as error:
        raise RuntimeFailure(f"cannot validate the deterministic build workspace tree: {error}") from error


def _remove_build_workspace(workspace: Path, cache_root: Path, *, missing_ok: bool) -> None:
    if not os.path.lexists(workspace):
        if missing_ok:
            return
        raise RuntimeFailure("deterministic build workspace disappeared before cleanup")
    _validate_build_workspace(workspace, cache_root)
    if not shutil.rmtree.avoids_symlink_attacks:
        raise RuntimeFailure("safe deterministic build-workspace cleanup is unavailable")
    try:
        shutil.rmtree(workspace)
    except OSError as error:
        raise RuntimeFailure(f"cannot clean the deterministic build workspace: {error}") from error
    if os.path.lexists(workspace):
        raise RuntimeFailure("deterministic build workspace remains after cleanup")


@contextlib.contextmanager
def _deterministic_build_workspace(cache_root: Path) -> Iterator[Path]:
    _ensure_private_directory(cache_root)
    cache = cache_root.resolve(strict=True)
    workspace = cache / BUILD_WORKSPACE_NAME
    _remove_build_workspace(workspace, cache, missing_ok=True)
    try:
        workspace.mkdir(mode=0o700)
        _validate_build_workspace(workspace, cache)
    except OSError as error:
        raise RuntimeFailure(f"cannot create the deterministic build workspace: {error}") from error
    try:
        yield workspace
    finally:
        _remove_build_workspace(workspace, cache, missing_ok=False)


def _disable_network() -> None:
    """Install an x86_64 seccomp filter denying Internet sockets/connect."""

    class SockFilter(ctypes.Structure):
        _fields_ = [
            ("code", ctypes.c_ushort),
            ("jt", ctypes.c_ubyte),
            ("jf", ctypes.c_ubyte),
            ("k", ctypes.c_uint),
        ]

    class SockFprog(ctypes.Structure):
        _fields_ = [("length", ctypes.c_ushort), ("filter", ctypes.POINTER(SockFilter))]

    load_word_absolute = 0x20
    jump_equal = 0x15
    return_constant = 0x06
    audit_arch_x86_64 = 0xC000003E
    seccomp_return_kill = 0x80000000
    seccomp_return_errno = 0x00050000 | errno.ENETUNREACH
    seccomp_return_allow = 0x7FFF0000
    syscall_socket = 41
    syscall_connect = 42
    address_family_inet = 2
    address_family_inet6 = 10
    instructions = (SockFilter * 12)(
        SockFilter(load_word_absolute, 0, 0, 4),
        SockFilter(jump_equal, 1, 0, audit_arch_x86_64),
        SockFilter(return_constant, 0, 0, seccomp_return_kill),
        SockFilter(load_word_absolute, 0, 0, 0),
        SockFilter(jump_equal, 0, 1, syscall_connect),
        SockFilter(return_constant, 0, 0, seccomp_return_errno),
        SockFilter(jump_equal, 0, 4, syscall_socket),
        SockFilter(load_word_absolute, 0, 0, 16),
        SockFilter(jump_equal, 1, 0, address_family_inet),
        SockFilter(jump_equal, 0, 1, address_family_inet6),
        SockFilter(return_constant, 0, 0, seccomp_return_errno),
        SockFilter(return_constant, 0, 0, seccomp_return_allow),
    )
    program = SockFprog(len(instructions), instructions)
    libc = ctypes.CDLL(None, use_errno=True)
    if libc.prctl(38, 1, 0, 0, 0) != 0 or libc.prctl(22, 2, ctypes.byref(program)) != 0:
        error_number = ctypes.get_errno()
        raise OSError(error_number, f"cannot install offline build seccomp filter: {os.strerror(error_number)}")


def _rename_exchange(first: Path, second: Path) -> None:
    libc = ctypes.CDLL(None, use_errno=True)
    renameat2 = getattr(libc, "renameat2", None)
    if renameat2 is None:
        raise RuntimeFailure("atomic symlink exchange is unavailable on this Linux runtime")
    renameat2.argtypes = [ctypes.c_int, ctypes.c_char_p, ctypes.c_int, ctypes.c_char_p, ctypes.c_uint]
    renameat2.restype = ctypes.c_int
    result = renameat2(-100, os.fsencode(first), -100, os.fsencode(second), 2)
    if result != 0:
        error_number = ctypes.get_errno()
        raise RuntimeFailure(f"atomic exchange failed: {os.strerror(error_number)}")
    _fsync_directory(first.parent)


class RuntimeEngine:
    def __init__(self, spec: RuntimeSpec):
        self.spec = spec
        _validate_manifest(spec.manifest, spec.manifest_path, spec.repository_root)

    @property
    def manifest(self) -> Mapping[str, Any]:
        return self.spec.manifest

    @property
    def patch_path(self) -> Path:
        return self.spec.manifest_path.parent / self.manifest["patch"]["path"]

    def _archive_root(self, *, create: bool) -> Path:
        return _private_child_directory(self.spec.cache_root, "archives", "archive cache root", create=create)

    def _npm_cache_root(self) -> Path:
        return _private_child_directory(self.spec.cache_root, "npm-cache", "offline npm cache root", create=False)

    def _generation_root(self, *, create: bool) -> Path:
        return _private_child_directory(self.spec.data_root, "generations", "generation root", create=create)

    @property
    def archive_specs(self) -> tuple[tuple[str, Mapping[str, Any], Path], ...]:
        archives = self.spec.cache_root / "archives"
        return (
            ("source", self.manifest["upstream"]["sourceArchive"], archives / "pi-source.tar.gz"),
            ("node", self.manifest["buildToolchain"]["node"], archives / "node-linux-x64.tar.xz"),
            ("bun", self.manifest["buildToolchain"]["bun"], archives / "bun-linux-x64.zip"),
        )

    def _open_url(self, url: str) -> BinaryIO:
        if self.spec.opener is not None:
            return self.spec.opener(url)
        request = urllib.request.Request(url, headers={"User-Agent": "qq-pi-runtime/1"})
        return urllib.request.urlopen(request, timeout=120)  # noqa: S310 - URL is manifest-validated HTTPS.

    def _fetch_archive(self, label: str, archive_spec: Mapping[str, Any], destination: Path) -> None:
        archives = self._archive_root(create=True)
        if destination.parent != archives:
            raise RuntimeFailure("archive destination is outside the exact archive cache root")
        expected = archive_spec["sha256"]
        if destination.is_file() and not destination.is_symlink() and _sha256_file(destination) == expected:
            return
        temporary = destination.parent / f".{destination.name}.part-{uuid.uuid4().hex}"
        try:
            digest = hashlib.sha256()
            with self._open_url(archive_spec["url"]) as response, temporary.open("xb") as output:
                while chunk := response.read(1024 * 1024):
                    output.write(chunk)
                    digest.update(chunk)
                output.flush()
                os.fsync(output.fileno())
            if digest.hexdigest() != expected:
                raise RuntimeFailure(f"downloaded {label} archive digest mismatch")
            os.replace(temporary, destination)
            _fsync_directory(destination.parent)
        except OSError as error:
            raise RuntimeFailure(f"cannot fetch {label} archive: {error}") from error
        finally:
            temporary.unlink(missing_ok=True)

    def _extract_source(self, archive: Path, parent: Path) -> Path:
        destination = parent / "source-extract"
        _safe_extract_tar(archive, destination)
        return _exact_wrapper(
            destination,
            self.manifest["upstream"]["sourceArchive"]["topLevelDirectory"],
            "source archive",
        )

    def _extract_toolchain(self, parent: Path) -> tuple[Path, Path, Path]:
        archive_paths = {label: path for label, _, path in self.archive_specs}
        node_extract = parent / "node-extract"
        # The pinned official Node archive has npm/npx/corepack convenience symlinks.
        # They are not materialized: qq invokes the pinned npm-cli.js directly.
        _safe_extract_tar(archive_paths["node"], node_extract, omit_symlinks=True)
        node_root = _exact_wrapper(
            node_extract,
            self.manifest["buildToolchain"]["node"]["topLevelDirectory"],
            "Node archive",
        )
        bun_extract = parent / "bun-extract"
        _safe_extract_zip(archive_paths["bun"], bun_extract)
        bun_root = _exact_wrapper(
            bun_extract,
            self.manifest["buildToolchain"]["bun"]["topLevelDirectory"],
            "Bun archive",
        )
        node = node_root / "bin" / "node"
        npm_cli = node_root / "lib" / "node_modules" / "npm" / "bin" / "npm-cli.js"
        bun = bun_root / "bun"
        for label, path in (("Node", node), ("npm", npm_cli), ("Bun", bun)):
            if not path.is_file() or path.is_symlink():
                raise RuntimeFailure(f"pinned {label} executable is absent from its archive")
        _set_mode(node, 0o755)
        _set_mode(bun, 0o755)
        # npm package scripts recursively invoke `npm`. The official archive's
        # convenience entry is a symlink, which safe extraction deliberately
        # does not materialize, so create a local regular-file launcher.
        npm_launcher = node_root / "bin" / "npm"
        npm_launcher.write_text(
            '#!/bin/sh\nexec "$(dirname -- "$0")/node" '
            '"$(dirname -- "$0")/../lib/node_modules/npm/bin/npm-cli.js" "$@"\n',
            encoding="utf-8",
        )
        _set_mode(npm_launcher, 0o755)
        self._verify_tool_versions(node, npm_cli, bun)
        return node, npm_cli, bun

    def _verify_tool_versions(self, node: Path, npm_cli: Path, bun: Path) -> None:
        expected_node = f"v{self.manifest['buildToolchain']['node']['version']}"
        expected_npm = self.manifest["buildToolchain"]["node"]["npmVersion"]
        expected_bun = self.manifest["buildToolchain"]["bun"]["version"]
        probes = (
            ("Node", [str(node), "--version"], expected_node),
            ("npm", [str(node), str(npm_cli), "--version"], expected_npm),
            ("Bun", [str(bun), "--version"], expected_bun),
        )
        for label, command, expected in probes:
            try:
                result = subprocess.run(
                    command,
                    check=True,
                    text=True,
                    capture_output=True,
                    timeout=20,
                    preexec_fn=_disable_network,
                )
            except (OSError, subprocess.SubprocessError) as error:
                raise RuntimeFailure(f"cannot execute pinned {label}: {error}") from error
            if result.stdout.strip() != expected:
                raise RuntimeFailure(f"pinned {label} version mismatch")

    def _model_data_lock(self, source_root: Path) -> Path:
        model_data = self.manifest["offlineModelData"]
        lock_path = source_root.joinpath(*PurePosixPath(model_data["lockfilePath"]).parts)
        try:
            lock = json.loads(lock_path.read_text(encoding="utf-8"))
            package_record = lock["packages"][f"node_modules/{model_data['package']}"]
        except (OSError, json.JSONDecodeError, KeyError, TypeError) as error:
            raise RuntimeFailure(f"offline model-data lock entry is absent or invalid: {error}") from error
        if package_record.get("version") != model_data["version"] or package_record.get("resolved") != model_data[
            "resolvedUrl"
        ]:
            raise RuntimeFailure("offline model-data package does not equal its exact source-lock entry")
        return lock_path

    def _npm_cache_marker(self, cache: Path, source_root: Path) -> dict[str, Any]:
        lock = source_root / "package-lock.json"
        model_data_lock = self._model_data_lock(source_root)
        return {
            "schemaVersion": CACHE_SCHEMA_VERSION,
            "sourceArchiveSha256": self.manifest["upstream"]["sourceArchive"]["sha256"],
            "lockSha256": _sha256_file(lock),
            "modelDataLockSha256": _sha256_file(model_data_lock),
            "modelDataArchiveSha256": self.manifest["offlineModelData"]["archiveSha256"],
            "nodeSha256": self.manifest["buildToolchain"]["node"]["sha256"],
            "npmVersion": self.manifest["buildToolchain"]["node"]["npmVersion"],
            "inventory": _inventory(cache, excluded={".qq-cache-manifest.json"}),
        }

    def _validate_npm_cache(self, cache: Path, source_root: Path | None = None) -> None:
        marker_path = cache / ".qq-cache-manifest.json"
        try:
            marker_bytes = marker_path.read_bytes()
            marker = json.loads(marker_bytes)
        except (OSError, json.JSONDecodeError) as error:
            raise RuntimeFailure(f"offline npm cache marker is absent or invalid: {error}") from error
        if marker_bytes != _canonical_json(marker):
            raise RuntimeFailure("offline npm cache marker is not canonical")
        expected_fixed = {
            "schemaVersion": CACHE_SCHEMA_VERSION,
            "sourceArchiveSha256": self.manifest["upstream"]["sourceArchive"]["sha256"],
            "modelDataArchiveSha256": self.manifest["offlineModelData"]["archiveSha256"],
            "nodeSha256": self.manifest["buildToolchain"]["node"]["sha256"],
            "npmVersion": self.manifest["buildToolchain"]["node"]["npmVersion"],
        }
        for key, value in expected_fixed.items():
            if marker.get(key) != value:
                raise RuntimeFailure(f"offline npm cache {key} mismatch")
        if source_root is not None:
            if marker.get("lockSha256") != _sha256_file(source_root / "package-lock.json"):
                raise RuntimeFailure("offline npm cache package lock mismatch")
            if marker.get("modelDataLockSha256") != _sha256_file(self._model_data_lock(source_root)):
                raise RuntimeFailure("offline npm cache model-data lock mismatch")
        model_data_cache = cache / ".qq-model-data"
        if not model_data_cache.is_dir() or model_data_cache.is_symlink():
            raise RuntimeFailure("offline npm cache has no pinned model data")
        if marker.get("inventory") != _inventory(cache, excluded={".qq-cache-manifest.json"}):
            raise RuntimeFailure("offline npm cache inventory mismatch")

    def _offline_environment(self, root: Path, node: Path, bun: Path, npm_cache: Path) -> dict[str, str]:
        home = root / "home"
        temporary = root / "tmp"
        cache_home = root / "xdg-cache"
        data_home = root / "xdg-data"
        state_home = root / "xdg-state"
        for path in (home, temporary, cache_home, data_home, state_home):
            path.mkdir(parents=True, mode=0o700, exist_ok=True)
        refusal_proxy = "http://127.0.0.1:9"
        return {
            "PATH": f"{node.parent}:{bun.parent}:/usr/bin:/bin",
            "HOME": str(home),
            "TMPDIR": str(temporary),
            "XDG_CACHE_HOME": str(cache_home),
            "XDG_DATA_HOME": str(data_home),
            "XDG_STATE_HOME": str(state_home),
            "CI": "1",
            "LANG": "C.UTF-8",
            "LC_ALL": "C.UTF-8",
            "TZ": "UTC",
            "SOURCE_DATE_EPOCH": "0",
            "PI_OFFLINE": "1",
            "npm_config_cache": str(npm_cache),
            "npm_config_offline": "true",
            "npm_config_ignore_scripts": "true",
            "npm_config_audit": "false",
            "npm_config_fund": "false",
            "npm_config_update_notifier": "false",
            "HTTP_PROXY": refusal_proxy,
            "HTTPS_PROXY": refusal_proxy,
            "ALL_PROXY": refusal_proxy,
            "http_proxy": refusal_proxy,
            "https_proxy": refusal_proxy,
            "all_proxy": refusal_proxy,
            "NO_PROXY": "",
            "no_proxy": "",
            "BUN_RUNTIME_TRANSPILER_CACHE_PATH": "0",
        }

    def _publish_cache_directory(self, candidate: Path, destination: Path) -> None:
        _require_mount_free_tree(candidate, "offline npm cache candidate")
        if os.path.lexists(destination):
            self._npm_cache_root()
            _rename_exchange(candidate, destination)
            _require_mount_free_tree(candidate, "replaced offline npm cache")
            shutil.rmtree(candidate)
        else:
            _require_mount_free_tree(destination, "offline npm cache root")
            os.replace(candidate, destination)
            _fsync_directory(destination.parent)

    def _hydrate_npm_cache(self, source_archive: Path, parent: Path) -> None:
        cache = self.spec.cache_root / "npm-cache"
        with tempfile.TemporaryDirectory(prefix=".npm-hydrate-", dir=parent) as temporary_name:
            temporary = Path(temporary_name)
            source_root = self._extract_source(source_archive, temporary)
            if os.path.lexists(cache):
                self._npm_cache_root()
                try:
                    self._validate_npm_cache(cache, source_root)
                    return
                except RuntimeFailure:
                    pass
            node, npm_cli, bun = self._extract_toolchain(temporary)
            candidate = parent / f".npm-cache-candidate-{uuid.uuid4().hex}"
            candidate.mkdir(mode=0o700)
            environment = self._offline_environment(temporary / "fetch-environment", node, bun, candidate)
            # Fetch is the sole network-capable phase. npm's reviewed lock controls
            # registry URLs/integrities; lifecycle scripts, audit, and funding calls stay off.
            for proxy_name in (
                "HTTP_PROXY",
                "HTTPS_PROXY",
                "ALL_PROXY",
                "http_proxy",
                "https_proxy",
                "all_proxy",
            ):
                environment.pop(proxy_name, None)
            environment["npm_config_offline"] = "false"
            try:
                npm_ci = [
                    str(node),
                    str(npm_cli),
                    "ci",
                    "--ignore-scripts",
                    "--no-audit",
                    "--no-fund",
                    "--cache",
                    str(candidate),
                ]
                subprocess.run(npm_ci, cwd=source_root, env=environment, check=True)
                model_data = self.manifest["offlineModelData"]
                install_lock_root = self._model_data_lock(source_root).parent
                subprocess.run(npm_ci, cwd=install_lock_root, env=environment, check=True)
                matching_archives = [
                    path
                    for path in candidate.rglob("*")
                    if path.is_file()
                    and not path.is_symlink()
                    and _sha256_file(path) == model_data["archiveSha256"]
                ]
                if len(matching_archives) != 1:
                    raise RuntimeFailure("npm cache does not contain exactly one pinned model-data package archive")
                installed_package = install_lock_root / "node_modules"
                installed_package = installed_package.joinpath(*model_data["package"].split("/"))
                try:
                    package = json.loads((installed_package / "package.json").read_text(encoding="utf-8"))
                except (OSError, json.JSONDecodeError) as error:
                    raise RuntimeFailure(f"installed model-data package is invalid: {error}") from error
                if package.get("name") != model_data["package"] or package.get("version") != model_data["version"]:
                    raise RuntimeFailure("installed model-data package identity mismatch")
                installed_data = installed_package.joinpath(*PurePosixPath(model_data["dataPath"]).parts)
                source_data = source_root / "packages" / "ai" / "src" / "providers" / "data"
                shutil.copytree(installed_data, source_data)
                subprocess.run(
                    [str(node), str(source_root / "packages/ai/scripts/check-model-data.ts")],
                    cwd=source_root,
                    env=environment,
                    check=True,
                )
                shutil.copytree(source_data, candidate / ".qq-model-data")
                shutil.rmtree(source_root / "node_modules", ignore_errors=True)
                shutil.rmtree(install_lock_root / "node_modules", ignore_errors=True)
                marker = self._npm_cache_marker(candidate, source_root)
                (candidate / ".qq-cache-manifest.json").write_bytes(_canonical_json(marker))
                self._validate_npm_cache(candidate, source_root)
                self._publish_cache_directory(candidate, cache)
            except (OSError, subprocess.SubprocessError) as error:
                raise RuntimeFailure(f"cannot hydrate exact-lock npm cache: {error}") from error
            finally:
                if candidate.exists():
                    _require_mount_free_tree(candidate, "offline npm cache candidate")
                    shutil.rmtree(candidate)

    def fetch(self) -> dict[str, Any]:
        self._check_platform()
        with _exclusive_lock(self.spec.cache_root):
            for label, archive_spec, destination in self.archive_specs:
                self._fetch_archive(label, archive_spec, destination)
            source_archive = dict((label, path) for label, _, path in self.archive_specs)["source"]
            self._hydrate_npm_cache(source_archive, self.spec.cache_root)
            return {
                "cacheRoot": str(self.spec.cache_root.resolve()),
                "archives": {
                    label: {"path": str(path.resolve()), "sha256": archive_spec["sha256"]}
                    for label, archive_spec, path in self.archive_specs
                },
                "npmCache": str((self.spec.cache_root / "npm-cache").resolve()),
            }

    def _check_platform(self) -> None:
        machine = platform.machine().lower()
        if sys.platform != "linux" or machine not in {"x86_64", "amd64"}:
            raise RuntimeFailure("qq's patched Pi runtime supports Linux x64 only")

    def _require_build_cache(self, source_root: Path | None = None) -> None:
        self._archive_root(create=False)
        for label, archive_spec, path in self.archive_specs:
            if not path.is_file() or path.is_symlink():
                raise RuntimeFailure(f"cached {label} archive is absent; run fetch")
            if _sha256_file(path) != archive_spec["sha256"]:
                raise RuntimeFailure(f"cached {label} archive digest mismatch; run fetch")
        self._validate_npm_cache(self._npm_cache_root(), source_root)

    def _patch_paths(self) -> list[str]:
        paths: set[str] = set()
        try:
            for line in self.patch_path.read_text(encoding="utf-8").splitlines():
                if not line.startswith("+++ "):
                    continue
                raw = line[4:].split("\t", 1)[0]
                if raw == "/dev/null":
                    continue
                if raw.startswith("b/"):
                    raw = raw[2:]
                paths.add(_safe_relative_path(raw, "patch target path").as_posix())
        except OSError as error:
            raise RuntimeFailure(f"cannot inspect durable patch: {error}") from error
        return sorted(paths)

    def _apply_patch(self, source_root: Path) -> None:
        if self._patch_paths() != self.manifest["changedUpstreamPaths"]:
            raise RuntimeFailure("durable patch target set differs from changedUpstreamPaths")
        base = [
            "patch",
            f"-p{self.manifest['patch']['stripComponents']}",
            "--batch",
            "--forward",
            "--fuzz=0",
            "--input",
            str(self.patch_path),
        ]
        patch_tmp = source_root / ".qq-patch-tmp"
        patch_tmp.mkdir(mode=0o700, exist_ok=True)
        environment = {
            "PATH": "/usr/bin:/bin",
            "LANG": "C",
            "LC_ALL": "C",
            "TMPDIR": str(patch_tmp),
        }
        try:
            subprocess.run(
                base + ["--dry-run"],
                cwd=source_root,
                env=environment,
                check=True,
                capture_output=True,
                preexec_fn=_disable_network,
            )
            subprocess.run(
                base,
                cwd=source_root,
                env=environment,
                check=True,
                capture_output=True,
                preexec_fn=_disable_network,
            )
        except subprocess.CalledProcessError as error:
            detail = (error.stderr or error.stdout or b"").decode(errors="replace").strip()
            raise RuntimeFailure(f"Pi patch preimage/apply mismatch: {detail}") from error
        package_path = source_root / "packages" / "coding-agent" / "package.json"
        try:
            package = json.loads(package_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as error:
            raise RuntimeFailure(f"patched coding-agent package is invalid: {error}") from error
        expected = self.manifest["patchedIdentity"]
        if package.get("version") != expected["packageVersion"] or package.get("piConfig", {}).get(
            "buildIdentity"
        ) != expected["buildIdentity"]:
            raise RuntimeFailure("patched source does not expose the manifest identity")

    def _run_build_commands(
        self,
        source_root: Path,
        node: Path,
        npm_cli: Path,
        bun: Path,
        environment: Mapping[str, str],
    ) -> Path:
        npm = [str(node), str(npm_cli)]
        commands: list[list[str]] = [
            npm + ["ci", "--ignore-scripts", "--offline", "--no-audit", "--no-fund"],
            npm + ["--prefix", "packages/tui", "run", "build"],
            npm + ["--prefix", "packages/ai", "run", "build:offline"],
            npm + ["--prefix", "packages/agent", "run", "build"],
            npm + ["--prefix", "packages/storage/sqlite-node", "run", "build"],
            npm + ["--prefix", "packages/coding-agent", "run", "build"],
            npm + ["--prefix", "packages/server", "run", "build"],
        ]
        try:
            for command in commands:
                subprocess.run(
                    command,
                    cwd=source_root,
                    env=dict(environment),
                    check=True,
                    preexec_fn=_disable_network,
                )
            output = source_root / ".qq-binary-output"
            subprocess.run(
                [
                    str(source_root / "scripts" / "build-binaries.sh"),
                    "--skip-install",
                    "--skip-deps",
                    "--skip-build",
                    "--platform",
                    EXPECTED_PLATFORM,
                    "--out",
                    str(output),
                ],
                cwd=source_root,
                env=dict(environment),
                check=True,
                preexec_fn=_disable_network,
            )
        except (OSError, subprocess.SubprocessError) as error:
            raise RuntimeFailure(f"offline patched Pi build failed: {error}") from error
        bundle = output / EXPECTED_PLATFORM
        if not bundle.is_dir() or bundle.is_symlink():
            raise RuntimeFailure("upstream standalone build did not produce the Linux-x64 bundle")
        return bundle

    def _provenance(self) -> dict[str, Any]:
        upstream = self.manifest["upstream"]
        toolchain = self.manifest["buildToolchain"]
        return {
            "manifestSchemaVersion": self.manifest["schemaVersion"],
            "manifestVersion": self.manifest["manifestVersion"],
            "upstreamRepository": upstream["repository"],
            "upstreamReleaseTag": upstream["releaseTag"],
            "upstreamCommit": upstream["commit"],
            "sourceArchiveSha256": upstream["sourceArchive"]["sha256"],
            "patchSha256": self.manifest["patch"]["sha256"],
            "patchedIdentity": self.manifest["patchedIdentity"],
            "offlineModelData": self.manifest["offlineModelData"],
            "platform": EXPECTED_PLATFORM,
            "node": {
                "version": toolchain["node"]["version"],
                "npmVersion": toolchain["node"]["npmVersion"],
                "url": toolchain["node"]["url"],
                "sha256": toolchain["node"]["sha256"],
            },
            "bun": {
                "version": toolchain["bun"]["version"],
                "url": toolchain["bun"]["url"],
                "sha256": toolchain["bun"]["sha256"],
            },
            "buildEngineVersion": ENGINE_VERSION,
        }

    def create_artifact(self, bundle: Path, output: Path) -> dict[str, Any]:
        if not bundle.is_dir() or bundle.is_symlink():
            raise RuntimeFailure("artifact bundle must be a real directory")
        _normalize_bundle_modes(bundle)
        self._check_binary_identity(bundle / "pi", output.parent)
        artifact_manifest = {
            "schemaVersion": ARTIFACT_SCHEMA_VERSION,
            "provenance": self._provenance(),
            "inventory": _inventory(bundle),
        }
        manifest_bytes = _canonical_json(artifact_manifest)
        generation = _sha256_bytes(manifest_bytes)
        _write_deterministic_artifact(output, manifest_bytes, bundle)
        return {
            "artifact": str(output.resolve()),
            "artifactSha256": _sha256_file(output),
            "generation": generation,
            "identity": self.manifest["patchedIdentity"]["reportedVersion"],
        }

    def build(self, output: Path) -> dict[str, Any]:
        self._check_platform()
        output = output.resolve()
        if output.exists() and (not output.is_file() or output.is_symlink()):
            raise RuntimeFailure("build output must be a regular file path")
        deterministic_workspace = self.spec.cache_root.resolve() / BUILD_WORKSPACE_NAME
        if output == deterministic_workspace or deterministic_workspace in output.parents:
            raise RuntimeFailure("build output may not be inside the disposable build workspace")
        with _exclusive_lock(self.spec.cache_root):
            self._require_build_cache()
            with _deterministic_build_workspace(self.spec.cache_root) as workspace:
                source_archive = dict((label, path) for label, _, path in self.archive_specs)["source"]
                source_root = self._extract_source(source_archive, workspace)
                self._require_build_cache(source_root)
                self._apply_patch(source_root)
                source_model_data = source_root / "packages" / "ai" / "src" / "providers" / "data"
                shutil.copytree(self.spec.cache_root / "npm-cache" / ".qq-model-data", source_model_data)
                node, npm_cli, bun = self._extract_toolchain(workspace)
                build_npm_cache = workspace / "npm-cache"
                shutil.copytree(self.spec.cache_root / "npm-cache", build_npm_cache)
                environment = self._offline_environment(workspace / "build-environment", node, bun, build_npm_cache)
                bundle = self._run_build_commands(source_root, node, npm_cli, bun, environment)
                return self.create_artifact(bundle, output)

    def _load_artifact_manifest(self, wrapper: Path) -> tuple[dict[str, Any], bytes]:
        manifest_path = wrapper / "manifest.json"
        if manifest_path.is_symlink() or not manifest_path.is_file():
            raise RuntimeFailure("artifact manifest is absent or not a regular file")
        try:
            manifest_bytes = manifest_path.read_bytes()
            artifact_manifest = json.loads(manifest_bytes)
        except (OSError, json.JSONDecodeError) as error:
            raise RuntimeFailure(f"artifact manifest is invalid: {error}") from error
        if manifest_bytes != _canonical_json(artifact_manifest):
            raise RuntimeFailure("artifact manifest is not canonical")
        root = _require_object(
            artifact_manifest,
            "artifact manifest",
            {"schemaVersion", "provenance", "inventory"},
        )
        if root["schemaVersion"] != ARTIFACT_SCHEMA_VERSION:
            raise RuntimeFailure("unsupported artifact schema")
        if root["provenance"] != self._provenance():
            raise RuntimeFailure("artifact provenance does not equal the current Repository manifest")
        if not isinstance(root["inventory"], list):
            raise RuntimeFailure("artifact inventory must be a list")
        return dict(root), manifest_bytes

    def _verify_inventory(self, bundle: Path, expected: Any) -> None:
        if not bundle.is_dir() or bundle.is_symlink():
            raise RuntimeFailure("artifact bundle is absent or not a real directory")
        actual = _inventory(bundle)
        if expected != actual:
            raise RuntimeFailure("artifact inventory has extras, missing files, or type/mode/digest differences")
        paths = [record.get("path") for record in expected if isinstance(record, dict)]
        if paths != sorted(set(paths)):
            raise RuntimeFailure("artifact inventory paths are not sorted and unique")
        binary_records = [record for record in expected if record.get("path") == "pi"]
        if len(binary_records) != 1 or binary_records[0].get("type") != "file" or not (
            binary_records[0].get("mode", 0) & 0o111
        ):
            raise RuntimeFailure("artifact inventory does not contain one executable Pi binary")

    def _check_binary_identity(self, binary: Path, temporary_parent: Path) -> None:
        if not binary.is_file() or binary.is_symlink() or not os.access(binary, os.X_OK):
            raise RuntimeFailure("Pi binary is absent, linked, or non-executable")
        temporary_parent.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix=".identity-", dir=temporary_parent) as temporary_name:
            root = Path(temporary_name)
            environment = self._offline_environment(root, binary, binary, root / "npm-cache")
            try:
                result = subprocess.run(
                    [str(binary), "--version"],
                    cwd=binary.parent,
                    env=environment,
                    check=True,
                    text=True,
                    capture_output=True,
                    timeout=20,
                    preexec_fn=_disable_network,
                )
            except (OSError, subprocess.SubprocessError) as error:
                raise RuntimeFailure(f"Pi binary identity probe failed: {error}") from error
        expected = self.manifest["patchedIdentity"]["reportedVersion"]
        if result.stdout.strip() != expected:
            raise RuntimeFailure(f"Pi binary identity is not exactly {expected}")

    def _inspect_extracted(self, extraction: Path) -> tuple[Path, dict[str, Any], bytes]:
        wrapper = _exact_wrapper(extraction, ARTIFACT_WRAPPER, "artifact")
        children = sorted(path.name for path in wrapper.iterdir())
        if children != ["bundle", "manifest.json"]:
            raise RuntimeFailure("artifact wrapper contains an unexpected path")
        artifact_manifest, manifest_bytes = self._load_artifact_manifest(wrapper)
        bundle = wrapper / "bundle"
        self._verify_inventory(bundle, artifact_manifest["inventory"])
        self._check_binary_identity(bundle / "pi", extraction.parent)
        return wrapper, artifact_manifest, manifest_bytes

    def _extract_and_inspect(self, artifact: Path, parent: Path) -> tuple[Path, Path, dict[str, Any], bytes]:
        if not artifact.is_file() or artifact.is_symlink():
            raise RuntimeFailure("artifact must be a regular file")
        extraction = parent / f".artifact-{uuid.uuid4().hex}"
        _safe_extract_tar(artifact, extraction)
        wrapper, artifact_manifest, manifest_bytes = self._inspect_extracted(extraction)
        return extraction, wrapper, artifact_manifest, manifest_bytes

    def inspect_artifact(self, artifact: Path) -> dict[str, Any]:
        _ensure_private_directory(self.spec.cache_root)
        with tempfile.TemporaryDirectory(prefix=".inspect-", dir=self.spec.cache_root) as temporary_name:
            temporary = Path(temporary_name)
            extraction, _wrapper, _manifest, manifest_bytes = self._extract_and_inspect(artifact.resolve(), temporary)
            shutil.rmtree(extraction)
            return {
                "artifact": str(artifact.resolve()),
                "artifactSha256": _sha256_file(artifact.resolve()),
                "generation": _sha256_bytes(manifest_bytes),
                "identity": self.manifest["patchedIdentity"]["reportedVersion"],
                "valid": True,
            }

    def _read_generation_link(self, name: str, *, required: bool) -> tuple[str, Path] | None:
        link = self.spec.data_root / name
        if not os.path.lexists(link):
            if required:
                raise RuntimeFailure(f"active runtime link {name!r} is missing")
            return None
        info = link.lstat()
        if not stat.S_ISLNK(info.st_mode):
            raise RuntimeFailure(f"runtime link {name!r} is not a symlink")
        target = os.readlink(link)
        expected_prefix = "generations/"
        if not target.startswith(expected_prefix) or "/" in target[len(expected_prefix) :]:
            raise RuntimeFailure(f"runtime link {name!r} escapes the generation root")
        generation = _safe_leaf(target[len(expected_prefix) :], f"{name} generation")
        path = self.spec.data_root / "generations" / generation
        try:
            resolved = path.resolve(strict=True)
            resolved.relative_to((self.spec.data_root / "generations").resolve(strict=True))
        except (OSError, ValueError) as error:
            raise RuntimeFailure(f"runtime link {name!r} has a missing or escaping target") from error
        if resolved != path:
            raise RuntimeFailure(f"runtime link {name!r} resolves through a linked generation")
        return generation, path

    def _verify_owner_modes(self, root: Path) -> None:
        for path in [root, *sorted(root.rglob("*"))]:
            info = path.lstat()
            relative = path.relative_to(root).as_posix() if path != root else "."
            if info.st_uid != os.geteuid():
                raise RuntimeFailure(f"active generation has foreign-owned path: {relative}")
            if stat.S_IMODE(info.st_mode) & 0o022:
                raise RuntimeFailure(f"active generation has group/world-writable path: {relative}")

    def _verify_generation(self, generation: str, path: Path) -> Path:
        if path.name != generation or not path.is_dir() or path.is_symlink():
            raise RuntimeFailure("generation target is not a real confined directory")
        self._verify_owner_modes(path)
        artifact_manifest, manifest_bytes = self._load_artifact_manifest(path)
        if _sha256_bytes(manifest_bytes) != generation:
            raise RuntimeFailure("generation identity does not derive from its canonical manifest")
        allowed = sorted(child.name for child in path.iterdir())
        if allowed != ["bundle", "manifest.json"]:
            raise RuntimeFailure("generation contains an unexpected path")
        bundle = path / "bundle"
        self._verify_inventory(bundle, artifact_manifest["inventory"])
        binary = bundle / "pi"
        self._check_binary_identity(binary, Path(tempfile.gettempdir()))
        return binary.resolve(strict=True)

    def _atomic_symlink(self, target: str, link: Path) -> None:
        temporary = self.spec.data_root / f".{link.name}.tmp-{uuid.uuid4().hex}"
        try:
            os.symlink(target, temporary)
            os.replace(temporary, link)
            _fsync_directory(self.spec.data_root)
        finally:
            temporary.unlink(missing_ok=True)

    def install(self, artifact: Path) -> dict[str, Any]:
        _ensure_private_directory(self.spec.data_root)
        with _exclusive_lock(self.spec.data_root):
            generations = self._generation_root(create=True)
            temporary = Path(tempfile.mkdtemp(prefix=".install-", dir=self.spec.data_root))
            try:
                extraction, wrapper, _artifact_manifest, manifest_bytes = self._extract_and_inspect(
                    artifact.resolve(), temporary
                )
                generation = _sha256_bytes(manifest_bytes)
                target = generations / generation
                current = self._read_generation_link("current", required=False)
                previous_present = os.path.lexists(self.spec.data_root / "previous")
                if current is None and previous_present:
                    raise RuntimeFailure("previous runtime state exists without a valid current generation")
                if current is not None:
                    self._verify_generation(*current)
                    previous_link = self.spec.data_root / "previous"
                    if os.path.lexists(previous_link) and not previous_link.is_symlink():
                        raise RuntimeFailure("previous runtime state is not a symlink")
                if target.exists() or target.is_symlink():
                    self._verify_generation(generation, target)
                else:
                    os.replace(wrapper, target)
                    _fsync_directory(generations)
                if current is not None and current[0] == generation:
                    return {
                        "generation": generation,
                        "binary": str((target / "bundle" / "pi").resolve()),
                        "activated": False,
                        "idempotent": True,
                    }
                if current is not None:
                    self._atomic_symlink(f"generations/{current[0]}", self.spec.data_root / "previous")
                self._atomic_symlink(f"generations/{generation}", self.spec.data_root / "current")
                binary = self._verify_generation(generation, target)
                return {
                    "generation": generation,
                    "binary": str(binary),
                    "activated": True,
                    "idempotent": False,
                }
            finally:
                shutil.rmtree(temporary, ignore_errors=True)

    def verify_active(self) -> dict[str, Any]:
        _ensure_private_directory(self.spec.data_root)
        self._generation_root(create=False)
        current = self._read_generation_link("current", required=True)
        assert current is not None
        binary = self._verify_generation(*current)
        return {
            "generation": current[0],
            "binary": str(binary),
            "identity": self.manifest["patchedIdentity"]["reportedVersion"],
            "valid": True,
        }

    def rollback(self) -> dict[str, Any]:
        _ensure_private_directory(self.spec.data_root)
        with _exclusive_lock(self.spec.data_root):
            self._generation_root(create=False)
            current = self._read_generation_link("current", required=True)
            previous = self._read_generation_link("previous", required=True)
            assert current is not None and previous is not None
            current_binary = self._verify_generation(*current)
            previous_binary = self._verify_generation(*previous)
            if current[0] == previous[0]:
                raise RuntimeFailure("current and previous generations are identical")
            del current_binary, previous_binary
            _rename_exchange(self.spec.data_root / "current", self.spec.data_root / "previous")
            active = self.verify_active()
            active["rolledBack"] = True
            active["rollForwardGeneration"] = current[0]
            return active

    def execute(self, arguments: Sequence[str]) -> None:
        active = self.verify_active()
        binary = active["binary"]
        os.execv(binary, [binary, *arguments])


def _json_success(value: Mapping[str, Any]) -> None:
    print(json.dumps(value, sort_keys=True, separators=(",", ":")))


def _parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="qq-pi-runtime", description=__doc__)
    subcommands = parser.add_subparsers(dest="command", required=True)
    subcommands.add_parser("fetch", help="fetch and verify the pinned source, toolchain, and npm cache")
    build = subcommands.add_parser("build", help="build a deterministic patched Pi artifact offline")
    build.add_argument("--output", required=True, type=Path)
    inspect = subcommands.add_parser("inspect-artifact", help="verify an artifact without installing it")
    inspect.add_argument("artifact", type=Path)
    install = subcommands.add_parser("install", help="verify and atomically activate an artifact")
    install.add_argument("artifact", type=Path)
    subcommands.add_parser("verify", help="verify the active generation")
    subcommands.add_parser("rollback", help="atomically exchange current and previous generations")
    execute = subcommands.add_parser("exec", help="execute only the verified active Pi")
    execute.add_argument("arguments", nargs=argparse.REMAINDER)
    return parser


def main(arguments: Sequence[str] | None = None) -> int:
    parsed = _parser().parse_args(arguments)
    engine = RuntimeEngine(RuntimeSpec.production())
    if parsed.command == "fetch":
        _json_success(engine.fetch())
    elif parsed.command == "build":
        _json_success(engine.build(parsed.output))
    elif parsed.command == "inspect-artifact":
        _json_success(engine.inspect_artifact(parsed.artifact))
    elif parsed.command == "install":
        _json_success(engine.install(parsed.artifact))
    elif parsed.command == "verify":
        _json_success(engine.verify_active())
    elif parsed.command == "rollback":
        _json_success(engine.rollback())
    elif parsed.command == "exec":
        executable_arguments = list(parsed.arguments)
        if executable_arguments[:1] == ["--"]:
            executable_arguments.pop(0)
        engine.execute(executable_arguments)
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeFailure as error:
        print(f"qq-pi-runtime: refusing: {error}", file=sys.stderr)
        raise SystemExit(1)
