#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"
CALL_PWD="$(pwd -P)"
MOUNT_DIR="$ROOT/home"
MOUNTED_CODEX_ENTRYPOINT="$ROOT/adapter/codex-mounted.md"
MOUNTED_SIGNOFF_HELPER="$ROOT/bin/home-signoff"

die() {
  printf 'home: %s\n' "$1" >&2
  exit 1
}

usage() {
  cat <<'USAGE'
Usage:
  bin/home greenfield <name> <target-path>
  bin/home resolve [<path>]
  bin/home help

Create a greenfield external project repository and mount it under:
  home/<name>

The target gets only its local node shape:
  intent/organizing-document.md

No root methodology prose, root check script, root adapter directory, or root bin
directory is copied. The target receives root-managed direct-path entrypoint symlinks:
AGENTS.md points to the mounted-node Codex entrypoint.
signoff points to the home signoff helper.
Direct opens resolve their mount path through the governing root.
USAGE
}

validate_mount_name() {
  local name=$1
  [ -n "$name" ] || die "missing mount name"
  [[ "$name" != */* && "$name" != *\\* ]] || die "mount name must not be a path: $name"
  [[ "$name" != "." && "$name" != ".." ]] || die "mount name must not be $name"
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] \
    || die "mount name must start with a letter or number and contain only letters, numbers, dots, underscores, and hyphens: $name"
}

absolute_target_path() {
  local path=$1
  case "$path" in
    /*) realpath -m -- "$path" ;;
    *)  realpath -m -- "$CALL_PWD/$path" ;;
  esac
}

ensure_target_outside_root() {
  local target=$1
  case "$target" in
    "$ROOT"|"$ROOT"/*)
      die "target path must be outside the hypercore root: $target"
      ;;
  esac
}

ensure_empty_target() {
  local target=$1 first
  if [ -e "$target" ]; then
    [ -d "$target" ] || die "target exists and is not a directory: $target"
    first="$(find "$target" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null || true)"
    [ -z "$first" ] || die "target directory is not empty: $target"
  else
    mkdir -p "$target"
  fi
}

write_organizing_document() {
  local target=$1 name=$2
  mkdir -p "$target/intent"
  cat > "$target/intent/organizing-document.md" <<EOF
# organizing document

This node is the greenfield project mounted as \`$name\` through hypercore home.
It starts with only its local node shape. Project-specific intent segments are added by
later signed work in this node.
EOF
}

link_direct_path_entrypoints() {
  local target=$1
  [ -f "$MOUNTED_CODEX_ENTRYPOINT" ] \
    || die "mounted Codex entrypoint missing: ${MOUNTED_CODEX_ENTRYPOINT#"$ROOT"/}"
  [ -x "$MOUNTED_SIGNOFF_HELPER" ] \
    || die "mounted signoff helper missing or not executable: ${MOUNTED_SIGNOFF_HELPER#"$ROOT"/}"
  ln -s "$MOUNTED_CODEX_ENTRYPOINT" "$target/AGENTS.md"
  ln -s "$MOUNTED_SIGNOFF_HELPER" "$target/signoff"
}

cmd_resolve() {
  local path_arg=${1:-} query query_physical mount target_root
  [ -z "${2:-}" ] || die "usage: bin/home resolve [<path>]"
  command -v realpath >/dev/null 2>&1 || die "realpath is required"

  if [ -n "$path_arg" ]; then
    case "$path_arg" in
      /*) query=$path_arg ;;
      *)  query=$CALL_PWD/$path_arg ;;
    esac
  else
    query=$CALL_PWD
  fi

  [ -e "$query" ] || die "path does not exist: $query"
  query_physical="$(realpath -e -- "$query" 2>/dev/null)" \
    || die "cannot resolve path: $query"

  for mount in "$MOUNT_DIR"/*; do
    [ -L "$mount" ] || continue
    target_root="$(realpath -e -- "$mount" 2>/dev/null)" || continue
    case "$query_physical" in
      "$target_root"|"$target_root"/*)
        [ -d "$mount/intent" ] \
          || die "matched mount is not a node; missing intent/: ${mount#"$ROOT"/}"
        printf '%s\n' "${mount#"$ROOT"/}"
        return 0
        ;;
    esac
  done

  die "path is not under a mounted node: $query_physical"
}

cmd_greenfield() {
  local name=${1:-} target_arg=${2:-} target mount_path
  [ -n "$name" ] && [ -n "$target_arg" ] && [ -z "${3:-}" ] \
    || die "usage: bin/home greenfield <name> <target-path>"
  validate_mount_name "$name"
  command -v git >/dev/null 2>&1 || die "git is required"
  command -v realpath >/dev/null 2>&1 || die "realpath is required"

  target="$(absolute_target_path "$target_arg")"
  ensure_target_outside_root "$target"

  mkdir -p "$MOUNT_DIR"
  mount_path="$MOUNT_DIR/$name"
  [ ! -e "$mount_path" ] && [ ! -L "$mount_path" ] \
    || die "mount path already exists: ${mount_path#"$ROOT"/}"

  ensure_empty_target "$target"
  git -C "$target" init --quiet
  write_organizing_document "$target" "$name"
  link_direct_path_entrypoints "$target"
  ln -s "$target" "$mount_path"

  printf 'created %s\n' "$target"
  printf 'mounted %s -> %s\n' "${mount_path#"$ROOT"/}" "$target"
}

case "${1:-}" in
  greenfield)
    shift
    cmd_greenfield "$@"
    ;;
  resolve)
    shift
    cmd_resolve "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  "")
    usage >&2
    exit 2
    ;;
  *)
    die "unknown command: $1"
    ;;
esac
