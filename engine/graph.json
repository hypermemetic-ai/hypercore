      }
    },
    {
      "created_at": "2026-06-10T01:59:22.858570",
      "id": "endorsement-1",
      "kind": "statement",
      "label": "Endorsement names who stands behind a statement.",
      "props": {
        "ord": 1,
        "owner": "operator",
        "segment": "endorsement"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.867746",
      "id": "endorsement-2",
      "kind": "statement",
      "label": "An endorsed statement is operator-owned.",
      "props": {
        "ord": 2,
        "owner": "operator",
        "segment": "endorsement"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.880074",
      "id": "endorsement-3",
      "kind": "statement",
      "label": "An unendorsed statement is machine-owned until an operator takes it on.",
      "props": {
        "ord": 3,
        "owner": "operator",
        "segment": "endorsement"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.889168",
      "id": "endorsement-4",
      "kind": "statement",
      "label": "The machine never endorses for the operator.",
      "props": {
        "ord": 4,
        "owner": "operator",
        "segment": "endorsement"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.897839",
      "id": "endorsement-5",
      "kind": "statement",
      "label": "Ownership and truth are separate. Ownership says who may responsibly change a statement; evidence says whether it still holds.",
      "props": {
        "ord": 5,
        "owner": "operator",
        "segment": "endorsement"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.905727",
      "id": "endorsement-6",
      "kind": "statement",
      "label": "An intent is operator-owned or machine-owned. The material that corresponds to it answers to whichever stands behind it.",
      "props": {
        "ord": 6,
        "owner": "operator",
        "segment": "endorsement"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.914827",
      "id": "endorsement-7",
      "kind": "statement",
      "label": "Ownership is visible in the derived view: a machine-owned statement ends with the marker [machine]. Endorsement is the endorse verb; render then drops the marker. Amending or striking are the operator's other two answers.",
      "props": {
        "ord": 7,
        "owner": "machine",
        "segment": "endorsement"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.922659",
      "id": "endorsement-8",
      "kind": "statement",
      "label": "The record of endorsements is what earns autonomy. Where the machine's settlements keep being taken on unchanged, its reach grows; where they keep being struck, it shrinks.",
      "props": {
        "ord": 8,
        "owner": "machine",
        "segment": "endorsement"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.536543",
      "id": "foundations",
      "kind": "segment",
      "label": "foundations",
      "props": {
        "renders_to": "foundations.md",
        "title": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.544891",
      "id": "foundations-1",
      "kind": "statement",
      "label": "hypercore is a small graph for a human and an agent to think with together.",
      "props": {
        "ord": 1,
        "owner": "operator",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.553202",
      "id": "foundations-2",
      "kind": "statement",
      "label": "The graph is the model: nodes, relations between them, clusters of relations, and material attached to nodes.",
      "props": {
        "ord": 2,
        "owner": "operator",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.561541",
      "id": "foundations-3",
      "kind": "statement",
      "label": "The machine carries no memory between episodes of work. hypercore holds that memory outside the machine: the graph, not the running conversation, is the durable shared state.",
      "props": {
        "ord": 3,
        "owner": "machine",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.571442",
      "id": "foundations-4",
      "kind": "statement",
      "label": "The database is the source of truth.",
      "props": {
        "ord": 4,
        "owner": "operator",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.580897",
      "id": "foundations-5",
      "kind": "statement",
      "label": "The files on disk are a derived view of the database. They exist so a human can read the graph and git can track how it changes.",
      "props": {
        "ord": 5,
        "owner": "operator",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.589885",
      "id": "foundations-6",
      "kind": "statement",
      "label": "Intent is authored through the statement verbs; render is the files' only writer. The snapshot in git is the durable form of both the graph and the statement store; the database file is a local working copy rebuilt from it with load.",
      "props": {
        "ord": 6,
        "owner": "machine",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.598525",
      "id": "foundations-7",
      "kind": "statement",
      "label": "The operator's attention is the scarcest resource in the system. The system spends it on judgment, never on filing.",
      "props": {
        "ord": 7,
        "owner": "machine",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.606499",
      "id": "foundations-8",
      "kind": "statement",
      "label": "The operator never performs graph maintenance. The machine files, links, and renders; the operator ratifies, vetoes, and redirects. An operator hand-tending the graph's bookkeeping is the earliest signal that ceremony has won.",
      "props": {
        "ord": 8,
        "owner": "machine",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.527354",
      "id": "hypercore",
      "kind": "node",
      "label": "hypercore",
      "props": {
        "intent": "organizing-document.md",
        "role": "root"
      }
    },
    {
      "created_at": "2026-06-10T02:35:16.413872",
      "id": "s_3729cb59",
      "kind": "statement",
      "label": "An operation is one move on the problem state, of six kinds: frame, gather, derive, generate, test, commit. Work is made of operations.",
      "props": {
        "ord": 11,
        "owner": "machine",
        "segment": "work"
      }
    },
    {
      "created_at": "2026-06-10T02:35:17.192347",
      "id": "s_81c38173",
      "kind": "statement",
      "label": "Who proposes, executes, judges, and decides is a property on each operation, not an operation of its own. The decision to commit belongs to whoever owns the consequences and cannot be delegated.",
      "props": {
        "ord": 13,
        "owner": "machine",
        "segment": "work"
      }
    },
    {
      "created_at": "2026-06-10T02:43:50.554150",
      "id": "s_d4bd1b45",
      "kind": "statement",
      "label": "Nodes are operations. Intent statements are not nodes: they live in their own store with their own index. An operation points to the statements it produces and is bound by the statements it acts under; both are references the operation carries, not edges to statement nodes.",
      "props": {
        "ord": 8,
        "owner": "operator",
        "segment": "structure"
      }
    },
    {
      "created_at": "2026-06-10T02:35:16.747171",
      "id": "s_e4f503c9",
      "kind": "statement",
      "label": "The alphabet of operations never grows. Named clusters of operations are the compounds that grow freely; decomposition is how a compound expands, not a primitive.",
      "props": {
        "ord": 12,
        "owner": "machine",
        "segment": "work"
      }
    },
    {
      "created_at": "2026-06-10T02:20:31.770138",
      "id": "s_f35147a3",
      "kind": "statement",
      "label": "The operator can read the system's state at a glance: the viewer shows who owns each statement and which work is open, without asking the machine.",
      "props": {
        "ord": 9,
        "owner": "machine",
        "segment": "foundations"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.701990",
      "id": "statements",
      "kind": "segment",
      "label": "statements",
      "props": {
        "renders_to": "statements.md",
        "title": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.718433",
      "id": "statements-1",
      "kind": "statement",
      "label": "A segment's intent document is that segment's current intended reality.",
      "props": {
        "ord": 1,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.821070",
      "id": "statements-10",
      "kind": "statement",
      "label": "Intent is discovered through work more than collected in advance. Revising a statement must stay cheap, or intent hardens into a spec the work quietly ignores.",
      "props": {
        "ord": 10,
        "owner": "machine",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.832085",
      "id": "statements-11",
      "kind": "statement",
      "label": "The default motion is ratification: the machine drafts concrete statements and the operator endorses, amends, or strikes them. The operator is rarely asked to author from nothing.",
      "props": {
        "ord": 11,
        "owner": "machine",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.840598",
      "id": "statements-12",
      "kind": "statement",
      "label": "A statement's body is plain prose. The formal part is the envelope: its id, segment, owner, and relations. Formalize the envelope, never the prose.",
      "props": {
        "ord": 12,
        "owner": "machine",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.731290",
      "id": "statements-2",
      "kind": "statement",
      "label": "A statement is declarative and strong enough to be wrong.",
      "props": {
        "ord": 2,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.741784",
      "id": "statements-3",
      "kind": "statement",
      "label": "Statements are written plainly.",
      "props": {
        "ord": 3,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.752792",
      "id": "statements-4",
      "kind": "statement",
      "label": "Within an execution graph, one name means one concept.",
      "props": {
        "ord": 4,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.761983",
      "id": "statements-5",
      "kind": "statement",
      "label": "Every statement should be ownable.",
      "props": {
        "ord": 5,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.773336",
      "id": "statements-6",
      "kind": "statement",
      "label": "Every statement should be falsifiable against material, evidence, or later judgment.",
      "props": {
        "ord": 6,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.785541",
      "id": "statements-7",
      "kind": "statement",
      "label": "A statement that is neither ownable nor falsifiable is not ready for intent.",
      "props": {
        "ord": 7,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.798068",
      "id": "statements-8",
      "kind": "statement",
      "label": "The operator and the machine are both bound by coherence.",
      "props": {
        "ord": 8,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.809985",
      "id": "statements-9",
      "kind": "statement",
      "label": "When the operator leaves a meaningful choice open and the machine settles it, that settlement is visible as machine-owned intent until the operator takes it on. The operator must be informed of this.",
      "props": {
        "ord": 9,
        "owner": "operator",
        "segment": "statements"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.614972",
      "id": "structure",
      "kind": "segment",
      "label": "structure",
      "props": {
        "renders_to": "structure.md",
        "title": "structure"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.622410",
      "id": "structure-1",
      "kind": "statement",
      "label": "A node is a thing in the graph.",
      "props": {
        "ord": 1,
        "owner": "operator",
        "segment": "structure"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.634370",
      "id": "structure-2",
      "kind": "statement",
      "label": "A node points to its material; its intent is the statements that bind it.",
      "props": {
        "ord": 2,
        "owner": "machine",
        "segment": "structure"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.642543",
      "id": "structure-3",
      "kind": "statement",
      "label": "Intent is the written model of what the node is meant to be. Material is what the node actually made, the thing reality can contradict.",
      "props": {
        "ord": 3,
        "owner": "operator",
        "segment": "structure"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.653216",
      "id": "structure-4",
      "kind": "statement",
      "label": "A relation is a directed, typed link from one node to another.",
      "props": {
        "ord": 4,
        "owner": "operator",
        "segment": "structure"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.662037",
      "id": "structure-5",
      "kind": "statement",
      "label": "A cluster is a named set of relations: a subgraph that stands for a repeatable operation.",
      "props": {
        "ord": 5,
        "owner": "operator",
        "segment": "structure"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.672373",
      "id": "structure-6",
      "kind": "statement",
      "label": "The intent lives at the root, as the markdown files there. Everything else in the repository is material.",
      "props": {
        "ord": 6,
        "owner": "operator",
        "segment": "structure"
      }
    },
    {
      "created_at": "2026-06-10T01:59:22.687331",
      "id": "structure-7",
      "kind": "statement",
      "label": "The engine is material. It is the implementation that stores and serves the graph.",
      "props": {
        "ord": 7,
        "owner": "operator",
        "segment": "structure"
      }
    },
    {
