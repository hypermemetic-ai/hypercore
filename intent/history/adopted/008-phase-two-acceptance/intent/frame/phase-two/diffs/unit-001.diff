+phase_two_units_from_frame_file() {
+  local file=$1
+  [ -f "$file" ] || return 1
+  awk '
+    function trim(s) {
+      sub(/^[[:space:]]+/, "", s)
+      sub(/[[:space:]]+$/, "", s)
+      return s
+    }
+    function emit() {
+      if (current != "") {
+        count += 1
+        printf "unit-%03d\t%s\n", count, trim(current)
+        current = ""
+      }
+    }
+    BEGIN {
+      in_units = 0
+      current = ""
+      count = 0
+    }
+    /^[[:space:]]*##[[:space:]]+/ && in_units {
+      emit()
+      exit
+    }
+    tolower($0) ~ /^[[:space:]]*implementation units for phase two:[[:space:]]*$/ {
+      in_units = 1
+      next
+    }
+    in_units {
+      line = $0
+      if (line ~ /^[[:space:]]*[0-9]+[.)][[:space:]]+/) {
+        emit()
+        sub(/^[[:space:]]*[0-9]+[.)][[:space:]]+/, "", line)
+        current = trim(line)
+        next
+      }
+      if (current != "" && line !~ /^[[:space:]]*$/) {
+        current = current " " trim(line)
+      }
+    }
+    END {
+      if (in_units) {
+        emit()
+      }
+      if (count == 0) {
+        exit 1
+      }
+    }
+  ' "$file"
+}
