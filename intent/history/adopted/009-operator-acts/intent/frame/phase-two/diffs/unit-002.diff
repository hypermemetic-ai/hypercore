+
+direction_selected_field_value_from_file() {
+  local file=$1
+  awk '
+    function trim(s) {
+      sub(/^[[:space:]]+/, "", s)
+      sub(/[[:space:]]+$/, "", s)
+      return s
+    }
+    /^[[:space:]]*```/ { fence = !fence; next }
+    fence { next }
+    {
+      line = $0
+      lowered = tolower(line)
+      gsub(/^[[:space:]]+/, "", lowered)
+      if (lowered ~ /^(selected-route|constraint|delegation):/) {
+        label = lowered
+        sub(/:.*/, "", label)
+        value = line
+        sub(/^[[:space:]]*[^:]*:[[:space:]]*/, "", value)
+        print label "\t" trim(value)
+        exit
+      }
+    }
+  ' "$file"
+}
