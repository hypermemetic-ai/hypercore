+      ;;
+    ""|*[!0-9]*)
+      die "invalid direction option: ${OPERATOR_GATE_TOKEN:-<empty>}"
+      ;;
+  esac
+  while IFS=$'\t' read -r number kind summary reversibility tradeoff id; do
+    if [ "$number" = "$choice" ]; then
