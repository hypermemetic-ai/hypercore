+    lowered == "## rejection choices" { in_rejection = 1; next }
+    lowered ~ /^## / { in_rejection = 0; next }
+    in_rejection && index(lowered, choice ":") == 1 {
+      value = line
+      sub(/^[[:space:]]*[^:]*:[[:space:]]*/, "", value)
+      print trim(value)
+      exit
+    }
+  ' "$file"
