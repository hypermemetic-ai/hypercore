+  [ "$NODE_REL" = "." ] || return 1
+  [ "$(basename "$d")" = "009-operator-acts" ] || return 1
+  frame_file="$(frame_dir_for "$d")/frame.md"
+  [ -f "$frame_file" ] || return 1
+  grep -Fq "this work's already" "$frame_file" \
