#!/usr/bin/env python3
"""hyper — the operator's interface to hypercore.

One file, stdlib only, keyboard only.  Every frame is read fresh from
disk: intent.md (the system), queue.md (decision cards), words.md (open
exchanges), work.md (work in-flight).  Every move the operator makes
lands on disk and is committed in their name before the screen redraws.
The screen re-reads disk on a one-second tick, so what lands shows up
on its own — no restart anywhere.

    ./hyper

Views    queue (home) . decision card . acceptance card . exchange .
         work . document . log
Decide   a approve . c cut . e explain (words optional)
Accept   a then y on an acceptance card — confirmed like every
         other release; s speaks reservations
Speak    s anywhere — words land verbatim, the place travels with them,
         and the machine is summoned to answer while you watch
Move     arrows . left/right across cards (j previous, k next) . up/down
         within the screen . enter open . esc back . q quit
"""

import curses
import locale
import os
import shlex
import shutil
import subprocess
import textwrap
import time
from datetime import date, datetime

ROOT = os.path.dirname(os.path.abspath(__file__))
INTENT = os.path.join(ROOT, "intent.md")
QUEUE = os.path.join(ROOT, "queue.md")
WORDS = os.path.join(ROOT, "words.md")
WORK = os.path.join(ROOT, "work.md")
MARKER = " [machine]"
LM = 3  # left margin

LEDGERS = ("intent.md", "queue.md", "words.md", "work.md")
GUARD = "the record is behind — m summons the machine to true it up"

MACHINE_LOG = os.path.join(ROOT, ".hyper-machine.log")
MACHINE_FILE = os.path.join(ROOT, "machine")
BRIEF = os.path.join(ROOT, "brief.md")
HYPER_LOG = os.path.join(ROOT, ".hyper.log")
FS_TRIES = 10
SUMMON = (
    "the interface summoned you. read brief.md — the session brief, "
    "written fresh at this summon — then queue.md and words.md; every "
    "operator word whose card or exchange block does not "
    "end with a machine line awaits you. but first: if the record is behind "
    "— git status shows uncommitted changes — true it up before anything "
    "else. read the diff, verify what it claims against what is actually "
    "on disk, finish or correct what the dead session left, and commit "
    "with grounds. then answer each waiting word as a "
    "'machine (YYYY-MM-DD): ...' line appended to the same block, per the "
    "standing orders — short enough to read on a card. if the words start "
    "work bigger than an answer, record the ask in work.md and say so in "
    "the answer; you may build when the words call for it, under the "
    "standing orders — decisions before material, every slice landed with "
    "its explanation and acceptance question. decisions that are the "
    "operator's land as questions in your answer line, to be settled in "
    "the interface — never assumed. never use AskUserQuestion here: nobody "
    "can see it. commit after every file you finish, with grounds, not "
    "once at the end — a session can die mid-flight, and only what is "
    "committed survives it. then stop."
)


# ----- disk ------------------------------------------------------------

def run(*args):
    return subprocess.run(args, cwd=ROOT, capture_output=True, text=True).stdout


def read_intent():
    """Every statement with its section and line span.  A statement is a
    paragraph: consecutive non-blank, non-heading lines."""
    with open(INTENT) as f:
        lines = f.read().splitlines()
    stmts, sec, i = [], None, 0
    while i < len(lines):
        if lines[i].startswith("## "):
            sec = lines[i][3:].strip()
            i += 1
        elif not lines[i].strip() or lines[i].startswith("#"):
            i += 1
        else:
            start = i
            para = []
            while i < len(lines) and lines[i].strip() and not lines[i].startswith("#"):
                para.append(lines[i].strip())
                i += 1
            text = " ".join(para)
            stmts.append({"text": text, "section": sec, "span": (start, i),
                          "pending": text.endswith(MARKER)})
    return lines, stmts


def write_intent(lines):
    with open(INTENT, "w") as f:
        f.write("\n".join(lines) + "\n")


def ledger(path):
    """A ledger file as raw '## ' blocks: the head line, '- key: value'
    fields, spoken operator/machine lines, and the blockquote if any."""
    if not os.path.exists(path):
        return []
    with open(path) as f:
        raw = f.read().splitlines()
    heads = [i for i, l in enumerate(raw) if l.startswith("## ")]
    blocks = []
    for a, b in zip(heads, heads[1:] + [len(raw)]):
        block = raw[a:b]
        fields, words = {}, []
        for ln in block:
            if ln.startswith("- ") and ": " in ln:
                k, v = ln[2:].split(": ", 1)
                fields[k.strip()] = v.strip()
            elif ln.startswith(("operator (", "machine (")):
                words.append(ln)
        blocks.append({"quote": " ".join(l[2:].strip() for l in block if l.startswith("> ")),
                       "fields": fields, "words": words, "lines": block})
    return blocks


def write_ledger(path, title, blocks):
    if not blocks:
        if os.path.exists(path):
            os.remove(path)
        return
    out = ["# " + title, ""]
    for b in blocks:
        entry = list(b["lines"])
        while entry and not entry[-1].strip():
            entry.pop()
        out += entry + [""]
    with open(path, "w") as f:
        f.write("\n".join(out) + "\n")


def card_for(st, cards):
    return next((b for b in cards if b["quote"] == st["text"]), None)


# ----- decisions (each one lands on disk and commits) -------------------

def head(text, n=8):
    words = text.replace(MARKER, "").split()
    return " ".join(words[:n]) + ("…" if len(words) > n else "")


def commit(subject, body, paths=("intent.md", "queue.md")):
    track = [p for p in paths
             if os.path.exists(os.path.join(ROOT, p)) or run("git", "ls-files", p).strip()]
    if track:
        run("git", "add", "--", *track)
    run("git", "commit", "-m", subject, "-m", body)
    return run("git", "log", "-1", "--format=%h").strip()


def find(text):
    _, stmts = read_intent()
    return next((s for s in stmts if s["text"] == text), None)


def approve(text, has_card):
    st = find(text)
    if st is None:
        return None
    lines, _ = read_intent()
    end = st["span"][1]
    if lines[end - 1].endswith(MARKER):
        lines[end - 1] = lines[end - 1][: -len(MARKER)]
    write_intent(lines)
    write_ledger(QUEUE, "queue", [b for b in ledger(QUEUE) if b["quote"] != text])
    grounds = ("grounds: the operator pressed approve in hyper with the card's entailments on screen."
               if has_card else
               "grounds: the operator pressed approve in hyper; no card was on file and the interface said so.")
    return commit("approved by the operator in the interface: " + head(text),
                  text.replace(MARKER, "") + "\n\n" + grounds)


def cut(text, card):
    st = find(text)
    if st is None:
        return None
    lines, _ = read_intent()
    s, e = st["span"]
    del lines[s:e]
    if 0 < s < len(lines) and not lines[s - 1].strip() and not lines[s].strip():
        del lines[s]
    write_intent(lines)
    write_ledger(QUEUE, "queue", [b for b in ledger(QUEUE) if b["quote"] != text])
    breaks = card["fields"].get("cut") if card else None
    body = ('the words that left: "' + text.replace(MARKER, "") + '"\n\n'
            + ("what it breaks, as drafted on the card: " + breaks if breaks else
               "no drafted entailments were on file; the interface said so before the pick."))
    return commit("cut by the operator in the interface: " + head(text), body)


def explain(st, words):
    cards = ledger(QUEUE)
    blk = next((b for b in cards if b["quote"] == st["text"]), None)
    if blk is None:
        blk = {"quote": st["text"],
               "lines": ["## " + head(st["text"]), "", "> " + st["text"], "",
                         "- section: " + (st["section"] or "—")]}
        cards.append(blk)
    if blk["lines"] and blk["lines"][-1].strip():
        blk["lines"].append("")
    blk["lines"].append("operator (%s): %s" % (date.today().isoformat(),
                        words.strip() or "explain — tell the story"))
    write_ledger(QUEUE, "queue", cards)
    return commit("the operator asks explain in the interface: " + head(st["text"]),
                  (words.strip() or "(no words — the machine tells the story)")
                  + "\n\nthe machine reads queue.md at next session start and answers.",
                  ("queue.md",))


def accept(name):
    """One frictionless act: the slice leaves work.md, git keeps the entry,
    and the commit is the operator's acceptance."""
    blocks = ledger(WORK)
    blk = next((b for b in blocks if b["lines"][0][3:].strip() == name), None)
    if blk is None:
        return None
    write_ledger(WORK, "work", [b for b in blocks if b is not blk])
    return commit("accepted by the operator in the interface: " + name,
                  "\n".join(blk["lines"])
                  + "\n\ngrounds: the operator pressed accept on the card, with what "
                    "the slice does and how to try it on screen. git keeps the entry.",
                  ("work.md",))


# ----- speech (from anywhere; the place travels with the words) ---------

def speak(place, words):
    stamp = date.today().isoformat()
    headline = "## from %s . %s" % (place, stamp)
    blocks = ledger(WORDS)
    blk = next((b for b in blocks if b["lines"][0] == headline), None)
    if blk is None:
        blk = {"lines": [headline]}
        blocks.append(blk)
    if blk["lines"][-1].strip():
        blk["lines"].append("")
    blk["lines"].append("operator (%s): %s" % (stamp, words.strip()))
    write_ledger(WORDS, "words", blocks)
    return commit("the operator speaks in the interface, from %s: %s" % (place, head(words)),
                  words.strip() + "\n\nthe machine reads words.md at next session start and answers.",
                  ("words.md",))


def speak_more(blk, words):
    key = blk["lines"][0]
    blocks = ledger(WORDS)
    tgt = next((b for b in blocks if b["lines"][0] == key), None)
    if tgt is None:
        return None
    if tgt["lines"][-1].strip():
        tgt["lines"].append("")
    tgt["lines"].append("operator (%s): %s" % (date.today().isoformat(), words.strip()))
    write_ledger(WORDS, "words", blocks)
    return commit("the operator speaks again in the interface: " + head(words),
                  words.strip() + "\n\nthe machine reads words.md at next session start and answers.",
                  ("words.md",))


def fold_exchange(blk):
    key = blk["lines"][0]
    blocks = ledger(WORDS)
    if not any(b["lines"][0] == key for b in blocks):
        return None
    write_ledger(WORDS, "words", [b for b in blocks if b["lines"][0] != key])
    return commit("the operator folds an exchange in the interface: " + head(key[3:]),
                  "\n".join(blk["lines"]) + "\n\ngit keeps the words.",
                  ("words.md",))


# ----- the machine (summoned by speech; answers onto the same block) -----

def machine_command():
    """One visible setting: the first plain line of the machine file at
    the root, {prompt} standing for the summon instruction — any harness
    that takes a prompt slots in.  HYPER_MACHINE in the environment
    overrides it (testing); with neither, claude."""
    cmd = os.environ.get("HYPER_MACHINE")
    if not cmd and os.path.exists(MACHINE_FILE):
        with open(MACHINE_FILE) as f:
            cmd = next((l.strip() for l in f
                        if l.strip() and not l.lstrip().startswith("#")), None)
    if not cmd:
        exe = shutil.which("claude") or os.path.expanduser("~/.local/bin/claude")
        if not os.path.exists(exe):
            return None
        cmd = shlex.quote(exe) + " -p {prompt} --permission-mode acceptEdits"
    argv = [SUMMON if t == "{prompt}" else t for t in shlex.split(cmd)]
    if SUMMON not in argv:
        argv.append(SUMMON)
    return argv


def machine_label():
    """What answers, by name: the harness from the machine command, and
    the model only when the command pins one — the screen never claims
    more than the command states."""
    argv = machine_command()
    if argv is None:
        return "none — the machine file names the command"
    name = os.path.basename(argv[0])
    model = argv[argv.index("--model") + 1] if "--model" in argv[:-1] else None
    return name + (" · " + model if model
                   else " · the harness default model — none pinned")


def summon():
    """A headless machine session in this repo: it trues up the record if
    it is behind, answers the operator's words onto the blocks that carry
    them, may build under the standing orders, commits as it goes, and
    stops.  The contract is files and git; the brief lands in brief.md so
    any harness reads the same bearings."""
    argv = machine_command()
    if argv is None:
        return None
    with open(BRIEF, "w") as f:
        f.write(run("bash", os.path.join(".claude", "hooks", "session-brief.sh"),
                    "--plain"))
    log = open(MACHINE_LOG, "ab", buffering=0)
    log.write(("\n--- summoned %s ---\n"
               % datetime.now().isoformat(timespec="seconds")).encode())
    try:
        return subprocess.Popen(argv, cwd=ROOT, stdin=subprocess.DEVNULL,
                                stdout=log, stderr=log, start_new_session=True)
    except FileNotFoundError:
        log.write(("the machine command was not found: %s\n" % argv[0]).encode())
        return None


def start_machine(machine):
    """Summon unless one is already answering (it reads from disk, so words
    that land mid-answer wait visibly and m summons again)."""
    if machine:
        return machine
    p = summon()
    return (p, time.time()) if p else None


def note(msg):
    """The flash dies with the screen; the log line is always quotable."""
    with open(HYPER_LOG, "a") as f:
        f.write("%s  %s\n" % (datetime.now().isoformat(timespec="seconds"), msg))
    return msg


def ensure_launcher():
    """The menu entry that launches hyper without a fresh login: a symlink
    in the applications directory to the repo's hyper.desktop, kept by
    hyper itself the way the autostart entry is — the repo stays the only
    place the entry is written.  Returns a flash only when something is
    wrong; the landing itself goes to the log."""
    target = os.path.join(ROOT, "hyper.desktop")
    link = os.path.join(os.path.expanduser("~"), ".local", "share",
                        "applications", "hyper.desktop")
    try:
        if os.path.islink(link):
            if os.readlink(link) == target:
                return None
            os.remove(link)
        elif os.path.exists(link):
            return note("a hyper.desktop that is not ours sits in the "
                        "applications menu — left alone")
        os.makedirs(os.path.dirname(link), exist_ok=True)
        os.symlink(target, link)
        note("the menu entry landed — hyper launches from the desktop menu now")
        return None
    except OSError as e:
        return note("the menu entry could not land: %s" % e)


def fullscreen_taken(wid):
    """Whether the window manager shows the window fullscreen yet; None
    when xprop is not there to ask."""
    try:
        r = subprocess.run(["xprop", "-id", wid, "_NET_WM_STATE"],
                           capture_output=True, text=True)
        if r.returncode == 0:
            return "_NET_WM_STATE_FULLSCREEN" in r.stdout
    except FileNotFoundError:
        pass
    return None


def fullscreen_tick(left):
    """ghostty ignores fullscreen=true at window creation on Linux
    (ghostty-org/ghostty #11252), and a request can fire before the window
    manager has taken the window — a startup race.  So when the login
    launcher asks (HYPER_FULLSCREEN=1): one request per tick until the
    window manager confirms it took, every outcome on disk where it stays
    quotable.  Returns (tries left, flash)."""
    wid = os.environ["WINDOWID"]
    taken = fullscreen_taken(wid)
    if taken:
        note("fullscreen confirmed by the window manager")
        return 0, ""
    try:
        r = subprocess.run(["wmctrl", "-i", "-r", wid, "-b", "add,fullscreen"],
                           capture_output=True, text=True)
    except FileNotFoundError:
        return 0, note("wmctrl is not installed — the fullscreen request could not be made")
    if r.returncode != 0:
        return 0, note("the fullscreen request failed — "
                       + (r.stderr.strip() or "no reason given"))
    left -= 1
    if left == 0 and taken is False:
        return 0, note("the fullscreen request was sent %d times and never stuck"
                       % FS_TRIES)
    if taken is None:
        return min(left, 2), ""  # nobody to confirm — ask thrice and rest
    return left, ""


# ----- screen -----------------------------------------------------------

def put(scr, y, x, s, attr=0):
    try:
        scr.addstr(y, x, s, attr)
    except curses.error:
        pass


def wrap(text, width):
    return textwrap.wrap(text, max(10, width)) or [""]


def read_words(scr, h, w, prompt):
    """The operator's words at the bottom of the screen, visible whole and
    editable until sent: the text wraps across as many lines as it needs,
    arrows move the cursor anywhere, home/end jump within the line,
    backspace and delete edit in place.  Enter sends, esc abandons —
    until then nothing binds."""
    curses.curs_set(1)
    scr.timeout(-1)
    width = max(10, w - 2 * LM)
    buf, pos, top_seen = "", 0, h - 2
    try:
        while True:
            rows = [buf[i:i + width] for i in range(0, len(buf), width)] or [""]
            if buf and len(buf) % width == 0:
                rows.append("")
            cr, cc = divmod(pos, width)
            maxrows = max(1, h - 8)
            base = max(0, cr - maxrows + 1)
            vis = rows[base:base + maxrows]
            top = h - 2 - len(vis) - 1
            top_seen = min(top_seen, top)
            for y in range(top_seen, h):
                put(scr, y, 0, " " * (w - 1))
            put(scr, top, LM, prompt[: w - 2 * LM], curses.A_DIM)
            for i, ln in enumerate(vis):
                put(scr, top + 1 + i, LM, ln)
            put(scr, h - 1, LM,
                "enter sends . esc abandons . arrows move . home/end jump"[: w - 2 * LM],
                curses.A_DIM)
            scr.move(top + 1 + cr - base, min(LM + cc, w - 2))
            scr.refresh()
            ch = scr.get_wch()
            if ch in ("\n", "\r") or ch == curses.KEY_ENTER:
                return buf
            if ch == "\x1b":
                return None
            if ch in ("\x7f", "\b") or ch == curses.KEY_BACKSPACE:
                if pos:
                    buf, pos = buf[: pos - 1] + buf[pos:], pos - 1
            elif ch == curses.KEY_DC:
                buf = buf[:pos] + buf[pos + 1:]
            elif ch == curses.KEY_LEFT:
                pos = max(0, pos - 1)
            elif ch == curses.KEY_RIGHT:
                pos = min(len(buf), pos + 1)
            elif ch == curses.KEY_UP:
                pos = max(0, pos - width)
            elif ch == curses.KEY_DOWN:
                pos = min(len(buf), pos + width)
            elif ch == curses.KEY_HOME or ch == "\x01":
                pos = (pos // width) * width
            elif ch == curses.KEY_END or ch == "\x05":
                pos = min(len(buf), (pos // width) * width + width)
            elif isinstance(ch, str) and ch.isprintable():
                buf, pos = buf[:pos] + ch + buf[pos:], pos + len(ch)
    finally:
        curses.curs_set(0)
        scr.timeout(1000)


def main(scr):
    try:
        curses.set_escdelay(25)
    except AttributeError:
        pass
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_RED, -1)
    curses.init_pair(2, curses.COLOR_YELLOW, -1)
    ALERT = curses.color_pair(1) | curses.A_BOLD
    ACCENT = curses.color_pair(2) | curses.A_BOLD
    DIM, BOLD, REV = curses.A_DIM, curses.A_BOLD, curses.A_REVERSE
    # the queue leads each entry with its kind — what kind of call the
    # operator faces reads before any title does
    KINDS = {"decide": ("decide", BOLD), "accept": ("accept", ACCENT),
             "read": ("answered", DIM), "sent": ("sent", DIM)}
    GUT = 10  # the kind column

    view, sel, ci, ai, wsel = "home", 0, 0, 0, 0
    wexp = False  # the work view opens folded to the graph line
    scroll, flash, confirm, exkey = 0, "", None, None
    machine = None  # (Popen, started) while a summoned session is answering
    flash = ensure_launcher() or flash
    fs_left = (FS_TRIES if os.environ.get("HYPER_FULLSCREEN")
               and os.environ.get("WINDOWID") else 0)
    if fs_left:
        fs_left, flash = fullscreen_tick(fs_left)
    scr.timeout(1000)  # the screen re-reads disk on its own — no restart anywhere

    while True:
        _, stmts = read_intent()
        pend = [s for s in stmts if s["pending"]]
        cards = ledger(QUEUE)
        exchanges = ledger(WORDS)
        work = ledger(WORK)
        dirty = run("git", "status", "--porcelain").strip()
        last = run("git", "log", "-1", "--format=%h %s . %cr").strip()

        awaits = [b for b in cards + exchanges
                  if b["words"] and b["words"][-1].startswith("operator (")]
        if machine and machine[0].poll() is not None:
            rc = machine[0].returncode
            flash = ("the machine has answered" if rc == 0 else
                     note("the machine failed (exit %d) — .hyper-machine.log holds the story" % rc))
            machine = None

        answered = [b for b in exchanges
                    if b["words"] and b["words"][-1].startswith("machine (")]
        sent = [b for b in exchanges if b not in answered]
        accepts = [b for b in work
                   if "awaiting acceptance" in b["fields"].get("state", "")]
        entries = ([("decide", s) for s in pend]
                   + [("accept", b) for b in accepts]
                   + [("read", b) for b in answered]
                   + [("sent", b) for b in sent])
        sel = max(0, min(sel, len(entries) - 1))
        ci = max(0, min(ci, len(pend) - 1))
        ai = max(0, min(ai, len(accepts) - 1))
        wsel = max(0, min(wsel, len(work) - 1))
        exb, exmax = None, 0
        if view == "card" and not pend:
            view = "home"
        if view == "accept" and not accepts:
            view = "home"
        if view == "exchange":
            exb = next((b for b in exchanges if b["lines"][0] == exkey), None)
            if exb is None:
                view = "home"
        if view == "work" and not work:
            view = "home"

        scr.erase()
        h, w = scr.getmaxyx()
        width = min(w - 2 * LM, 76)
        top = 4
        view_h = max(1, h - top - 6)
        guarded = any(l.split()[-1] in LEDGERS for l in dirty.splitlines())

        put(scr, 0, LM, "H Y P E R C O R E", BOLD)
        parts = []
        if pend:
            parts.append("%d TO DECIDE" % len(pend))
        if accepts:
            parts.append("%d TO ACCEPT" % len(accepts))
        if answered:
            parts.append("%d ANSWERED" % len(answered))
        status = " . ".join(parts) if parts else "QUEUE CLEAR"
        put(scr, 0, max(LM, w - len(status) - LM), status, BOLD if parts else DIM)
        # the machine's name rides the top row, dim, between title and
        # status — drawn only when it fits whole
        label = machine_label()
        lx = (w - len(label)) // 2
        if lx > LM + 19 and lx + len(label) <= w - LM - len(status) - 2:
            put(scr, 0, lx, label, DIM)
        put(scr, 1, LM, "─" * max(0, w - 2 * LM), DIM)
        mtxt = ""
        if machine:
            mtxt = "the machine is answering · %ds" % (time.time() - machine[1])
            put(scr, 2, max(LM, w - len(mtxt) - LM), mtxt, BOLD)
        elif awaits:
            mtxt = ("%d word%s the machine — m summons it"
                    % (len(awaits), " awaits" if len(awaits) == 1 else "s await"))
            put(scr, 2, max(LM, w - len(mtxt) - LM), mtxt, DIM)
        if dirty:
            files = ", ".join(l.split()[-1] for l in dirty.splitlines())
            room = w - 2 * LM - (len(mtxt) + 2 if mtxt else 0)
            put(scr, 2, LM,
                ("the record is behind — uncommitted: %s — m trues it up"
                 % files)[: max(0, room)], ALERT)

        if view == "home":
            put(scr, top, LM, "THE QUEUE", DIM)
            y = top + 2
            if entries:
                for i, (kind, obj) in enumerate(entries):
                    label, lattr = KINDS[kind]
                    if kind == "decide":
                        text = obj["text"].replace(MARKER, "")
                        tag = obj["section"] or ""
                    else:
                        text = obj["lines"][0][3:].strip()
                        tag = ""
                    room = width - GUT - (len(tag) + 2 if tag else 0)
                    if len(text) > room:
                        text = text[: max(1, room - 1)] + "…"
                    if i == sel:
                        put(scr, y, LM, " " * width, REV)
                        put(scr, y, LM, label, lattr | REV)
                        put(scr, y, LM + GUT, text, REV)
                        if tag:
                            put(scr, y, LM + width - len(tag), tag, REV)
                    else:
                        put(scr, y, LM, label, lattr)
                        put(scr, y, LM + GUT, text, 0 if kind in ("decide", "accept") else DIM)
                        if tag:
                            put(scr, y, LM + width - len(tag), tag, DIM)
                    y += 1
            else:
                put(scr, y, LM, "nothing waits on you.", DIM)
                y += 1
            y += 1
            if work:
                put(scr, y, LM, ("work in-flight: %d . awaiting your acceptance: %d . "
                                 "w opens the view" % (len(work), len(accepts)))[: w - 2 * LM],
                    DIM)
                y += 1
            put(scr, y, LM, ("last  " + last)[: w - 2 * LM], DIM)

        elif view == "card":
            st = pend[ci]
            card = card_for(st, cards)
            put(scr, top, LM,
                ("%s . %d of %d" % (st["section"] or "—", ci + 1, len(pend))).upper(), DIM)
            rows = [[(LM, ln, BOLD)] for ln in wrap(st["text"].replace(MARKER, ""), width)]
            rows += [[(LM, "[machine]", DIM)], []]
            drafted = False
            if card:
                for key in ("context", "approve", "cut"):
                    val = card["fields"].get(key)
                    if not val:
                        continue
                    drafted = True
                    first = True
                    for ln in wrap(val, width - 9):
                        rows.append([(LM, "%7s" % key, DIM), (LM + 9, ln, 0)]
                                    if first else [(LM + 9, ln, 0)])
                        first = False
            if not drafted:
                rows += [[(LM, ln, BOLD)]
                         for ln in wrap("no entailments on file — context and what "
                                        "approve or cut entails is not drafted; "
                                        "e asks the machine for them.", width)]
            if card and card["words"]:
                rows += [[], [(LM, "THE EXCHANGE SO FAR", DIM)]]
                for wln in card["words"]:
                    attr = DIM if wln.startswith("operator (") else 0
                    rows.append([])
                    rows += [[(LM + 2, ln, attr)] for ln in wrap(wln, width - 2)]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "accept":
            blk = accepts[ai]
            name = blk["lines"][0][3:].strip()
            put(scr, top, LM,
                ("awaiting your acceptance . %d of %d" % (ai + 1, len(accepts))).upper(),
                DIM)
            rows = [[(LM, ln, BOLD)] for ln in wrap(name, width)]
            rows.append([])
            for key, label in (("ask", "it does"), ("try", "try it"),
                               ("state", "state"), ("waits on", "waits")):
                val = blk["fields"].get(key)
                if not val:
                    continue
                first = True
                for ln in wrap(val, width - 9):
                    rows.append([(LM, "%7s" % label, DIM), (LM + 9, ln, 0)]
                                if first else [(LM + 9, ln, 0)])
                    first = False
                rows.append([])
            rows += [[(LM, ln, DIM)]
                     for ln in wrap("a then y accepts and releases the slice — the "
                                    "entry leaves work.md, git keeps it. speak only "
                                    "if you have reservations.", width)]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "exchange":
            # the exchange reads as a chat: it opens pinned to the newest
            # words (scroll == -1) and follows them as they land; scrolling
            # up unpins, reaching the bottom pins again.
            put(scr, top, LM, exb["lines"][0][3:].strip().upper(), DIM)
            rows = []
            for wln in exb["words"]:
                attr = DIM if wln.startswith("operator (") else 0
                rows.append([])
                rows += [[(LM, ln, attr)] for ln in wrap(wln, width)]
            exmax = max(0, len(rows) - view_h)
            eff = exmax if scroll == -1 else max(0, min(scroll, exmax))
            for i, segs in enumerate(rows[eff: eff + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            if eff > 0:
                put(scr, top + 1, LM, "… %d above — ↑ scrolls" % eff, DIM)
            below = len(rows) - view_h - eff
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "work" and not wexp:
            put(scr, top, LM, "WORK IN-FLIGHT", DIM)
            # the view opens folded to the graph line — the default reads
            # at project level, one project today; enter unfolds it
            put(scr, top + 2, LM, ("hypercore" + " " * width)[:width], REV)
            summary = ("%d entr%s · %d await your acceptance"
                       % (len(work), "y" if len(work) == 1 else "ies", len(accepts)))
            if len(summary) <= width - len("hypercore") - 2:
                put(scr, top + 2, LM + width - len(summary), summary, REV)

        elif view == "work":
            put(scr, top, LM, "WORK IN-FLIGHT", DIM)
            # one project today: the entries hang a level below their
            # graph — the cheap seam toward many projects, presentation
            # only until a second graph exists
            rows, marks = [[(LM, "hypercore", BOLD)], []], []
            iw = width - 2
            for i, b in enumerate(work):
                # the title owns its row; the state sits beside it only when
                # it fits whole, and wraps below otherwise — never the
                # other way around
                name = b["lines"][0][3:].strip()
                state = b["fields"].get("state", "")
                shown = name if len(name) <= iw else name[: iw - 1] + "…"
                inline = state if state and len(state) <= iw - len(shown) - 2 else ""
                marks.append(len(rows))
                if i == wsel:
                    row = [(LM + 2, (shown + " " * iw)[:iw], REV)]
                    if inline:
                        row.append((LM + 2 + iw - len(inline), inline, REV))
                else:
                    row = [(LM + 2, shown, BOLD)]
                    if inline:
                        row.append((LM + 2 + iw - len(inline), inline, DIM))
                rows.append(row)
                if state and not inline:
                    rows += [[(LM + 4, ln, DIM)] for ln in wrap(state, iw - 2)]
                ask = b["fields"].get("ask")
                if ask:
                    rows += [[(LM + 4, ln, DIM)] for ln in wrap(ask, iw - 2)]
                waits = b["fields"].get("waits on")
                if waits:
                    rows += [[(LM + 4, ln, DIM)]
                             for ln in wrap("waits on " + waits, iw - 2)]
                rows.append([])
            if marks:
                mark = marks[wsel]
                nxt = marks[wsel + 1] if wsel + 1 < len(marks) else len(rows)
                if mark < scroll:
                    scroll = mark
                if nxt > scroll + view_h:
                    scroll = max(0, nxt - view_h)
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view in ("doc", "log"):
            put(scr, top, LM, "INTENT" if view == "doc" else "THE RECORD", DIM)
            if view == "doc":
                rows, cursec = [], None
                for st in stmts:
                    if st["section"] != cursec:
                        cursec = st["section"]
                        rows += [("", 0), ((cursec or "").upper(), BOLD), ("", 0)]
                    attr = DIM if st["pending"] else 0
                    rows += [(ln, attr) for ln in wrap(st["text"], width)]
                    rows.append(("", 0))
            else:
                rows = [((e if len(e) <= width else e[: width - 1] + "…"), 0)
                        for e in run("git", "log", "-200",
                                     "--format=%h %s . %cr").splitlines()]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, (txt, attr) in enumerate(rows[scroll: scroll + view_h]):
                put(scr, top + 2 + i, LM, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        hints = {
            "home": (("enter open . j/k move . " if entries else "")
                     + ("m summon . " if (awaits or dirty) and not machine else "")
                     + "s speak . w work . d document . g log . q quit"),
            "card": "a approve . c cut . e explain . s speak . j/k statements . space/b page . esc back",
            "accept": "a accept . s reservations . j/k slices . space/b page . esc back",
            "exchange": "s speak . c fold away . space/b page . esc back",
            "work": ("j/k move . s speak on it . space/b page . esc fold" if wexp
                     else "enter unfold . s speak . esc back"),
            "doc": "space/b page . s speak . esc back",
            "log": "space/b page . s speak . esc back",
        }[view]
        put(scr, h - 3, LM, "─" * max(0, w - 2 * LM), DIM)
        if confirm:
            kind = confirm[0]
            msg = {"approve": "approve — the marker drops and this statement becomes yours",
                   "cut": "cut — the words leave intent",
                   "accept": "accept — the slice is released and leaves work.md; git keeps the entry",
                   "fold": "fold this exchange away — git keeps the words"}[kind] \
                  + " . y confirm . esc keep"
            put(scr, h - 2, LM, msg[: w - 2 * LM], ALERT if kind == "cut" else BOLD)
        elif flash:
            put(scr, h - 2, LM, flash[: w - 2 * LM], BOLD)
        put(scr, h - 1, LM, hints[: w - 2 * LM], DIM)
        scr.refresh()

        ch = scr.getch()
        if ch == -1:
            # the tick: re-read disk, redraw, touch nothing — except the
            # fullscreen request, retried until the window manager confirms
            if fs_left:
                fs_left, msg = fullscreen_tick(fs_left)
                if msg:
                    flash = msg
            continue
        flash = ""

        if confirm:
            kind, payload = confirm
            confirm = None
            if ch in (ord("y"), ord("Y")):
                if guarded:
                    flash = GUARD
                    continue
                if kind == "fold":
                    hsh = fold_exchange(payload)
                    flash = ("that exchange is no longer on disk — refreshed" if hsh is None
                             else "folded . committed %s" % hsh)
                    view = "home"
                elif kind == "accept":
                    hsh = accept(payload)
                    flash = ("that slice is no longer on disk — refreshed" if hsh is None
                             else "accepted . committed %s . git keeps the entry" % hsh)
                else:
                    card = card_for(payload, cards)
                    hsh = (approve(payload["text"], card is not None) if kind == "approve"
                           else cut(payload["text"], card))
                    flash = ("that statement is no longer on disk — refreshed" if hsh is None
                             else "%s . committed %s" % ("approved" if kind == "approve" else "cut", hsh))
            continue

        if view == "home":
            if ch == ord("q"):
                return
            elif ch in (curses.KEY_DOWN, ord("k")):
                sel += 1
            elif ch in (curses.KEY_UP, ord("j")):
                sel -= 1
            elif ch in (10, 13, curses.KEY_ENTER) and entries:
                kind, obj = entries[sel]
                if kind == "decide":
                    view, ci, scroll = "card", pend.index(obj), 0
                elif kind == "accept":
                    view, ai, scroll = "accept", accepts.index(obj), 0
                else:
                    view, exkey, scroll = "exchange", obj["lines"][0], -1
            elif ch == ord("m") and (awaits or dirty) and not machine:
                machine = start_machine(machine)
                flash = ("the machine is summoned" if machine else
                         "no machine to summon — the machine file names the command")
            elif ch == ord("w") and work:
                view, scroll, wexp = "work", 0, False
            elif ch == ord("d"):
                view, scroll = "doc", 0
            elif ch == ord("g"):
                view, scroll = "log", 0
            elif ch == ord("s"):
                if guarded:
                    flash = GUARD
                else:
                    wd = read_words(scr, h, w, "your words (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak("the queue", wd)
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "card":
            if ch == 27:
                view = "home"
            elif ch in (curses.KEY_RIGHT, ord("k")):
                ci, scroll = ci + 1, 0
            elif ch in (curses.KEY_LEFT, ord("j")):
                ci, scroll = ci - 1, 0
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord(" "):
                scroll += view_h
            elif ch == ord("b"):
                scroll -= view_h
            elif ch == ord("a"):
                confirm = ("approve", pend[ci])
            elif ch == ord("c"):
                confirm = ("cut", pend[ci])
            elif ch in (ord("e"), ord("s")):
                wd = read_words(scr, h, w, "your words (enter sends . empty = just "
                                           "explain . esc abandons): ")
                if wd is not None:
                    hsh = explain(pend[ci], wd)
                    machine = start_machine(machine)
                    flash = ("on disk . committed %s . the machine is answering" % hsh
                             if machine else
                             "on disk . committed %s . no machine to summon — the words wait" % hsh)

        elif view == "accept":
            if ch == 27:
                view = "home"
            elif ch in (curses.KEY_RIGHT, ord("k")):
                ai, scroll = ai + 1, 0
            elif ch in (curses.KEY_LEFT, ord("j")):
                ai, scroll = ai - 1, 0
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord(" "):
                scroll += view_h
            elif ch == ord("b"):
                scroll -= view_h
            elif ch == ord("a"):
                confirm = ("accept", accepts[ai]["lines"][0][3:].strip())
            elif ch == ord("s"):
                if guarded:
                    flash = GUARD
                else:
                    name = accepts[ai]["lines"][0][3:].strip()
                    wd = read_words(scr, h, w,
                                    "your reservations (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak('the acceptance card, on "%s"' % name, wd)
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "exchange":
            if ch == 27:
                view = "home"
            elif ch == curses.KEY_DOWN:
                if scroll != -1:
                    scroll += 1
                    if scroll >= exmax:
                        scroll = -1
            elif ch == curses.KEY_UP:
                scroll = max(0, (exmax if scroll == -1 else scroll) - 1)
            elif ch == ord(" "):
                if scroll != -1:
                    scroll += view_h
                    if scroll >= exmax:
                        scroll = -1
            elif ch == ord("b"):
                scroll = max(0, (exmax if scroll == -1 else scroll) - view_h)
            elif ch == ord("c"):
                confirm = ("fold", exb)
            elif ch == ord("s"):
                if guarded:
                    flash = GUARD
                else:
                    wd = read_words(scr, h, w, "your words (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak_more(exb, wd)
                        machine = start_machine(machine)
                        scroll = -1
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "work":
            if ch == 27:
                if wexp:
                    wexp, scroll = False, 0
                else:
                    view = "home"
            elif ch in (10, 13, curses.KEY_ENTER) and not wexp:
                wexp, scroll = True, 0
            elif ch in (curses.KEY_DOWN, ord("k")) and wexp:
                wsel += 1
            elif ch in (curses.KEY_UP, ord("j")) and wexp:
                wsel -= 1
            elif ch == ord(" ") and wexp:
                scroll += view_h
            elif ch == ord("b") and wexp:
                scroll -= view_h
            elif ch == ord("s") and work:
                if guarded:
                    flash = GUARD
                else:
                    name = (work[wsel]["lines"][0][3:].strip() if wexp
                            else "hypercore")
                    wd = read_words(scr, h, w, "your words (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak('the work view, on "%s"' % name, wd)
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view in ("doc", "log"):
            if ch in (27, ord("q"), ord("d") if view == "doc" else ord("g")):
                view = "home"
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord(" "):
                scroll += view_h
            elif ch == ord("b"):
                scroll -= view_h
            elif ch == ord("s"):
                if guarded:
                    flash = GUARD
                else:
                    place = "the document" if view == "doc" else "the log"
                    wd = read_words(scr, h, w, "your words (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak(place, wd)
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"


if __name__ == "__main__":
    if not os.path.exists(INTENT):
        raise SystemExit("hyper: intent.md not found beside this file")
    locale.setlocale(locale.LC_ALL, "")
    curses.wrapper(main)
