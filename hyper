# ----- disk ------------------------------------------------------------

def run_in(cwd, *args):
    return subprocess.run(args, cwd=cwd, capture_output=True, text=True).stdout


def run(*args):
    return run_in(ROOT, *args)


def read_intent(path=INTENT):
    """Every statement with its section and line span.  A statement is a
    paragraph: consecutive non-blank, non-heading lines."""
    with open(path) as f:
        lines = f.read().splitlines()
    stmts, sec, i = [], None, 0
    while i < len(lines):
        if lines[i].startswith("## "):
            sec = lines[i][3:].strip()
            i += 1
        elif not lines[i].strip() or lines[i].startswith("#"):
            i += 1
        else:
            start = i
            para = []
            while i < len(lines) and lines[i].strip() and not lines[i].startswith("#"):
                para.append(lines[i].strip())
                i += 1
            text = " ".join(para)
            stmts.append({"text": text, "section": sec, "span": (start, i),
                          "pending": text.endswith(MARKER)})
    return lines, stmts


def write_intent(lines, path=INTENT):
    with open(path, "w") as f:
        f.write("\n".join(lines) + "\n")


def linked_intents():
    """Statements from every linked folder's intent.md (the registry is
    the link): outside work lives with its project, so each statement
    carries its project's name, folder, and file — ratifying it edits and
    commits there, never here."""
    out = []
    for b in ledger(REGISTRY):
        name = b["lines"][0][3:].strip()
        root = os.path.expanduser(b["fields"].get("path", ""))
        path = os.path.join(root, "intent.md")
        if os.path.isfile(path):
            _, stmts = read_intent(path)
            for s in stmts:
                s["project"], s["root"], s["file"] = name, root, path
            out += stmts
    return out


# a pick is a decision, not speech: the settle line narrates the act
# instead of quoting the operator (their word, 2026-06-11, twice — "I
# pick a decision, I see it here as if I had written something")
OP_LINES = ("operator (", "the operator decides (")


def ledger(path):
    """A ledger file as raw '## ' blocks: the head line, '- key: value'
    fields, spoken operator/machine lines, and the blockquote if any."""
    if not os.path.exists(path):
        return []
    with open(path) as f:
        raw = f.read().splitlines()
    heads = [i for i, l in enumerate(raw) if l.startswith("## ")]
    blocks = []
    for a, b in zip(heads, heads[1:] + [len(raw)]):
        block = raw[a:b]
        fields, words = {}, []
        for ln in block:
            if ln.startswith("- ") and ": " in ln:
                k, v = ln[2:].split(": ", 1)
                fields[k.strip()] = v.strip()
            elif ln.startswith(OP_LINES + ("machine (",)):
                words.append(ln)
        blocks.append({"quote": " ".join(l[2:].strip() for l in block if l.startswith("> ")),
                       "fields": fields, "words": words, "lines": block})
    return blocks


def write_ledger(path, title, blocks):
    if not blocks:
        if os.path.exists(path):
            os.remove(path)
        return
    out = ["# " + title, ""]
    for b in blocks:
        entry = list(b["lines"])
        while entry and not entry[-1].strip():
            entry.pop()
        out += entry + [""]
    with open(path, "w") as f:
        f.write("\n".join(out) + "\n")


def exchange_sig(b):
    """An answered exchange's identity for unread tracking: the block head
    plus its latest machine line, so a fresh answer reads unread again."""
    last = next((w for w in reversed(b["words"])
                 if w.startswith("machine (")), "")
    return hashlib.sha1((b["lines"][0] + "\n" + last).encode()).hexdigest()


def read_marks():
    if not os.path.exists(READ_FILE):
        return set()
    with open(READ_FILE) as f:
        return set(f.read().split())


def mark_read(b, current):
    """The operator opened the answer: record it, dropping marks whose
    exchanges have folded away."""
    sigs = {exchange_sig(x) for x in current}
    marks = (read_marks() & sigs) | {exchange_sig(b)}
    with open(READ_FILE, "w") as f:
        f.write("\n".join(sorted(marks)) + "\n")


def card_for(st, cards):
    return next((b for b in cards if b["quote"] == st["text"]), None)


def graph_folder(name):
    """Where a graph's folder is today: under work/ while open, under
    archive/ once folded. Either parent exists only while it holds one."""
    for base in (WORKDIR, ARCHDIR):
        d = os.path.join(base, name)
        if os.path.isdir(d):
            return d
    return os.path.join(WORKDIR, name)


def graphs_in(root):
    """Every execution graph under a folder, read fresh:
    <root>/work/<name>/graph.md open, <root>/archive/<name>/graph.md
    folded — a ledger of nodes whose first block is the root ask born
    with its check. Folded graphs stay listed: finishing the work must
    not cost the operator the view of it."""
    out = []
    for sub in ("work", "archive"):
        base = os.path.join(root, sub)
        if not os.path.isdir(base):
            continue
        for name in sorted(os.listdir(base)):
            path = os.path.join(base, name, "graph.md")
            if os.path.exists(path):
                blocks = ledger(path)
                if blocks:
                    out.append((name, blocks))
    return out


def graphs():
    """hypercore's own execution graphs — see graphs_in."""
    return graphs_in(ROOT)


def since_last_act():
    """What the machine did since the operator last acted — read live
    from git every time, no state kept anywhere.  An operator act is a
    commit hyper made in the operator's name, and every such subject says
    so (the subject leads with "operator …"; older generations said
    "the operator …" and "… in the interface"); everything newer is the
    machine's, returned newest first as 'hash subject' lines."""
    out = []
    for line in run("git", "log", "-100", "--format=%h %s").splitlines():
        subject = line.split(" ", 1)[1] if " " in line else ""
        if (subject.startswith(("operator ", "the operator "))
                or ("the operator" in subject
                    and "in the interface" in subject)):
            return out
        out.append(line)
    return out


def gist(line):
    """The latest move as one quiet clause — the act up to its first
    joint, with the thing it concerned when one is named, and the age.
    Carefully selected, not the whole subject: the main screen's last
    line wears this (the operator's word, 2026-06-11 — function and
    beauty shouldn't compete).  Returns (text, age)."""
    rest = line.partition(" ")[2]
    sub, sep, age = rest.rpartition(" . ")
    if not sep or not age.endswith("ago"):
        sub, age = rest, ""
    sub = sub.replace(" in the interface", "")

    def first_joint(s):
        cut = len(s)
        for sp in (": ", " — ", ", ", ". "):
            i = s.find(sp)
            if 0 <= i < cut:
                cut = i
        return cut

    cut = first_joint(sub)
    head, tail = sub[:cut], sub[cut:]
    m = re.search('"[^"]+"', tail)
    if m:
        thing = m.group(0)
    elif tail.startswith(": "):
        t = tail[2:]
        thing = t[: first_joint(t)].rstrip(":,. ")
    else:
        thing = ""
    return (head + " — " + thing if thing else head, age)


# ----- decisions (each one lands on disk and commits) -------------------

def head(text, n=24):
    # the record is read on a wide screen — a subject cut at eight words
    # left entries short with much room to spare (the operator's word,
    # 2026-06-11); the full words always ride in the commit body
    words = text.replace(MARKER, "").split()
    return " ".join(words[:n]) + ("…" if len(words) > n else "")


def commit(subject, body, paths=("intent.md", "queue.md"), root=ROOT):
    # the log is changed at generation, never at display (the operator's
    # word, 2026-06-11): every subject leaves here without the articles
    # that carry nothing — the full words always ride in the body
    subject = " ".join(w for w in subject.split(" ")
                       if w not in ("the", "a", "an"))
    track = [p for p in paths
             if os.path.exists(os.path.join(root, p))
             or run_in(root, "git", "ls-files", p).strip()]
    if track:
        run_in(root, "git", "add", "--", *track)
    run_in(root, "git", "commit", "-m", subject, "-m", body)
    return run_in(root, "git", "log", "-1", "--format=%h").strip()


def find(text, path=INTENT):
    _, stmts = read_intent(path)
    return next((s for s in stmts if s["text"] == text), None)


def drop_card(text, subject, linked_hash, project):
    """A linked statement's card lives in hypercore's queue.md while its
    words live in the linked repo: the intent edit commits there, the
    card's exit commits here, each naming the other."""
    if not any(b["quote"] == text for b in ledger(QUEUE)):
        return
    write_ledger(QUEUE, "queue", [b for b in ledger(QUEUE) if b["quote"] != text])
    commit(subject + " — the card leaves the queue",
           "the statement lives in the linked repo %s; its intent commit "
           "there is %s." % (project, linked_hash), ("queue.md",))


def approve(st, has_card):
    text, path, root = st["text"], st.get("file", INTENT), st.get("root", ROOT)
    cur = find(text, path)
    if cur is None:
        return None
    lines, _ = read_intent(path)
    end = cur["span"][1]
    if lines[end - 1].endswith(MARKER):
        lines[end - 1] = lines[end - 1][: -len(MARKER)]
    write_intent(lines, path)
    grounds = ("grounds: the operator pressed approve in hyper with the card's entailments on screen."
               if has_card else
               "grounds: the operator pressed approve in hyper; no card was on file and the interface said so.")
    subject = "the operator approves: " + head(text)
    if root == ROOT:
        write_ledger(QUEUE, "queue", [b for b in ledger(QUEUE) if b["quote"] != text])
        return commit(subject, text.replace(MARKER, "") + "\n\n" + grounds)
    h = commit(subject, text.replace(MARKER, "") + "\n\n" + grounds
               + "\n\nratified from hyper; hypercore's registry links this folder.",
               ("intent.md",), root)
    drop_card(text, subject, h, st.get("project", "?"))
    return h


def cut(st, card):
    text, path, root = st["text"], st.get("file", INTENT), st.get("root", ROOT)
    cur = find(text, path)
    if cur is None:
        return None
    lines, _ = read_intent(path)
    s, e = cur["span"]
    del lines[s:e]
    if 0 < s < len(lines) and not lines[s - 1].strip() and not lines[s].strip():
        del lines[s]
    write_intent(lines, path)
    breaks = card["fields"].get("cut") if card else None
    body = ('the words that left: "' + text.replace(MARKER, "") + '"\n\n'
            + ("what it breaks, as drafted on the card: " + breaks if breaks else
               "no drafted entailments were on file; the interface said so before the pick."))
    subject = "the operator cuts: " + head(text)
    if root == ROOT:
        write_ledger(QUEUE, "queue", [b for b in ledger(QUEUE) if b["quote"] != text])
        return commit(subject, body)
    h = commit(subject, body, ("intent.md",), root)
    drop_card(text, subject, h, st.get("project", "?"))
    return h


def explain(st, words):
    cards = ledger(QUEUE)
    blk = next((b for b in cards if b["quote"] == st["text"]), None)
    if blk is None:
        blk = {"quote": st["text"],
               "lines": ["## " + head(st["text"]), "", "> " + st["text"], "",
                         "- section: " + (st["section"] or "—")]}
        if st.get("project", "hypercore") != "hypercore":
            blk["lines"].append("- project: " + st["project"])
        cards.append(blk)
    if blk["lines"] and blk["lines"][-1].strip():
        blk["lines"].append("")
    blk["lines"].append("operator (%s): %s" % (date.today().isoformat(),
                        words.strip() or "explain — tell the story"))
    write_ledger(QUEUE, "queue", cards)
    return commit("the operator asks explain: " + head(st["text"]),
                  (words.strip() or "(no words — the machine tells the story)")
                  + "\n\nthe machine reads queue.md at next session start and answers.",
                  ("queue.md",))


def fold_root(gname, root=ROOT):
    """The fold rides the acceptance: when an accepted slice was a graph's
    folding condition (the card names it in a graph field), the result lands
    on the root, the state turns folded, and the folder moves under
    archive/ in the same act — a folded graph is history, archived; work/
    holds only current work and is gone when none is. root is the repo the
    graph lives in — a linked card folds in its own project. Returns
    the edited path (at its new home), or None."""
    src = os.path.join(root, "work", gname)
    path = os.path.join(src, "graph.md")
    if not os.path.exists(path):
        return None
    with open(path) as f:
        raw = f.read().splitlines()
    heads = [i for i, l in enumerate(raw) if l.startswith("## ")]
    if not heads:
        return None
    end = heads[1] if len(heads) > 1 else len(raw)
    for i in range(heads[0], end):
        if raw[i].startswith("- state: "):
            if "folded" in raw[i]:
                return None
            raw[i] = "- state: folded"
            if not any(l.startswith("- result: ") for l in raw[heads[0]:end]):
                raw.insert(i, "- result: accepted by the operator from the "
                              "slice's card (%s)" % date.today().isoformat())
            with open(path, "w") as f:
                f.write("\n".join(raw) + "\n")
            dst = os.path.join(root, "archive", gname)
            os.makedirs(os.path.join(root, "archive"), exist_ok=True)
            run_in(root, "git", "mv", src, dst)
            try:
                os.rmdir(os.path.join(root, "work"))
            except OSError:
                pass  # other work is current — the folder stays
            return os.path.relpath(os.path.join(dst, "graph.md"), root)
    return None


def clear_rider(kind, name):
    """A card's exchange serves the act it informs (the operator's word,
    2026-06-12): once the decision or acceptance lands, an answered rider
    clears with it. A block still ending in operator words awaits the
    machine and stays. Returns the cleared block, or None."""
    key = '## from the %s card, on "%s"' % (kind, name)
    blocks = ledger(WORDS)
    blk = next((b for b in blocks if b["lines"][0].startswith(key)), None)
    if (blk is None or not blk["words"]
            or not blk["words"][-1].startswith("machine (")):
        return None
    write_ledger(WORDS, "words", [b for b in blocks if b is not blk])
    return blk


def accept(name, root=ROOT):
    """One frictionless act: the slice leaves work.md, git keeps the entry,
    and the commit is the operator's acceptance. A card carrying a graph
    field folds that graph in the same commit. root is the repo the card's
    work.md lives in — a linked slice is accepted from hyper and commits
    in its own project (outside work lives with its project, ratified)."""
    wpath = os.path.join(root, "work.md")
    blocks = ledger(wpath)
    blk = next((b for b in blocks if b["lines"][0][3:].strip() == name), None)
    if blk is None:
        return None
    write_ledger(wpath, "work", [b for b in blocks if b is not blk])
    gname = blk["fields"].get("graph")
    folded = fold_root(gname, root) if gname else None
    cleared = clear_rider("acceptance", name)
    body = ("\n".join(blk["lines"])
            + "\n\ngrounds: the operator pressed approve on the card, with what "
              "the slice does and how to try it on screen. git keeps the entry.")
    if folded:
        body += ("\n\nthe slice was %s's folding condition; the fold rides "
                 "this commit — result on the root, state folded, the "
                 "folder moved under archive/." % gname)
    if cleared:
        body += ("\n\nthe answered exchange on the card served the "
                 "acceptance and clears with it (the operator's word, "
                 "2026-06-12). git keeps the words.")
    paths = ["work.md"] + ([folded] if folded else [])
    if cleared and root == ROOT:
        paths.append("words.md")
    h = commit("the operator accepts: " + name
               + (" — %s folds" % gname if folded else ""),
               body, tuple(paths), root)
    if cleared and root != ROOT:
        commit('exchange on "%s" cleared with the acceptance' % name,
               "\n".join(cleared["lines"]) + "\n\ngit keeps the words.",
               ("words.md",))
    return h


def settle_card(name, word, root=ROOT):
    """A decisive word on a decision card settles it on the spot, and the
    decision just is the decision (the operator's word, 2026-06-11): no
    exchange spawns, no line lands in the conversation ledger. The entry's
    state flips to decided in the same commit; the machine executes the
    word and clears the entry with the executing commit. root is the repo
    the card's work.md lives in — a linked entry settles in a commit
    there."""
    stamp = date.today().isoformat()
    wpath = os.path.join(root, "work.md")
    wblocks = ledger(wpath)
    entry = next((b for b in wblocks
                  if b["lines"][0][3:].strip() == name), None)
    if entry is None:
        return None
    entry["lines"] = [("- state: decided (%s) — %s" % (stamp, word.strip()))
                      if l.startswith("- state:") else l
                      for l in entry["lines"]]
    write_ledger(wpath, "work", wblocks)
    cleared = clear_rider("decision", name)
    body = (word.strip() + "\n\nthe decision just is the decision (the "
            "operator's word, 2026-06-11): recorded, not conversation-"
            "spawning. the entry stands decided until the machine executes "
            "the word and clears it with the executing commit.")
    if cleared:
        body += ("\n\nthe answered exchange on the card informed the "
                 "decision and clears with it (the operator's word, "
                 "2026-06-12). git keeps the words.")
    h = commit('the operator decides — "%s": %s' % (name, head(word)),
               body,
               ("work.md", "words.md") if cleared and root == ROOT
               else ("work.md",), root)
    if cleared and root != ROOT:
        commit('exchange on "%s" cleared with the decision' % name,
               "\n".join(cleared["lines"]) + "\n\ngit keeps the words.",
               ("words.md",))
    return h


# ----- speech (from anywhere; the place travels with the words) ---------

def speak(place, words):
    # the queue is the main screen — words spoken there are the default
    # channel, not a place worth naming (the operator's word,
    # 2026-06-11); the place travels only when it narrows context
    stamp = date.today().isoformat()
    headline = ("## from %s . %s" % (place, stamp) if place
                else "## words . %s" % stamp)
    blocks = ledger(WORDS)
    blk = next((b for b in blocks if b["lines"][0] == headline), None)
    if blk is None:
        blk = {"lines": [headline]}
        blocks.append(blk)
    if blk["lines"][-1].strip():
        blk["lines"].append("")
    blk["lines"].append("operator (%s): %s" % (stamp, words.strip()))
    write_ledger(WORDS, "words", blocks)
    m = re.search('"[^"]+"', place or "")
    return commit("the operator speaks%s: %s"
                  % (" on " + m.group(0) if m
                     else ", " + place if place else "", head(words)),
                  words.strip() + "\n\nthe machine reads words.md at next session start and answers.",
                  ("words.md",))


def speak_more(blk, words):
    key = blk["lines"][0]
    blocks = ledger(WORDS)
    tgt = next((b for b in blocks if b["lines"][0] == key), None)
    if tgt is None:
        return None
    if tgt["lines"][-1].strip():
        tgt["lines"].append("")
    tgt["lines"].append("operator (%s): %s" % (date.today().isoformat(), words.strip()))
    write_ledger(WORDS, "words", blocks)
    return commit("the operator speaks again: " + head(words),
                  words.strip() + "\n\nthe machine reads words.md at next session start and answers.",
                  ("words.md",))


def fold_exchange(blk):
    key = blk["lines"][0]
    blocks = ledger(WORDS)
    if not any(b["lines"][0] == key for b in blocks):
        return None
    write_ledger(WORDS, "words", [b for b in blocks if b["lines"][0] != key])
    m = re.search('"[^"]+"', key)
    return commit("the operator folds the exchange%s" % (
                      " on " + m.group(0) if m else ": " + head(key[3:])),
                  "\n".join(blk["lines"]) + "\n\ngit keeps the words.",
                  ("words.md",))


# ----- the machine (summoned by speech; answers onto the same block) -----

def harness_line(envvar, path):
    """One visible setting: the first plain line of the file at the root,
    the environment variable overriding it (testing)."""
    cmd = os.environ.get(envvar)
    if not cmd and os.path.exists(path):
        with open(path) as f:
            cmd = next((l.strip() for l in f
                        if l.strip() and not l.lstrip().startswith("#")), None)
    return cmd


def fill(cmd, prompt):
    argv = [prompt if t == "{prompt}" else t for t in shlex.split(cmd)]
    if prompt not in argv:
        argv.append(prompt)
    return argv


def machine_command(task=SUMMON):
    """The machine file at the root, {prompt} standing for the summon
    instruction — any harness that takes a prompt slots in.  HYPER_MACHINE
    in the environment overrides it (testing); with neither, claude.
    task is the instruction handed in: SUMMON for words, OPEN_WORK for
    open work standing with none."""
    cmd = harness_line("HYPER_MACHINE", MACHINE_FILE)
    if not cmd:
        exe = shutil.which("claude") or os.path.expanduser("~/.local/bin/claude")
        if not os.path.exists(exe):
            return None
        cmd = shlex.quote(exe) + " -p {prompt} --dangerously-skip-permissions"
    return fill(cmd, task)


def mini_command():
    """The small machine for busywork — a bare true-up of a record left
    behind, under the commit-only bar in TRUE_UP.  Set in the mini file
    beside the machine file; with no mini, None — the full machine takes
    the true-up itself."""
    cmd = harness_line("HYPER_MINI", MINI_FILE)
    return fill(cmd, TRUE_UP) if cmd else None


def machine_label():
    """What answers, by name: the harness from the machine command, and
    the model only when the command pins one — the screen never claims
    more than the command states."""
    argv = machine_command()
    if argv is None:
        return "none — the machine file names the command"
    name = os.path.basename(argv[0])
    model = argv[argv.index("--model") + 1] if "--model" in argv[:-1] else None
    return model or name + " · the harness default model — none pinned"


class Foreign:
    """A machine another hyper summoned, known only by the pid in the lock
    file.  poll mirrors Popen: None while it lives, 0 once gone — its real
    exit code died with the hyper that summoned it, and the record check
    catches anything it left behind."""

    returncode = 0

    def __init__(self, pid):
        self.pid = pid

    def poll(self):
        try:
            os.kill(self.pid, 0)
            return None
        except OSError:
            return 0


def locked_machine():
    """The pid the lock file names, if that machine is still alive.  The
    one-machine bar used to live in each hyper's memory and died with it —
    every relaunch while words waited summoned another machine, and three
    once ran at the same time on the same words.  A stale lock (its pid
    gone) is cleared on sight."""
    try:
        with open(MACHINE_PID) as f:
            pid = int(f.read().strip())
        os.kill(pid, 0)
        return pid
    except (OSError, ValueError):
        try:
            os.remove(MACHINE_PID)
        except OSError:
            pass
        return None


def summon(kind="machine", task=None, cwd=None):
    """A headless machine session: it trues up the record if
    it is behind, answers the operator's words onto the blocks that carry
    them, may build under the standing orders, commits as it goes, and
    stops.  The contract is files and git; the brief lands in brief.md so
    any harness reads the same bearings.  kind "mini" is the small machine
    on the bare true-up — no brief, its whole task is in the prompt.
    task overrides the instruction (OPEN_WORK for open work, no words; LINKED
    filled per repo for open work in a linked project).  cwd sends the
    session into a linked repo — the operator's word, 2026-06-11; the
    brief and the log stay hypercore's, named by absolute path."""
    argv = mini_command() if kind == "mini" else machine_command(task or SUMMON)
    if argv is None:
        return None
    if kind != "mini":
        with open(BRIEF, "w") as f:
            f.write(run("bash", os.path.join(".claude", "hooks", "session-brief.sh"),
                        "--plain"))
    log = open(MACHINE_LOG, "ab", buffering=0)
    log.write(("\n--- summoned %s (%s)%s ---\n"
               % (datetime.now().isoformat(timespec="seconds"), kind,
                  " in " + cwd if cwd else "")).encode())
    try:
        return subprocess.Popen(argv, cwd=cwd or ROOT, stdin=subprocess.DEVNULL,
                                stdout=log, stderr=log, start_new_session=True)
    except FileNotFoundError:
        log.write(("the %s command was not found: %s\n" % (kind, argv[0])).encode())
        return None


def start_machine(machine, kind="machine", task=None, cwd=None, label=None):
    """Summon unless one is already working — this hyper's own, or one
    another hyper summoned, adopted from the lock file (it reads from
    disk, so words that land mid-answer wait visibly and m summons
    again).  Two hypers booting in the same instant can still double;
    the lock shrinks the window from every relaunch to that blink."""
    if machine:
        return machine
    pid = locked_machine()
    if pid:
        try:
            started = os.path.getmtime(MACHINE_PID)
        except OSError:
            started = time.time()
        return (Foreign(pid), started, "machine")
    p = summon(kind, task, cwd)
    if not p:
        return None
    with open(MACHINE_PID, "w") as f:
        f.write(str(p.pid))
    return (p, time.time(), label or kind)


def note(msg):
    """The flash dies with the screen; the log line is always quotable."""
    with open(HYPER_LOG, "a") as f:
        f.write("%s  %s\n" % (datetime.now().isoformat(timespec="seconds"), msg))
    return msg


def play_cue():
    """A short sound when the queue turns actionable — the operator asked
    for it (2026-06-13) so they need not watch the screen; cue-attention is
    their pick. Fire-and-forget through paplay: no audio (no paplay, no sink)
    is a silent no-op, never an error in the loop."""
    try:
        subprocess.Popen(["paplay", CUE],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError:
        pass


def attn_key(kind, obj):
    """A stable identity for an item needing the operator — a statement by
    its text, a card or exchange by its heading — so the cue fires only on
    new arrivals, never while items just sit."""
    return (kind, obj["text"] if kind == "decide" else obj["lines"][0])


def ensure_launcher():
    """The menu entry that launches hyper without a fresh login: a symlink
    in the applications directory to the repo's hyper.desktop, kept by
    hyper itself the way the autostart entry is — the repo stays the only
    place the entry is written.  A test hyper (the machine overridden in
    the environment) never touches it, and a healthy link to some other
    live copy is left alone — only a dangling link is taken over; this is
    how the entry once went missing.  Returns a flash only when something
    is wrong; the landing itself goes to the log."""
    if os.environ.get("HYPER_MACHINE") or os.environ.get("HYPER_MINI"):
        return None
    target = os.path.join(ROOT, "hyper.desktop")
    link = os.path.join(os.path.expanduser("~"), ".local", "share",
                        "applications", "hyper.desktop")
    try:
        if os.path.islink(link):
            if os.readlink(link) == target:
                return None
            if os.path.exists(link):  # healthy, someone else's — not stolen
                return note("the menu entry points at another live hyper: %s "
                            "— left alone" % os.readlink(link))
            os.remove(link)
        elif os.path.exists(link):
            return note("a hyper.desktop that is not ours sits in the "
                        "applications menu — left alone")
        os.makedirs(os.path.dirname(link), exist_ok=True)
        os.symlink(target, link)
        note("the menu entry landed — hyper launches from the desktop menu now")
        return None
    except OSError as e:
        return note("the menu entry could not land: %s" % e)


def fullscreen_taken(wid):
    """Whether the window manager shows the window fullscreen yet; None
    when xprop is not there to ask."""
    try:
        r = subprocess.run(["xprop", "-id", wid, "_NET_WM_STATE"],
                           capture_output=True, text=True)
        if r.returncode == 0:
            return "_NET_WM_STATE_FULLSCREEN" in r.stdout
    except FileNotFoundError:
        pass
    return None


def fullscreen_tick(left):
    """ghostty ignores fullscreen=true at window creation on Linux
    (ghostty-org/ghostty #11252), and a request can fire before the window
    manager has taken the window — a startup race.  So when the login
    launcher asks (HYPER_FULLSCREEN=1): one request per tick until the
    window manager confirms it took, every outcome on disk where it stays
    quotable.  Returns (tries left, flash)."""
    wid = os.environ["WINDOWID"]
    taken = fullscreen_taken(wid)
    if taken:
        note("fullscreen confirmed by the window manager")
        return 0, ""
    try:
        r = subprocess.run(["wmctrl", "-i", "-r", wid, "-b", "add,fullscreen"],
                           capture_output=True, text=True)
    except FileNotFoundError:
        return 0, note("wmctrl is not installed — the fullscreen request could not be made")
    if r.returncode != 0:
        return 0, note("the fullscreen request failed — "
                       + (r.stderr.strip() or "no reason given"))
    left -= 1
    if left == 0 and taken is False:
        return 0, note("the fullscreen request was sent %d times and never stuck"
                       % FS_TRIES)
    if taken is None:
        return min(left, 2), ""  # nobody to confirm — ask thrice and rest
    return left, ""


def focus_taken(wid):
    """Whether the window manager shows the keyboard in the window yet;
    None when xprop is not there to ask."""
    try:
        r = subprocess.run(["xprop", "-root", "_NET_ACTIVE_WINDOW"],
                           capture_output=True, text=True)
        if r.returncode == 0 and "window id #" in r.stdout:
            active = r.stdout.rsplit("#", 1)[1].split()[0].rstrip(",")
            return int(active, 16) == int(wid)
    except (FileNotFoundError, ValueError, IndexError):
        pass
    return None


def focus_tick(left):
    """The window manager can take the window fullscreen and still leave
    the keyboard elsewhere: focus-stealing prevention rejects ghostty's
    timestamp-0 activation, the interface fills the screen, and every
    keystroke lands in the window behind it (2026-06-11 — the operator
    typed at a dead screen and the keys went to the browser under it).
    So, beside the fullscreen retries: confirm the focus, and where it
    was refused take it directly — XSetInputFocus, which the activation
    politics cannot veto — until the window manager shows it held.
    Returns (tries left, flash)."""
    wid = os.environ["WINDOWID"]
    taken = focus_taken(wid)
    if taken:
        note("keyboard focus confirmed by the window manager")
        return 0, ""
    try:
        r = subprocess.run(["xdotool", "windowfocus", wid],
                           capture_output=True, text=True)
    except FileNotFoundError:
        return 0, note("xdotool is not installed — keyboard focus could "
                       "not be taken")
    if r.returncode != 0:
        return 0, note("the focus request failed — "
                       + (r.stderr.strip() or "no reason given"))
    left -= 1
    if left == 0 and taken is False:
        return 0, note("the focus request was sent %d times and never stuck"
                       % FS_TRIES)
    if taken is None:
        return min(left, 2), ""  # nobody to confirm — ask thrice and rest
    return left, ""


# ----- screen -----------------------------------------------------------

def put(scr, y, x, s, attr=0):
    try:
        scr.addstr(y, x, s, attr)
    except curses.error:
        pass


def wrap(text, width):
    return textwrap.wrap(text, max(10, width)) or [""]


def read_words(scr, h, w, prompt):
    """The operator's words at the bottom of the screen, visible whole and
    editable until sent: the text wraps across as many lines as it needs,
    arrows move the cursor anywhere, home/end jump within the line,
    backspace and delete edit in place.  Enter sends, esc abandons —
    until then nothing binds."""
    curses.curs_set(1)
    scr.timeout(-1)
    width = max(10, w - 2 * LM)
    buf, pos, top_seen = "", 0, h - 2
    try:
        while True:
            rows = [buf[i:i + width] for i in range(0, len(buf), width)] or [""]
            if buf and len(buf) % width == 0:
                rows.append("")
            cr, cc = divmod(pos, width)
            maxrows = max(1, h - 8)
            base = max(0, cr - maxrows + 1)
            vis = rows[base:base + maxrows]
            top = h - 2 - len(vis) - 1
            top_seen = min(top_seen, top)
            for y in range(top_seen, h):
                put(scr, y, 0, " " * (w - 1))
            put(scr, top, LM, prompt[: w - 2 * LM], curses.A_DIM)
            for i, ln in enumerate(vis):
                put(scr, top + 1 + i, LM, ln)
            put(scr, h - 1, LM,
                "enter sends . esc abandons . arrows move . home/end jump"[: w - 2 * LM],
                curses.A_DIM)
            scr.move(top + 1 + cr - base, min(LM + cc, w - 2))
            scr.refresh()
            ch = scr.get_wch()
            if ch in ("\n", "\r") or ch == curses.KEY_ENTER:
                return buf
            if ch == "\x1b":
                return None
            if ch in ("\x7f", "\b") or ch == curses.KEY_BACKSPACE:
                if pos:
                    buf, pos = buf[: pos - 1] + buf[pos:], pos - 1
            elif ch == curses.KEY_DC:
                buf = buf[:pos] + buf[pos + 1:]
            elif ch == curses.KEY_LEFT:
                pos = max(0, pos - 1)
            elif ch == curses.KEY_RIGHT:
                pos = min(len(buf), pos + 1)
            elif ch == curses.KEY_UP:
                pos = max(0, pos - width)
            elif ch == curses.KEY_DOWN:
                pos = min(len(buf), pos + width)
            elif ch == curses.KEY_HOME or ch == "\x01":
                pos = (pos // width) * width
            elif ch == curses.KEY_END or ch == "\x05":
                pos = min(len(buf), (pos // width) * width + width)
            elif isinstance(ch, str) and ch.isprintable():
                buf, pos = buf[:pos] + ch + buf[pos:], pos + len(ch)
    finally:
        curses.curs_set(0)
        scr.timeout(1000)


def main(scr):
    try:
        curses.set_escdelay(25)
    except AttributeError:
        pass
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_RED, -1)
    curses.init_pair(2, curses.COLOR_YELLOW, -1)
    curses.init_pair(3, curses.COLOR_CYAN, -1)
    ALERT = curses.color_pair(1) | curses.A_BOLD
    ACCENT = curses.color_pair(2) | curses.A_BOLD
    DIM, BOLD, REV = curses.A_DIM, curses.A_BOLD, curses.A_REVERSE
    # the log's rows alternate a faint shade for multiline readability
    # (the operator's word, 2026-06-11 — the traditional approach, kept
    # subtle); event types tell apart by color, not text (their word,
    # seventh round) — tasteful and muted: sand for the operator's
    # speech, moss for their decisions, plain dim for the machine
    ZEBRA, SPEAK, DECIDE = 0, curses.A_DIM, curses.A_DIM
    # color pairs do not OR together — a colored act on a shaded row
    # needs its own on-shade pair, or it paints a black block (the
    # operator saw it); ZMAP carries each colored attr to its shaded twin
    ZMAP = {}
    if curses.COLORS >= 256:
        curses.init_pair(4, -1, 233)
        curses.init_pair(5, 180, -1)
        curses.init_pair(6, 108, -1)
        curses.init_pair(7, 180, 233)
        curses.init_pair(8, 108, 233)
        ZEBRA = curses.color_pair(4)
        SPEAK, DECIDE = curses.color_pair(5), curses.color_pair(6)
        ZMAP = {SPEAK: curses.color_pair(7), DECIDE: curses.color_pair(8)}
    # the queue leads each entry with its kind — what kind of call the
    # operator faces reads before any title does
    KINDS = {"decide": ("decide", BOLD), "settle": ("decide", BOLD),
             "accept": ("accept", ACCENT),
             "read": ("answered", DIM), "sent": ("sent", DIM)}

    AGE_W = 14  # the age column — wide enough for "13 minutes ago"

    def log_segs(line, x, room):
        # the log is changed at generation, never at display (the
        # operator's word, 2026-06-11 — no combining the two approaches):
        # subjects arrive article-free from commit(), and the display
        # renders them as written — columns for hash and age, color held
        # to the act phrase so the substance stays plain ink.
        hsh, _, rest = line.partition(" ")
        sub, sep, age = rest.rpartition(" . ")
        if not sep or not age.endswith("ago"):
            sub, age = rest, ""
        cut = len(sub)
        for sp in (": ", " — "):
            i = sub.find(sp)
            if 0 <= i < cut:
                cut = i
        act = sub[:cut]
        if act.startswith(("operator speaks", "operator asks",
                           "operator folds", "the operator speaks",
                           "the operator asks", "the operator folds")):
            aattr = SPEAK
        elif (act.startswith(("operator ", "the operator "))
              or ("the operator" in act and "in the interface" in act)):
            aattr = DECIDE
        elif act.startswith(("machine", "mini", "trued",
                             "the machine", "the mini")):
            aattr = DIM
        else:
            aattr, cut = 0, 0
        acol = x + room - AGE_W
        hcol = (acol - 2 if age else x + room) - len(hsh)
        segs = []
        text_room = hcol - x - 2
        subj = (sub if len(sub) <= text_room
                else sub[: max(1, text_room - 1)] + "…")
        if cut and aattr:
            segs.append((x, subj[:cut], aattr))
            if len(subj) > cut:
                segs.append((x + cut, subj[cut:], 0))
        else:
            segs.append((x, subj, 0))
        if hcol > x:
            segs.append((hcol, hsh, DIM))
        if age:
            segs.append((acol + max(0, AGE_W - len(age)), age[:AGE_W], DIM))
        return segs
    GUT = 10  # the kind column

    view, sel, ci, ai, si, wsel, gsel = "home", 0, 0, 0, 0, 0, 0
    back = None  # where h left from — h on home returns there
    wexp = None  # the work view opens folded; set, it names the unfolded project
    dunit = 0  # the project whose documents the document view shows
    scroll, flash, confirm, exkey = 0, "", None, None
    prev_attn = None  # the last tick's set of items needing the operator — the
                      # cue fires on new arrivals; None until the first tick seeds it
    machine = None  # (Popen, started, kind) while a summoned session is working
    escalate = False  # a mini left work behind — the next summon goes to the full machine
    boot = True  # the first frame summons the machine itself when the record calls
    resummon = False  # words landed mid-answer — one more summon when this one ends
    worked_head = None  # the head the last unattended summon worked from
    lworked = {}  # the same guard per linked repo, keyed by project name
    flash = ensure_launcher() or flash
    fs_left = (FS_TRIES if os.environ.get("HYPER_FULLSCREEN")
               and os.environ.get("WINDOWID") else 0)
    foc_left = fs_left
    if fs_left:
        fs_left, flash = fullscreen_tick(fs_left)
    if foc_left:
        foc_left, msg = focus_tick(foc_left)
        flash = flash or msg
    scr.timeout(1000)  # the screen re-reads disk on its own — no restart anywhere

    while True:
        _, stmts = read_intent()
        for s in stmts:
            s["project"], s["root"], s["file"] = "hypercore", ROOT, INTENT
        lstmts = linked_intents()
        # hypercore's statements keep the head of the queue; a linked
        # project's pending statements follow, each wearing its name
        pend = [s for s in stmts + lstmts if s["pending"]]
        cards = ledger(QUEUE)
        exchanges = ledger(WORDS)
        work = ledger(WORK)
        gs = graphs()
        # the work view's units: the repo's own standing work first, then
        # every execution graph — folded ones too — read live; the graphs
        # are hypercore's children and show under its line, never beside
        # it (the operator's pick, 2026-06-11)
        projects = [("hypercore", None)] + gs
        linked = ledger(REGISTRY)
        # a linked project is a unit of its own (the operator's word,
        # 2026-06-11): its folder carries its work.md and graphs, read
        # live — outside work lives with its project (ratified). each
        # unit's graph entries follow its own entry, so a graph's
        # project index sits just past its parent's.
        lidx = []
        # the standing-work line counts everything the work view shows —
        # linked ledgers and open graphs included (the operator's word,
        # 2026-06-11: discuss stood invisible in a count of 0). a linked
        # entry awaiting the operator is a queue card like hypercore's
        # own — each block wears its project and root so the act commits
        # in the right repo; lunits feeds the linked summons
        lwork_n = lgopen = 0
        lflat, lunits = [], []
        for b in linked:
            lname = b["lines"][0][3:].strip()
            lpath = os.path.expanduser(b["fields"].get("path", ""))
            lwpath = os.path.join(lpath, "work.md")
            lwork = ledger(lwpath) if os.path.exists(lwpath) else []
            for x in lwork:
                x["project"], x["root"] = lname, lpath
            lgs = graphs_in(lpath)
            lidx.append(len(projects))
            projects.append((lname, ("linked", lpath, lwork, lgs)))
            projects.extend(lgs)
            lwork_n += len(lwork)
            lopen_n = sum(1 for _, blks in lgs
                          if "folded" not in blks[0]["fields"].get("state", ""))
            lgopen += lopen_n
            lflat += lwork
            lunits.append((lname, lpath, lopen_n))
        # gopen is hypercore's own — the unattended summons works this
        # repo; what a linked project's graphs wait on lives with them
        gopen = sum(1 for _, blks in gs
                    if "folded" not in blks[0]["fields"].get("state", ""))
        dirty = run("git", "status", "--porcelain").strip()
        last = run("git", "log", "-1", "--format=%h %s . %cr").strip()

        awaits = [b for b in cards + exchanges
                  if b["words"] and b["words"][-1].startswith(OP_LINES)]
        if machine and machine[0].poll() is not None:
            rc, kind = machine[0].returncode, machine[2]
            if locked_machine() == machine[0].pid:
                try:
                    os.remove(MACHINE_PID)
                except OSError:
                    pass
            machine = None
            if kind == "mini" and (rc != 0 or dirty):
                # the mini's bar: commit what is on disk, leave the rest —
                # whatever it leaves escalates to the full machine
                escalate = True
                flash = note("the mini left work behind%s — named in "
                             ".hyper-machine.log; m summons the full machine"
                             % ("" if rc == 0 else " (exit %d)" % rc))
            elif rc != 0:
                flash = note("the machine failed (exit %d) — .hyper-machine.log "
                             "holds the story; m retries" % rc)
            else:
                flash = ("the mini trued up the record" if kind == "mini"
                         else "the machine has finished")
                if resummon and awaits:
                    # words landed mid-answer — one more summon, and the flag
                    # is consumed: only a fresh operator act sets it again
                    machine = start_machine(None)
                    if machine:
                        flash = "words landed mid-answer — the machine is summoned again"
            resummon = False
        if not dirty:
            escalate = False
        if boot:
            # the machine answers without m: at launch, a behind record or
            # waiting words summon it themselves; m stays as the manual retry
            boot = False
            if (awaits or dirty) and not machine:
                kind = ("mini" if dirty and not awaits and mini_command()
                        else "machine")
                machine = start_machine(machine, kind)
                if machine:
                    flash = (note("a machine another hyper summoned is "
                                  "working — adopted, not doubled")
                             if isinstance(machine[0], Foreign) else
                             "the record called — the %s is summoned" % kind)

        # unattended summons (option 3, the operator's pick 2026-06-11):
        # open work with no machine running and no words waiting summons
        # the machine itself — work moves without the operator watching.
        # progress is the guard: one summon per head, so a session that
        # leaves the work standing (it waits on the operator, or it made
        # no move) cannot loop the spend; m is the manual override.
        # the summons reaches linked repos too (the operator's word,
        # 2026-06-11): hypercore's own open work first, then each linked
        # project with an open graph, the session sent into that repo
        # under the standing orders, guarded by its own head
        head = last.partition(" ")[0]
        if not machine and not awaits and not dirty:
            if gopen and head != worked_head:
                machine = start_machine(None, task=OPEN_WORK)
                if machine:
                    worked_head = head
                    flash = note("open work stands — the machine is "
                                 "summoned to it")
            else:
                for lname, lpath, lopen_n in lunits:
                    if not lopen_n:
                        continue
                    lhead = run_in(lpath, "git", "log", "-1",
                                   "--format=%h").strip()
                    if not lhead or lhead == lworked.get(lname):
                        continue
                    machine = start_machine(
                        None, task=LINKED % {"name": lname, "hyper": ROOT},
                        cwd=lpath, label="machine in " + lname)
                    if machine:
                        lworked[lname] = lhead
                        flash = note("open work stands in %s — the machine "
                                     "is summoned into it" % lname)
                    break

        accepts = [b for b in work + lflat
                   if "awaiting acceptance" in b["fields"].get("state", "")]
        # standing work is the operator's action list: an entry awaiting
        # their decision is a queue card like any other call they face —
        # a linked project's entries included, each wearing its name
        decides = [b for b in work + lflat
                   if "awaiting your decision" in b["fields"].get("state", "")]
        # words spoken on a work card ride that card: they show below it,
        # not as their own queue item, while the card stands
        riders = tuple(['## from the acceptance card, on "%s"'
                        % b["lines"][0][3:].strip() for b in accepts]
                       + ['## from the decision card, on "%s"'
                          % b["lines"][0][3:].strip() for b in decides])
        standalone = [b for b in exchanges
                      if not b["lines"][0].startswith(riders)]
        # a card the operator has spoken on wears that, not its stale
        # state: their word landed, the machine owes the next move
        spoken = set()
        for kind, blks in (("decision", decides), ("acceptance", accepts)):
            for b in blks:
                key = ('## from the %s card, on "%s"'
                       % (kind, b["lines"][0][3:].strip()))
                if any(x["words"] and x["words"][-1].startswith(OP_LINES)
                       for x in exchanges if x["lines"][0].startswith(key)):
                    spoken.add(b["lines"][0])
        # a statement the operator wrote under is spoken the same way:
        # their words end its card unanswered, so the next move is the
        # machine's, not theirs (the operator's word, 2026-06-11)
        for s in pend:
            c = card_for(s, cards)
            s["spoken"] = bool(c and c["words"]
                               and c["words"][-1].startswith(OP_LINES))
        answered = [b for b in standalone
                    if b["words"] and b["words"][-1].startswith("machine (")]
        seen = read_marks()
        for b in answered:
            b["unread"] = exchange_sig(b) not in seen
        sent = [b for b in standalone if b not in answered]
        # what needs the operator sorts above what waits on the machine
        # (the operator's word, 2026-06-11): a spoken-on card and an
        # unanswered exchange need nothing until the response lands
        attention = ([("decide", s) for s in pend if not s["spoken"]]
                     + [("settle", b) for b in decides
                        if b["lines"][0] not in spoken]
                     + [("accept", b) for b in accepts
                        if b["lines"][0] not in spoken]
                     + [("read", b) for b in answered])
        waiting = ([("decide", s) for s in pend if s["spoken"]]
                   + [("settle", b) for b in decides
                      if b["lines"][0] in spoken]
                   + [("accept", b) for b in accepts
                      if b["lines"][0] in spoken]
                   + [("sent", b) for b in sent])
        entries = attention + waiting
        nattn = len(attention)
        # a sound when the queue turns actionable, so the operator need not
        # watch the screen (their word, 2026-06-13; cue-attention their pick):
        # cue on any newly-arrived item needing them — the nothing→something
        # transition and each new card alike — never while items just sit. the
        # first tick seeds the set silently; an already-open hyper is not news.
        cur_attn = {attn_key(k, o) for k, o in attention}
        if prev_attn is not None and cur_attn - prev_attn:
            play_cue()
        prev_attn = cur_attn
        sel = max(0, min(sel, len(entries) - 1))
        ci = max(0, min(ci, len(pend) - 1))
        ai = max(0, min(ai, len(accepts) - 1))
        si = max(0, min(si, len(decides) - 1))
        # the top-level lines: hypercore, then each linked project —
        # all selectable (the operator's word, 2026-06-11)
        gsel = max(0, min(gsel, len(lidx)))
        dunit = max(0, min(dunit, len(projects) - 1))
        if wexp is not None and wexp >= len(projects):
            wexp = None
        if wexp in (None, 0):
            nwitems = len(work) + len(gs)
        else:
            pdata = projects[wexp][1]
            nwitems = (len(pdata[2]) + len(pdata[3])
                       if isinstance(pdata, tuple) else len(pdata))
        wsel = max(0, min(wsel, nwitems - 1))
        exb, exmax = None, 0
        if view == "card" and not pend:
            view = "home"
        if view == "accept" and not accepts:
            view = "home"
        if view == "settle" and not decides:
            view = "home"
        if view == "exchange":
            exb = next((b for b in exchanges if b["lines"][0] == exkey), None)
            if exb is None:
                view = "home"

        scr.erase()
        h, w = scr.getmaxyx()
        width = min(w - 2 * LM, 76)
        top = 4
        view_h = max(1, h - top - 6)
        # the guard is scoped per act (the operator's pick, 2026-06-11):
        # each act blocks only on the files its own commit writes —
        # speech on words.md, ratification on intent or queue, cards on
        # work.md and words.md — so the machine mid-write on one ledger
        # never locks the others
        dirty_files = {l.split()[-1] for l in dirty.splitlines()}
        held = MIDWRITE if machine else GUARD

        put(scr, 0, LM, "H Y P E R C O R E", BOLD)
        parts = []
        if pend or decides:
            parts.append("%d TO DECIDE" % (len(pend) + len(decides)))
        if accepts:
            parts.append("%d TO ACCEPT" % len(accepts))
        if answered:
            parts.append("%d ANSWERED" % len(answered))
        status = " . ".join(parts) if parts else "QUEUE CLEAR"
        put(scr, 0, max(LM, w - len(status) - LM), status, BOLD if parts else DIM)
        put(scr, 1, LM, "─" * max(0, w - 2 * LM), DIM)
        mtxt = ""
        if machine:
            # the clock reads like speech — 1m 50s, not 1:50 (the
            # operator's word, 2026-06-11); under a minute the minutes go
            mins, secs = divmod(int(time.time() - machine[1]), 60)
            mtxt = ("the %s is working · %s"
                    % (machine[2],
                       "%dm %02ds" % (mins, secs) if mins else "%ds" % secs))
            put(scr, 2, max(LM, w - len(mtxt) - LM), mtxt, BOLD)
        elif awaits:
            mtxt = ("%d word%s the machine — m summons it"
                    % (len(awaits), " awaits" if len(awaits) == 1 else "s await"))
            put(scr, 2, max(LM, w - len(mtxt) - LM), mtxt, DIM)
        if dirty:
            # red is reserved for a dead session's leavings — the one
            # state that needs the operator; a working machine's dirty
            # tree is just the work happening, and reads dim
            files = ", ".join(l.split()[-1] for l in dirty.splitlines())
            room = w - 2 * LM - (len(mtxt) + 2 if mtxt else 0)
            if machine:
                put(scr, 2, LM,
                    ("the machine is mid-write: %s" % files)[: max(0, room)],
                    DIM)
            else:
                put(scr, 2, LM,
                    ("the record is behind — uncommitted: %s — m trues it up"
                     % files)[: max(0, room)], ALERT)

        if view == "home":
            y = top
            # the queue wears a head: what the machine did since the
            # operator's last act, read live from git each tick — the
            # transparency record, without leaving the queue. the main
            # screen speaks in calm prose (the operator's word,
            # 2026-06-11 — immaculate, tasteful, never tarnished);
            # columns, hashes, and stripes stay in the log view
            moves = since_last_act()
            if moves:
                put(scr, y, LM, "SINCE YOU LAST ACTED — %d MOVE%s"
                    % (len(moves), "" if len(moves) == 1 else "S"), DIM)
                y += 1
                hw = w - 2 * LM - 2
                for ln in moves[:4]:
                    subj = ln.partition(" ")[2].strip()
                    if len(subj) > hw:
                        subj = subj[: max(1, hw - 1)] + "…"
                    put(scr, y, LM + 2, subj, DIM)
                    y += 1
                if len(moves) > 4:
                    put(scr, y, LM + 2,
                        "… %d more — g opens the log" % (len(moves) - 4), DIM)
                    y += 1
                y += 1
            put(scr, y, LM, "THE QUEUE", DIM)
            y += 2
            if entries:
                for i, (kind, obj) in enumerate(entries):
                    label, lattr = KINDS[kind]
                    if ((kind in ("settle", "accept")
                            and obj["lines"][0] in spoken)
                            or (kind == "decide" and obj.get("spoken"))):
                        label, lattr = "spoken", DIM
                    if kind == "decide":
                        text = obj["text"].replace(MARKER, "")
                        tag = obj["section"] or ""
                        if obj.get("project", "hypercore") != "hypercore":
                            tag = obj["project"] + (" · " + tag if tag else "")
                    else:
                        text = obj["lines"][0][3:].strip()
                        tag = (obj["project"]
                               if obj.get("project", "hypercore") != "hypercore"
                               else "")
                    room = width - GUT - (len(tag) + 2 if tag else 0)
                    if len(text) > room:
                        text = text[: max(1, room - 1)] + "…"
                    # every decision wears the cost of its own delay: a
                    # card filed with a blocks field carries it on the
                    # queue line itself, dim after the title
                    cost = (obj["fields"].get("blocks", "")
                            if kind in ("settle", "accept") else "")
                    crm = room - len(text) - 3
                    if cost and crm >= 12:
                        if len(cost) > crm:
                            cost = cost[: max(1, crm - 1)] + "…"
                    else:
                        cost = ""
                    if i == sel:
                        # selection is a bar beside the line, not a wash
                        # over it (the operator's word, 2026-06-11 — the
                        # highlighter obscured the status): every color
                        # on the row stays its own
                        put(scr, y, 0, "▌", ACCENT)
                        put(scr, y, LM, label, lattr | BOLD)
                        put(scr, y, LM + GUT, text, BOLD)
                        if cost:
                            put(scr, y, LM + GUT + len(text),
                                " — " + cost, DIM | BOLD)
                        if tag:
                            put(scr, y, LM + width - len(tag), tag, BOLD)
                    else:
                        # an unread answer reads bold and clears once
                        # opened — proper unread behavior, in place of
                        # the dot (their word, 2026-06-12)
                        if kind == "read" and obj.get("unread"):
                            put(scr, y, LM, label, BOLD)
                            put(scr, y, LM + GUT, text, BOLD)
                        else:
                            put(scr, y, LM, label, lattr)
                            put(scr, y, LM + GUT, text,
                                0 if kind in ("decide", "settle", "accept")
                                else DIM)
                        if cost:
                            put(scr, y, LM + GUT + len(text),
                                " — " + cost, DIM)
                        if tag:
                            put(scr, y, LM + width - len(tag), tag, DIM)
                    y += 1
            else:
                put(scr, y, LM, "nothing waits on you.", DIM)
                y += 1
            y += 1
            # the standing-work line, in the operator's own words
            # (2026-06-11): the line below the queue, and only that one —
            # the counts, then the key that opens them ("your" stays cut).
            # the counts span the linked projects too
            put(scr, y, LM,
                ("standing work: %d . awaiting acceptance: %d . "
                 "open subgraphs: %d . w opens the view"
                 % (len(work) + lwork_n, len(accepts), gopen + lgopen))
                [: w - 2 * LM], DIM)
            y += 1
            # the line below is one quiet clause — the act, the thing it
            # concerned, the age; carefully selected, never the whole
            # subject. it reads "latest:" — the newspaper vibe (the
            # operator's word, 2026-06-11)
            ltxt, lage = gist(last)
            put(scr, y, LM,
                ("latest: " + ltxt + (" . " + lage if lage else ""))
                [: w - 2 * LM], DIM)

        elif view == "card":
            st = pend[ci]
            card = card_for(st, cards)
            sec = st["section"] or "—"
            if st.get("project", "hypercore") != "hypercore":
                sec = st["project"] + " · " + sec
            put(scr, top, LM,
                ("%s . %d of %d" % (sec, ci + 1, len(pend))).upper(), DIM)
            rows = [[(LM, ln, BOLD)] for ln in wrap(st["text"].replace(MARKER, ""), width)]
            rows += [[(LM, "[machine]", DIM)], []]
            drafted = False
            if card:
                for key in ("context", "approve", "cut"):
                    val = card["fields"].get(key)
                    if not val:
                        continue
                    drafted = True
                    first = True
                    for ln in wrap(val, width - 9):
                        rows.append([(LM, "%7s" % key, DIM), (LM + 9, ln, 0)]
                                    if first else [(LM + 9, ln, 0)])
                        first = False
            if not drafted:
                rows += [[(LM, ln, BOLD)]
                         for ln in wrap("no entailments on file — context and what "
                                        "approve or cut entails is not drafted; "
                                        "e asks the machine for them.", width)]
            if card and card["words"]:
                rows += [[], [(LM, "THE EXCHANGE SO FAR", DIM)]]
                for wln in card["words"]:
                    attr = (DECIDE if wln.startswith("the operator decides (")
                            else DIM if wln.startswith("operator (") else 0)
                    rows.append([])
                    rows += [[(LM + 2, ln, attr)] for ln in wrap(wln, width - 2)]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "settle":
            # a standing work entry awaiting the operator's decision: the
            # ask, the options with what each entails, and one channel —
            # the operator's word settles it
            blk = decides[si]
            name = blk["lines"][0][3:].strip()
            shead = "awaiting your decision . %d of %d" % (si + 1, len(decides))
            if blk.get("project", "hypercore") != "hypercore":
                shead = blk["project"] + " . " + shead
            put(scr, top, LM, shead.upper(), DIM)
            rows = [[(LM, ln, BOLD)] for ln in wrap(name, width)]
            rows.append([])
            opts = [o.strip() for o in blk["fields"].get("options", "").split(" . ")
                    if o.strip()]
            for key, label in (("ask", "it asks"), ("blocks", "blocks"),
                               ("options", None),
                               ("state", "state"), ("since", "since")):
                if key == "options":
                    # each option wears the number that picks it — the
                    # number is the word, y confirms, and the option's own
                    # words land on the card in the operator's name
                    for n, opt in enumerate(opts, 1):
                        first = True
                        for ln in wrap(opt, width - 9):
                            rows.append([(LM, "%7d" % n, BOLD), (LM + 9, ln, 0)]
                                        if first else [(LM + 9, ln, 0)])
                            first = False
                        rows.append([])
                    continue
                val = blk["fields"].get(key)
                if key == "state" and blk["lines"][0] in spoken:
                    val = "your words landed — the machine is on it"
                if not val:
                    continue
                first = True
                for ln in wrap(val, width - 9):
                    rows.append([(LM, "%7s" % label, DIM), (LM + 9, ln, 0)]
                                if first else [(LM + 9, ln, 0)])
                    first = False
                rows.append([])
            chat = [wln for b in exchanges
                    if b["lines"][0].startswith(
                        '## from the decision card, on "%s"' % name)
                    for wln in b["words"]]
            if chat:
                rows += [[(LM, "THE EXCHANGE SO FAR", DIM)]]
                for wln in chat:
                    attr = (DECIDE if wln.startswith("the operator decides (")
                            else DIM if wln.startswith("operator (") else 0)
                    rows.append([])
                    rows += [[(LM + 2, ln, attr)] for ln in wrap(wln, width - 2)]
                rows.append([])
            rows += [[(LM, ln, DIM)]
                     for ln in wrap("a approves . c cuts"
                                    + (" . 1–%d picks an option" % len(opts)
                                       if opts else "")
                                    + " — y confirms any, and the word lands "
                                    "on the card for the machine to execute; "
                                    "s speaks anything else in your own "
                                    "words.", width)]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "accept":
            blk = accepts[ai]
            name = blk["lines"][0][3:].strip()
            ahead = "awaiting your acceptance . %d of %d" % (ai + 1, len(accepts))
            if blk.get("project", "hypercore") != "hypercore":
                ahead = blk["project"] + " . " + ahead
            put(scr, top, LM, ahead.upper(), DIM)
            rows = [[(LM, ln, BOLD)] for ln in wrap(name, width)]
            rows.append([])
            for key, label in (("ask", "it does"), ("blocks", "blocks"),
                               ("try", "try it"),
                               ("state", "state"), ("waits on", "waits")):
                val = blk["fields"].get(key)
                if key == "state" and blk["lines"][0] in spoken:
                    val = "your words landed — the machine is on it"
                if not val:
                    continue
                first = True
                for ln in wrap(val, width - 9):
                    rows.append([(LM, "%7s" % label, DIM), (LM + 9, ln, 0)]
                                if first else [(LM + 9, ln, 0)])
                    first = False
                rows.append([])
            chat = [wln for b in exchanges
                    if b["lines"][0].startswith(
                        '## from the acceptance card, on "%s"' % name)
                    for wln in b["words"]]
            if chat:
                rows += [[(LM, "THE EXCHANGE SO FAR", DIM)]]
                for wln in chat:
                    attr = (DECIDE if wln.startswith("the operator decides (")
                            else DIM if wln.startswith("operator (") else 0)
                    rows.append([])
                    rows += [[(LM + 2, ln, attr)] for ln in wrap(wln, width - 2)]
                rows.append([])
            rows += [[(LM, ln, DIM)]
                     for ln in wrap("a then y approves and releases the slice — the "
                                    "entry leaves work.md, git keeps it. speak only "
                                    "if you have reservations.", width)]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "exchange":
            # the exchange reads as a chat: it opens pinned to the newest
            # words (scroll == -1) and follows them as they land; scrolling
            # up unpins, reaching the bottom pins again.
            put(scr, top, LM, exb["lines"][0][3:].strip().upper(), DIM)
            rows = []
            for wln in exb["words"]:
                attr = (DECIDE if wln.startswith("the operator decides (")
                        else DIM if wln.startswith("operator (") else 0)
                rows.append([])
                rows += [[(LM, ln, attr)] for ln in wrap(wln, width)]
            exmax = max(0, len(rows) - view_h)
            eff = exmax if scroll == -1 else max(0, min(scroll, exmax))
            for i, segs in enumerate(rows[eff: eff + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            if eff > 0:
                put(scr, top + 1, LM, "… %d above — ↑ scrolls" % eff, DIM)
            below = len(rows) - view_h - eff
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "work" and wexp is None:
            put(scr, top, LM, "STANDING WORK", DIM)
            # the view opens folded to one line per top-level unit — today
            # hypercore alone; its graphs are children, reached by
            # unfolding it, never beside it
            # the summary speaks the operator's format (their word,
            # 2026-06-11 — "your" is cut)
            summary = ("standing work: %d . awaiting acceptance: %d"
                       % (len(work), len(accepts)))
            if gs:
                summary += (" . open subgraphs: %d" % gopen if gopen
                            else " . folded subgraphs: %d" % len(gs))
            # one selectable line per top-level unit: hypercore first,
            # then every linked project — outside work lives with its
            # project (ratified), each a peer, never a child; enter
            # unfolds the line under the cursor, d opens its documents
            tops = [("hypercore", summary)]
            # a linked project's line wears the same data as hypercore's
            # (the operator's word, 2026-06-11 — discuss read thinner);
            # its path moves to the unfolded headline
            for n, b in enumerate(linked):
                lname = b["lines"][0][3:].strip()
                ldata = projects[lidx[n]][1]
                lw, lgs = ldata[2], ldata[3]
                lacc = sum(1 for x in lw if "awaiting acceptance"
                           in x["fields"].get("state", ""))
                lsum = ("standing work: %d . awaiting acceptance: %d"
                        % (len(lw), lacc))
                if lgs:
                    lopen = sum(1 for _, blks in lgs
                                if "folded" not in blks[0]["fields"].get("state", ""))
                    lsum += (" . open subgraphs: %d" % lopen if lopen
                             else " . folded subgraphs: %d" % len(lgs))
                tops.append((lname, lsum))
            for i, (tname, tsum) in enumerate(tops):
                if i >= view_h:
                    break
                y = top + 2 + i
                if i == gsel:
                    put(scr, y, LM, (tname + " " * width)[:width], REV)
                    if len(tsum) <= width - len(tname) - 2:
                        put(scr, y, LM + width - len(tsum), tsum, REV)
                else:
                    put(scr, y, LM, tname, BOLD)
                    if len(tsum) <= width - len(tname) - 2:
                        put(scr, y, LM + width - len(tsum), tsum, DIM)

        elif view == "work":
            put(scr, top, LM, "STANDING WORK", DIM)
            # one unit unfolded: under hypercore, work.md entries first and
            # its execution graphs below them — children under their
            # parent; a graph unfolds further to its nodes, its head
            # naming the parent its root's of: field records
            pname, pdata = projects[wexp]
            if pdata is None:
                items, glines, headline = work, gs, pname
            elif isinstance(pdata, tuple):
                # a linked project unfolds to its own work and graphs,
                # read live from its folder
                items, glines = pdata[2], pdata[3]
                headline = (pname + " · linked · "
                            + pdata[1].replace(os.path.expanduser("~"), "~"))
            else:
                items, glines = pdata, []
                headline = (pdata[0]["fields"].get("of", "hypercore")
                            + " › " + pname)
            rows, marks = [[(LM, headline, BOLD)], []], []
            iw = width - 2
            for i, b in enumerate(items):
                # the title owns its row; the state sits beside it only when
                # it fits whole, and wraps below otherwise — never the
                # other way around
                name = b["lines"][0][3:].strip()
                state = b["fields"].get("state", "")
                shown = name if len(name) <= iw else name[: iw - 1] + "…"
                inline = state if state and len(state) <= iw - len(shown) - 2 else ""
                marks.append(len(rows))
                if i == wsel:
                    row = [(LM + 2, (shown + " " * iw)[:iw], REV)]
                    if inline:
                        row.append((LM + 2 + iw - len(inline), inline, REV))
                else:
                    row = [(LM + 2, shown, BOLD)]
                    if inline:
                        row.append((LM + 2 + iw - len(inline), inline, DIM))
                rows.append(row)
                if state and not inline:
                    rows += [[(LM + 4, ln, DIM)] for ln in wrap(state, iw - 2)]
                ask = b["fields"].get("ask")
                if ask:
                    rows += [[(LM + 4, ln, DIM)] for ln in wrap(ask, iw - 2)]
                for key in ("check", "result"):
                    val = b["fields"].get(key)
                    if val:
                        rows += [[(LM + 4, ln, DIM)]
                                 for ln in wrap(key + ": " + val, iw - 2)]
                waits = b["fields"].get("waits on")
                if waits:
                    rows += [[(LM + 4, ln, DIM)]
                             for ln in wrap("waits on " + waits, iw - 2)]
                rows.append([])
            for j, (gname, gblocks) in enumerate(glines):
                i = len(items) + j
                folded = "folded" in gblocks[0]["fields"].get("state", "")
                nodes = "%d node%s" % (len(gblocks),
                                       "" if len(gblocks) == 1 else "s")
                if folded:
                    gsum = "folded · " + nodes
                else:
                    gsum = "%s · %d open" % (nodes, sum(
                        1 for b in gblocks
                        if "open" in b["fields"].get("state", "")))
                shown = gname if len(gname) <= iw else gname[: iw - 1] + "…"
                inline = gsum if len(gsum) <= iw - len(shown) - 2 else ""
                marks.append(len(rows))
                if i == wsel:
                    row = [(LM + 2, (shown + " " * iw)[:iw], REV)]
                    if inline:
                        row.append((LM + 2 + iw - len(inline), inline, REV))
                else:
                    row = [(LM + 2, shown, BOLD)]
                    if inline:
                        row.append((LM + 2 + iw - len(inline), inline, DIM))
                rows.append(row)
                if folded:
                    # a fold can be trusted only as far as its checks
                    # reach (ratified): the archived line wears its
                    # root's check, so that reach reads from the list
                    chk = gblocks[0]["fields"].get("check")
                    if chk:
                        rows += [[(LM + 4, ln, DIM)]
                                 for ln in wrap("check: " + chk, iw - 2)]
                rows.append([])
            if marks:
                mark = marks[wsel]
                nxt = marks[wsel + 1] if wsel + 1 < len(marks) else len(rows)
                if mark < scroll:
                    scroll = mark
                if nxt > scroll + view_h:
                    scroll = max(0, nxt - view_h)
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view in ("doc", "log"):
            dname = projects[dunit][0] if view == "doc" else ""
            put(scr, top, LM,
                ("INTENT" if dunit == 0 else dname.upper())
                if view == "doc" else "THE RECORD", DIM)
            if view == "doc" and dunit == 0:
                rows, cursec = [], None
                for st in stmts:
                    if st["section"] != cursec:
                        cursec = st["section"]
                        rows += [("", 0), ((cursec or "").upper(), BOLD), ("", 0)]
                    attr = DIM if st["pending"] else 0
                    rows += [(ln, attr) for ln in wrap(st["text"], width)]
                    rows.append(("", 0))
            elif view == "doc" and isinstance(projects[dunit][1], tuple):
                # a linked project's document is its intent.md, read live
                # from its own folder
                rows = []
                ipath = os.path.join(projects[dunit][1][1], "intent.md")
                if os.path.isfile(ipath):
                    with open(ipath, encoding="utf-8") as f:
                        for ln in f.read().splitlines():
                            rows += ([(wl, 0) for wl in wrap(ln, width)]
                                     or [("", 0)])
                else:
                    rows = [("no intent.md in " + projects[dunit][1][1], DIM)]
            elif view == "doc":
                # a graph's documents are its folder, read live — under
                # work/ while open, under archive/ once folded — every
                # file in it, led by its name; a linked graph's folder
                # sits under its own project
                folder = graph_folder(dname)
                if not os.path.isdir(folder):
                    for b in linked:
                        lp = os.path.expanduser(b["fields"].get("path", ""))
                        for sub in ("work", "archive"):
                            cand = os.path.join(lp, sub, dname)
                            if os.path.isdir(cand):
                                folder = cand
                rows = []
                for fn in (sorted(os.listdir(folder))
                           if os.path.isdir(folder) else []):
                    fpath = os.path.join(folder, fn)
                    if not os.path.isfile(fpath):
                        continue
                    rows += [("", 0), (fn, BOLD), ("", 0)]
                    with open(fpath, encoding="utf-8") as f:
                        for ln in f.read().splitlines():
                            rows += [(wl, 0) for wl in wrap(ln, width)]
            else:
                # the record gets the whole screen — the rows asked for
                # room (the operator's word), and the 76-column measure
                # is for prose, not a table
                lw = w - 2 * LM
                rows = [log_segs(e, LM, lw)
                        for e in run("git", "log", "-200",
                                     "--format=%h %s . %cr").splitlines()]
            if view == "doc":
                rows = [[(LM, txt, attr)] if txt else [] for txt, attr in rows]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                # the stripes ride the entries, not the screen — scrolling
                # keeps each row's shade
                shade = (ZEBRA if view == "log" and (scroll + i) % 2 else 0)
                if shade:
                    put(scr, top + 2 + i, LM, " " * (w - 2 * LM), shade)
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt,
                        ZMAP.get(attr, attr | shade) if shade else attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        hints = {
            "home": (("enter open . j/k move . " if entries else "")
                     + ("m summon . " if (awaits or dirty or gopen)
                        and not machine else "")
                     + ("h back . " if back else "")
                     + "s speak . w work . g log . q quit"),
            "card": "a approve . c cut . e explain . s speak . j/k statements . space/b page . h home . esc back",
            "settle": "a approve . c cut . 1–9 pick . s speak . j/k cards . space/b page . h home . esc back",
            "accept": "a approve . s speak . j/k slices . space/b page . h home . esc back",
            "exchange": "s speak . c fold away . space/b page . h home . esc back",
            "work": ("enter unfold . d document . s speak . h home . esc back"
                     if wexp is None else
                     "enter unfold graph . j/k move . d document . "
                     "s speak on it . space/b scroll . h home . esc fold"
                     if wexp == 0 else
                     "j/k move . s speak on it . space/b scroll . h home . esc back"),
            "doc": "space/b page . s speak . h home . esc back",
            "log": "space/b page . s speak . h home . esc back",
        }[view]
        put(scr, h - 3, LM, "─" * max(0, w - 2 * LM), DIM)
        if confirm:
            # the one thing that matters reads first and loudest: y confirms
            kind = confirm[0]
            lead = "y confirms %s . esc keeps things as they are" \
                   % {"approve": "approve", "cut": "the cut", "accept": "approve",
                      "fold": "the fold", "go": "approve", "cut-card": "the cut",
                      "pick": "option %s" % (confirm[1][1] if kind == "pick" else "")}[kind]
            tail = {"approve": "the marker drops; the statement becomes yours",
                    "cut": "the words leave intent",
                    "accept": "the slice is released; git keeps the entry",
                    "fold": "the exchange leaves the queue; git keeps the words",
                    "go": "the word settles the card — it leaves the queue; "
                          "the machine executes it",
                    "cut-card": "the word settles the card — it leaves the queue; "
                                "the machine executes it",
                    "pick": "the option's words land in your name and settle "
                            "the card; the machine executes them"}[kind]
            put(scr, h - 2, LM, lead[: w - 2 * LM],
                ALERT if kind in ("cut", "cut-card") else BOLD)
            x = LM + len(lead) + 3
            if x < w - LM:
                put(scr, h - 2, x, tail[: w - LM - x], DIM)
        elif flash:
            put(scr, h - 2, LM, flash[: w - 2 * LM], BOLD)
        put(scr, h - 1, LM, hints[: w - 2 * LM], DIM)
        # the machine's name sits bottom right, dim, out of the queue's
        # way — drawn only when it fits clear of the key hints
        label = machine_label()
        if LM + len(hints) + 2 + len(label) <= w - LM:
            put(scr, h - 1, w - LM - len(label), label, DIM)
        scr.refresh()

        ch = scr.getch()
        if ch == -1:
            # the tick: re-read disk, redraw, touch nothing — except the
            # fullscreen and focus requests, retried until the window
            # manager confirms each
            if fs_left:
                fs_left, msg = fullscreen_tick(fs_left)
                if msg:
                    flash = msg
            if foc_left:
                foc_left, msg = focus_tick(foc_left)
                if msg:
                    flash = msg
            continue
        flash = ""

        if confirm:
            kind, payload = confirm
            confirm = None
            if ch in (ord("y"), ord("Y")):
                needs = {"go": ("words.md", "work.md"),
                         "cut-card": ("words.md", "work.md"),
                         "pick": ("words.md", "work.md"),
                         "fold": ("words.md",),
                         "accept": ("work.md",),
                         "approve": ("intent.md", "queue.md"),
                         "cut": ("intent.md", "queue.md")}[kind]
                if dirty_files.intersection(needs):
                    flash = held
                    continue
                # a linked card's act writes its own repo's work.md too —
                # the same per-act guard, scoped to that repo
                root = (payload[-1] if kind in ("go", "cut-card", "pick",
                                                "accept") else ROOT)
                if root != ROOT and run_in(root, "git", "status",
                                           "--porcelain", "work.md").strip():
                    flash = held
                    continue
                if kind in ("go", "cut-card", "pick"):
                    # the key is the word, and the word is decisive: it
                    # lands on the card, the card settles in the same
                    # commit, and the machine executes it
                    if kind == "pick":
                        name, n, opt, root = payload
                        word = "option %d — %s" % (n, opt)
                    else:
                        name, root = payload
                        word = "approve" if kind == "go" else "cut"
                    hsh = settle_card(name, word, root)
                    resummon = resummon or machine is not None
                    machine = start_machine(machine)
                    flash = ("%s . settled . committed %s . the machine is working" % (word, hsh)
                             if machine else
                             "%s . settled . committed %s . no machine to summon — the word waits" % (word, hsh))
                elif kind == "fold":
                    hsh = fold_exchange(payload)
                    flash = ("that exchange is no longer on disk — refreshed" if hsh is None
                             else "folded . committed %s" % hsh)
                    view = "home"
                elif kind == "accept":
                    hsh = accept(*payload)
                    flash = ("that slice is no longer on disk — refreshed" if hsh is None
                             else "approved . committed %s . git keeps the entry" % hsh)
                else:
                    card = card_for(payload, cards)
                    hsh = (approve(payload, card is not None) if kind == "approve"
                           else cut(payload, card))
                    flash = ("that statement is no longer on disk — refreshed" if hsh is None
                             else "%s . committed %s" % ("approved" if kind == "approve" else "cut", hsh))
            continue

        if ch == ord("h"):
            # h jumps home from anywhere; from home it returns to where
            # you last were (the operator's word, 2026-06-11)
            if view != "home":
                back = (view, sel, ci, ai, si, wsel, gsel, wexp, dunit,
                        scroll, exkey)
                view, scroll = "home", 0
            elif back:
                (view, sel, ci, ai, si, wsel, gsel, wexp, dunit,
                 scroll, exkey) = back
                back = None
            continue

        # space/b adapt to the page (the operator's word, 2026-06-11 —
        # what reads best comes down to the view): the reading views
        # page; the lists keep their one-line walk; arrows stay the fine
        # grain everywhere, home/end the snap to the edges. in an
        # exchange, space pages toward the tail and pins there
        if view in ("card", "settle", "accept", "exchange", "doc", "log"):
            if ch == ord(" "):
                ch = curses.KEY_NPAGE
            elif ch == ord("b"):
                ch = curses.KEY_PPAGE

        if ch in (curses.KEY_NPAGE, curses.KEY_PPAGE,
                  curses.KEY_HOME, curses.KEY_END):
            # the jumps live on their own keys (the operator's word,
            # 2026-06-11): pgup/pgdn jump a screenful, home/end jump to
            # the edges — generalized from the main page to every view
            step = {curses.KEY_NPAGE: view_h, curses.KEY_PPAGE: -view_h,
                    curses.KEY_HOME: -10 ** 6, curses.KEY_END: 10 ** 6}[ch]
            if view == "home":
                sel = max(0, min(sel + step, len(entries) - 1))
            elif view == "exchange":
                if ch == curses.KEY_END:
                    scroll = -1
                elif ch == curses.KEY_HOME:
                    scroll = 0
                elif ch == curses.KEY_NPAGE and scroll != -1:
                    scroll += view_h
                    if scroll >= exmax:
                        scroll = -1
                elif ch == curses.KEY_PPAGE:
                    scroll = max(0, (exmax if scroll == -1 else scroll)
                                 - view_h)
            elif view == "work":
                if wexp is None:
                    gsel = max(0, min(gsel + step, len(lidx)))
                else:
                    wsel = max(0, min(wsel + step, nwitems - 1))
            else:
                scroll = max(0, scroll + step)
            continue

        if view == "home":
            if ch == ord("q"):
                return
            elif ch in (curses.KEY_DOWN, ord("k")):
                sel += 1
            elif ch in (curses.KEY_UP, ord("j")):
                sel -= 1
            elif ch in (10, 13, curses.KEY_ENTER) and entries:
                kind, obj = entries[sel]
                if kind == "decide":
                    view, ci, scroll = "card", pend.index(obj), 0
                elif kind == "settle":
                    view, si, scroll = "settle", decides.index(obj), 0
                elif kind == "accept":
                    view, ai, scroll = "accept", accepts.index(obj), 0
                else:
                    view, exkey, scroll = "exchange", obj["lines"][0], -1
                    if kind == "read":
                        mark_read(obj, answered)
            elif (ch == ord("m") and not machine
                  and (awaits or dirty or gopen or lgopen)):
                # busywork goes to the mini: a bare true-up — record behind,
                # no words waiting, nothing escalated — is its whole class;
                # open work with neither gets the work summons by hand —
                # the override when the progress guard holds the automatic
                # one. with only a linked repo's work open, the session
                # goes into that repo (the operator's word, 2026-06-11)
                kind = ("mini" if dirty and not awaits and not escalate
                        and mini_command() else "machine")
                task, cwd, label = None, None, None
                if not awaits and not dirty:
                    if gopen:
                        task = OPEN_WORK
                    else:
                        lname, lpath, _ = next(
                            (u for u in lunits if u[2]), (None, None, 0))
                        if lname:
                            task = LINKED % {"name": lname, "hyper": ROOT}
                            cwd, label = lpath, "machine in " + lname
                machine = start_machine(machine, kind, task, cwd, label)
                if machine and task is not None:
                    if cwd:
                        lworked[lname] = run_in(
                            cwd, "git", "log", "-1", "--format=%h").strip()
                    else:
                        worked_head = last.partition(" ")[0]
                flash = ("the %s is summoned" % (label or kind) if machine else
                         "no machine to summon — the machine file names the command")
            elif ch == ord("w"):
                # always open — finished work stays visible, its list and
                # documents reachable; nothing open is a state, not a wall
                view, scroll, wexp = "work", 0, None
            elif ch == ord("g"):
                view, scroll = "log", 0
            elif ch == ord("s"):
                if "words.md" in dirty_files:
                    flash = held
                else:
                    wd = read_words(scr, h, w, "your words "
                                               "(enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak("", wd)
                        resummon = resummon or machine is not None
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is working" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "card":
            if ch == 27:
                view = "home"
            elif ch in (curses.KEY_RIGHT, ord("k")):
                ci, scroll = ci + 1, 0
            elif ch in (curses.KEY_LEFT, ord("j")):
                ci, scroll = ci - 1, 0
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord("a"):
                confirm = ("approve", pend[ci])
            elif ch == ord("c"):
                confirm = ("cut", pend[ci])
            elif ch in (ord("e"), ord("s")):
                wd = read_words(scr, h, w, "your words, on this statement (enter sends . "
                                           "empty = just explain . esc abandons): ")
                if wd is not None:
                    hsh = explain(pend[ci], wd)
                    resummon = resummon or machine is not None
                    machine = start_machine(machine)
                    flash = ("on disk . committed %s . the machine is working" % hsh
                             if machine else
                             "on disk . committed %s . no machine to summon — the words wait" % hsh)

        elif view == "settle":
            if ch == 27:
                view = "home"
            elif ch in (curses.KEY_RIGHT, ord("k")):
                si, scroll = si + 1, 0
            elif ch in (curses.KEY_LEFT, ord("j")):
                si, scroll = si - 1, 0
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord("a"):
                confirm = ("go", (decides[si]["lines"][0][3:].strip(),
                                  decides[si].get("root", ROOT)))
            elif ch == ord("c"):
                confirm = ("cut-card", (decides[si]["lines"][0][3:].strip(),
                                        decides[si].get("root", ROOT)))
            elif ord("1") <= ch <= ord("9"):
                opts = [o.strip() for o in
                        decides[si]["fields"].get("options", "").split(" . ")
                        if o.strip()]
                n = ch - ord("0")
                if n <= len(opts):
                    confirm = ("pick", (decides[si]["lines"][0][3:].strip(),
                                        n, opts[n - 1],
                                        decides[si].get("root", ROOT)))
            elif ch == ord("s"):
                if "words.md" in dirty_files:
                    flash = held
                else:
                    name = decides[si]["lines"][0][3:].strip()
                    wd = read_words(scr, h, w,
                                    'your words, on "%s" '
                                    "(enter sends . esc abandons): " % name)
                    if wd and wd.strip():
                        hsh = speak('the decision card, on "%s"' % name, wd)
                        resummon = resummon or machine is not None
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is working" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "accept":
            if ch == 27:
                view = "home"
            elif ch in (curses.KEY_RIGHT, ord("k")):
                ai, scroll = ai + 1, 0
            elif ch in (curses.KEY_LEFT, ord("j")):
                ai, scroll = ai - 1, 0
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord("a"):
                confirm = ("accept", (accepts[ai]["lines"][0][3:].strip(),
                                      accepts[ai].get("root", ROOT)))
            elif ch == ord("s"):
                if "words.md" in dirty_files:
                    flash = held
                else:
                    name = accepts[ai]["lines"][0][3:].strip()
                    wd = read_words(scr, h, w,
                                    'your words, on "%s" '
                                    "(enter sends . esc abandons): " % name)
                    if wd and wd.strip():
                        hsh = speak('the acceptance card, on "%s"' % name, wd)
                        resummon = resummon or machine is not None
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is working" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "exchange":
            if ch == 27:
                view = "home"
            elif ch == curses.KEY_DOWN:
                if scroll != -1:
                    scroll += 1
                    if scroll >= exmax:
                        scroll = -1
            elif ch == curses.KEY_UP:
                scroll = max(0, (exmax if scroll == -1 else scroll) - 1)
            elif ch == ord("c"):
                confirm = ("fold", exb)
            elif ch == ord("s"):
                if "words.md" in dirty_files:
                    flash = held
                else:
                    wd = read_words(scr, h, w, "your words, into this exchange "
                                               "(enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak_more(exb, wd)
                        resummon = resummon or machine is not None
                        machine = start_machine(machine)
                        scroll = -1
                        flash = ("on disk . committed %s . the machine is working" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "work":
            if ch == 27:
                pdata = projects[wexp][1] if wexp is not None else None
                if wexp is None:
                    view = "home"
                elif wexp == 0 or isinstance(pdata, tuple):
                    # a unit folds back to its own top line
                    gsel = 0 if wexp == 0 else 1 + lidx.index(wexp)
                    wexp, scroll = None, 0
                else:
                    # a graph backs out to its own line under its parent —
                    # the same path that reached it
                    parent = 0
                    for li in lidx:
                        if wexp > li:
                            parent = li
                    if parent == 0:
                        wexp, wsel, scroll = 0, len(work) + (wexp - 1), 0
                    else:
                        plw = len(projects[parent][1][2])
                        wexp, wsel, scroll = (parent,
                                              plw + (wexp - parent - 1), 0)
            elif ch in (10, 13, curses.KEY_ENTER):
                if wexp is None:
                    # enter unfolds the top line under the cursor
                    wexp = 0 if gsel == 0 else lidx[gsel - 1]
                    wsel, scroll = 0, 0
                else:
                    pdata = projects[wexp][1]
                    if wexp == 0 and wsel >= len(work) and gs:
                        # enter on a graph line unfolds it to its nodes
                        wexp, wsel, scroll = 1 + (wsel - len(work)), 0, 0
                    elif (isinstance(pdata, tuple)
                          and wsel >= len(pdata[2]) and pdata[3]):
                        wexp, wsel, scroll = (
                            wexp + 1 + (wsel - len(pdata[2])), 0, 0)
            elif ch == ord("d") and wexp is None:
                # the selection is the unit: d opens the documents of the
                # line under the cursor — intent.md for a project
                dunit = 0 if gsel == 0 else lidx[gsel - 1]
                view, scroll = "doc", 0
            elif ch == ord("d") and wexp is not None:
                pdata = projects[wexp][1]
                if wexp == 0 and wsel >= len(work) and gs:
                    # d on a graph line opens that graph's documents
                    dunit, view, scroll = 1 + (wsel - len(work)), "doc", 0
                elif isinstance(pdata, tuple):
                    dunit = (wexp + 1 + (wsel - len(pdata[2]))
                             if wsel >= len(pdata[2]) and pdata[3] else wexp)
                    view, scroll = "doc", 0
            elif ch in (curses.KEY_DOWN, ord("k")):
                if wexp is None:
                    gsel += 1
                else:
                    wsel += 1
            elif ch in (curses.KEY_UP, ord("j")):
                if wexp is None:
                    gsel -= 1
                else:
                    wsel -= 1
            elif ch == ord(" ") and wexp is not None:
                scroll += 1
            elif ch == ord("b") and wexp is not None:
                scroll -= 1
            elif ch == ord("s"):
                if "words.md" in dirty_files:
                    flash = held
                else:
                    # the place travels with the words: a project line, a
                    # work.md entry, or a node of the graph it belongs to
                    if wexp is None:
                        name = ("hypercore" if gsel == 0
                                else projects[lidx[gsel - 1]][0])
                        place = 'the work view, on "%s"' % name
                    else:
                        pname, pdata = projects[wexp]
                        if pdata is None and wsel >= len(work) and gs:
                            name = gs[wsel - len(work)][0]
                            place = 'the work view, on the graph "%s"' % name
                        elif pdata is None:
                            name = (work[wsel]["lines"][0][3:].strip()
                                    if work else pname)
                            place = 'the work view, on "%s"' % name
                        elif isinstance(pdata, tuple):
                            litems, lgs = pdata[2], pdata[3]
                            if wsel >= len(litems) and lgs:
                                name = lgs[wsel - len(litems)][0]
                                place = ('the work view, on the graph "%s"'
                                         % name)
                            else:
                                name = (litems[wsel]["lines"][0][3:].strip()
                                        if litems else pname)
                                place = 'the work view, on "%s"' % name
                        else:
                            name = (pdata[wsel]["lines"][0][3:].strip()
                                    if pdata else pname)
                            place = 'the graph "%s", on "%s"' % (pname, name)
                    wd = read_words(scr, h, w, 'your words, on "%s" '
                                               "(enter sends . esc abandons): " % name)
                    if wd and wd.strip():
                        hsh = speak(place, wd)
                        resummon = resummon or machine is not None
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is working" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view in ("doc", "log"):
            if ch in (27, ord("q"), ord("d") if view == "doc" else ord("g")):
                # the document goes back where its line lives: intent to
                # the folded view, a graph's folder to its line under
                # its parent; the log still backs out to the queue
                view = "work" if view == "doc" else "home"
                if view == "work":
                    pdata = projects[dunit][1]
                    if dunit == 0:
                        wexp, scroll = None, 0
                    elif isinstance(pdata, tuple):
                        gsel = 1 + lidx.index(dunit)
                        wexp, scroll = None, 0
                    else:
                        parent = 0
                        for li in lidx:
                            if dunit > li:
                                parent = li
                        if parent == 0:
                            wexp, wsel, scroll = (0, len(work) + dunit - 1,
                                                  0)
                        else:
                            plw = len(projects[parent][1][2])
                            wexp, wsel, scroll = (
                                parent, plw + (dunit - parent - 1), 0)
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord("s"):
                if "words.md" in dirty_files:
                    flash = held
                else:
                    place = (("the document" if dunit == 0 else
                              'the documents of "%s"' % projects[dunit][0])
                             if view == "doc" else "the log")
                    wd = read_words(scr, h, w, "your words, from %s "
                                               "(enter sends . esc abandons): " % place)
                    if wd and wd.strip():
                        hsh = speak(place, wd)
                        resummon = resummon or machine is not None
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is working" % hsh
                                 if machine else
                                 "on disk . committed %s . no machine to summon — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"


if __name__ == "__main__":
    if not os.path.exists(INTENT):
        raise SystemExit("hyper: intent.md not found beside this file")
    locale.setlocale(locale.LC_ALL, "")
    curses.wrapper(main)
