#!/usr/bin/env python3
"""hyper — the operator's interface to hypercore.

One file, stdlib only, keyboard only.  Every frame is read fresh from
disk: intent.md (the system), queue.md (decision cards), words.md (open
exchanges), work.md (work in flight).  Every move the operator makes
lands on disk and is committed in their name before the screen redraws.
The screen re-reads disk on a one-second tick, so what lands shows up
on its own — no restart anywhere.

    ./hyper

Views    queue (home) . decision card . exchange . work . document . log
Decide   a approve . c cut . e explain (words optional)
Speak    s anywhere — words land verbatim, the place travels with them,
         and the machine is summoned to answer while you watch
Move     arrows . left/right across statements . up/down within the
         screen . enter open . esc back . q quit
"""

import curses
import locale
import os
import shlex
import shutil
import subprocess
import textwrap
import time
from datetime import date, datetime

ROOT = os.path.dirname(os.path.abspath(__file__))
INTENT = os.path.join(ROOT, "intent.md")
QUEUE = os.path.join(ROOT, "queue.md")
WORDS = os.path.join(ROOT, "words.md")
WORK = os.path.join(ROOT, "work.md")
MARKER = " [machine]"
LM = 3  # left margin

LEDGERS = ("intent.md", "queue.md", "words.md")
GUARD = "intent.md, queue.md or words.md has uncommitted changes — resolve before moving"

MACHINE_LOG = os.path.join(ROOT, ".hyper-machine.log")
SUMMON = (
    "the operator spoke in hyper and the interface summoned you. read the "
    "session brief, then queue.md and words.md; every operator word whose "
    "card or exchange block does not end with a machine line awaits you. "
    "answer each as a 'machine (YYYY-MM-DD): ...' line appended to the same "
    "block, per the standing orders — short enough to read on a card. if "
    "the words start work bigger than an answer, record the ask in work.md "
    "and say so in the answer; build nothing in this channel. decisions "
    "that are the operator's land as questions in your answer line, to be "
    "settled in the interface — never assumed. never use AskUserQuestion "
    "here: nobody can see it. commit every change with grounds, then stop."
)


# ----- disk ------------------------------------------------------------

def run(*args):
    return subprocess.run(args, cwd=ROOT, capture_output=True, text=True).stdout


def read_intent():
    """Every statement with its section and line span.  A statement is a
    paragraph: consecutive non-blank, non-heading lines."""
    with open(INTENT) as f:
        lines = f.read().splitlines()
    stmts, sec, i = [], None, 0
    while i < len(lines):
        if lines[i].startswith("## "):
            sec = lines[i][3:].strip()
            i += 1
        elif not lines[i].strip() or lines[i].startswith("#"):
            i += 1
        else:
            start = i
            para = []
            while i < len(lines) and lines[i].strip() and not lines[i].startswith("#"):
                para.append(lines[i].strip())
                i += 1
            text = " ".join(para)
            stmts.append({"text": text, "section": sec, "span": (start, i),
                          "pending": text.endswith(MARKER)})
    return lines, stmts


def write_intent(lines):
    with open(INTENT, "w") as f:
        f.write("\n".join(lines) + "\n")


def ledger(path):
    """A ledger file as raw '## ' blocks: the head line, '- key: value'
    fields, spoken operator/machine lines, and the blockquote if any."""
    if not os.path.exists(path):
        return []
    with open(path) as f:
        raw = f.read().splitlines()
    heads = [i for i, l in enumerate(raw) if l.startswith("## ")]
    blocks = []
    for a, b in zip(heads, heads[1:] + [len(raw)]):
        block = raw[a:b]
        fields, words = {}, []
        for ln in block:
            if ln.startswith("- ") and ": " in ln:
                k, v = ln[2:].split(": ", 1)
                fields[k.strip()] = v.strip()
            elif ln.startswith(("operator (", "machine (")):
                words.append(ln)
        blocks.append({"quote": " ".join(l[2:].strip() for l in block if l.startswith("> ")),
                       "fields": fields, "words": words, "lines": block})
    return blocks


def write_ledger(path, title, blocks):
    if not blocks:
        if os.path.exists(path):
            os.remove(path)
        return
    out = ["# " + title, ""]
    for b in blocks:
        entry = list(b["lines"])
        while entry and not entry[-1].strip():
            entry.pop()
        out += entry + [""]
    with open(path, "w") as f:
        f.write("\n".join(out) + "\n")


def card_for(st, cards):
    return next((b for b in cards if b["quote"] == st["text"]), None)


# ----- decisions (each one lands on disk and commits) -------------------

def head(text, n=8):
    words = text.replace(MARKER, "").split()
    return " ".join(words[:n]) + ("…" if len(words) > n else "")


def commit(subject, body, paths=("intent.md", "queue.md")):
    track = [p for p in paths
             if os.path.exists(os.path.join(ROOT, p)) or run("git", "ls-files", p).strip()]
    if track:
        run("git", "add", "--", *track)
    run("git", "commit", "-m", subject, "-m", body)
    return run("git", "log", "-1", "--format=%h").strip()


def find(text):
    _, stmts = read_intent()
    return next((s for s in stmts if s["text"] == text), None)


def approve(text, has_card):
    st = find(text)
    if st is None:
        return None
    lines, _ = read_intent()
    end = st["span"][1]
    if lines[end - 1].endswith(MARKER):
        lines[end - 1] = lines[end - 1][: -len(MARKER)]
    write_intent(lines)
    write_ledger(QUEUE, "queue", [b for b in ledger(QUEUE) if b["quote"] != text])
    grounds = ("grounds: the operator pressed approve in hyper with the card's entailments on screen."
               if has_card else
               "grounds: the operator pressed approve in hyper; no card was on file and the interface said so.")
    return commit("approved by the operator in the interface: " + head(text),
                  text.replace(MARKER, "") + "\n\n" + grounds)


def cut(text, card):
    st = find(text)
    if st is None:
        return None
    lines, _ = read_intent()
    s, e = st["span"]
    del lines[s:e]
    if 0 < s < len(lines) and not lines[s - 1].strip() and not lines[s].strip():
        del lines[s]
    write_intent(lines)
    write_ledger(QUEUE, "queue", [b for b in ledger(QUEUE) if b["quote"] != text])
    breaks = card["fields"].get("cut") if card else None
    body = ('the words that left: "' + text.replace(MARKER, "") + '"\n\n'
            + ("what it breaks, as drafted on the card: " + breaks if breaks else
               "no drafted entailments were on file; the interface said so before the pick."))
    return commit("cut by the operator in the interface: " + head(text), body)


def explain(st, words):
    cards = ledger(QUEUE)
    blk = next((b for b in cards if b["quote"] == st["text"]), None)
    if blk is None:
        blk = {"quote": st["text"],
               "lines": ["## " + head(st["text"]), "", "> " + st["text"], "",
                         "- section: " + (st["section"] or "—")]}
        cards.append(blk)
    if blk["lines"] and blk["lines"][-1].strip():
        blk["lines"].append("")
    blk["lines"].append("operator (%s): %s" % (date.today().isoformat(),
                        words.strip() or "explain — tell the story"))
    write_ledger(QUEUE, "queue", cards)
    return commit("the operator asks explain in the interface: " + head(st["text"]),
                  (words.strip() or "(no words — the machine tells the story)")
                  + "\n\nthe machine reads queue.md at next session start and answers.",
                  ("queue.md",))


# ----- speech (from anywhere; the place travels with the words) ---------

def speak(place, words):
    stamp = date.today().isoformat()
    headline = "## from %s . %s" % (place, stamp)
    blocks = ledger(WORDS)
    blk = next((b for b in blocks if b["lines"][0] == headline), None)
    if blk is None:
        blk = {"lines": [headline]}
        blocks.append(blk)
    if blk["lines"][-1].strip():
        blk["lines"].append("")
    blk["lines"].append("operator (%s): %s" % (stamp, words.strip()))
    write_ledger(WORDS, "words", blocks)
    return commit("the operator speaks in the interface, from %s: %s" % (place, head(words)),
                  words.strip() + "\n\nthe machine reads words.md at next session start and answers.",
                  ("words.md",))


def speak_more(blk, words):
    key = blk["lines"][0]
    blocks = ledger(WORDS)
    tgt = next((b for b in blocks if b["lines"][0] == key), None)
    if tgt is None:
        return None
    if tgt["lines"][-1].strip():
        tgt["lines"].append("")
    tgt["lines"].append("operator (%s): %s" % (date.today().isoformat(), words.strip()))
    write_ledger(WORDS, "words", blocks)
    return commit("the operator speaks again in the interface: " + head(words),
                  words.strip() + "\n\nthe machine reads words.md at next session start and answers.",
                  ("words.md",))


def fold_exchange(blk):
    key = blk["lines"][0]
    blocks = ledger(WORDS)
    if not any(b["lines"][0] == key for b in blocks):
        return None
    write_ledger(WORDS, "words", [b for b in blocks if b["lines"][0] != key])
    return commit("the operator folds an exchange in the interface: " + head(key[3:]),
                  "\n".join(blk["lines"]) + "\n\ngit keeps the words.",
                  ("words.md",))


# ----- the machine (summoned by speech; answers onto the same block) -----

def summon():
    """A headless machine session in this repo: it reads the ledgers,
    answers the operator's words onto the blocks that carry them, commits,
    and stops.  It builds nothing; bigger asks return through work.md.
    HYPER_MACHINE overrides the command (testing)."""
    over = os.environ.get("HYPER_MACHINE")
    if over:
        argv = shlex.split(over)
    else:
        exe = shutil.which("claude") or os.path.expanduser("~/.local/bin/claude")
        if not os.path.exists(exe):
            return None
        argv = [exe, "-p", SUMMON, "--permission-mode", "acceptEdits"]
    log = open(MACHINE_LOG, "ab", buffering=0)
    log.write(("\n--- summoned %s ---\n"
               % datetime.now().isoformat(timespec="seconds")).encode())
    return subprocess.Popen(argv, cwd=ROOT, stdin=subprocess.DEVNULL,
                            stdout=log, stderr=log, start_new_session=True)


def start_machine(machine):
    """Summon unless one is already answering (it reads from disk, so words
    that land mid-answer wait visibly and m summons again)."""
    if machine:
        return machine
    p = summon()
    return (p, time.time()) if p else None


def login_fullscreen():
    """ghostty ignores fullscreen=true at window creation on Linux
    (ghostty-org/ghostty #11252); the toggle works once the window is
    mapped.  When the login launcher asks (HYPER_FULLSCREEN=1), send the
    window manager the same request the ctrl+enter toggle makes."""
    wid = os.environ.get("WINDOWID")
    if not (os.environ.get("HYPER_FULLSCREEN") and wid):
        return ""
    try:
        r = subprocess.run(["xdotool", "windowstate", "--add", "FULLSCREEN", wid],
                           capture_output=True, text=True)
        return ("" if r.returncode == 0 else
                "the fullscreen request failed — " + (r.stderr.strip() or "no reason given"))
    except FileNotFoundError:
        return "xdotool is not installed — the fullscreen request could not be made"


# ----- screen -----------------------------------------------------------

def put(scr, y, x, s, attr=0):
    try:
        scr.addstr(y, x, s, attr)
    except curses.error:
        pass


def wrap(text, width):
    return textwrap.wrap(text, max(10, width)) or [""]


def read_words(scr, h, w, prompt):
    """The operator's words at the bottom of the screen, visible whole and
    editable until sent: the text wraps across as many lines as it needs,
    arrows move the cursor anywhere, home/end jump within the line,
    backspace and delete edit in place.  Enter sends, esc abandons —
    until then nothing binds."""
    curses.curs_set(1)
    scr.timeout(-1)
    width = max(10, w - 2 * LM)
    buf, pos, top_seen = "", 0, h - 2
    try:
        while True:
            rows = [buf[i:i + width] for i in range(0, len(buf), width)] or [""]
            if buf and len(buf) % width == 0:
                rows.append("")
            cr, cc = divmod(pos, width)
            maxrows = max(1, h - 8)
            base = max(0, cr - maxrows + 1)
            vis = rows[base:base + maxrows]
            top = h - 2 - len(vis) - 1
            top_seen = min(top_seen, top)
            for y in range(top_seen, h):
                put(scr, y, 0, " " * (w - 1))
            put(scr, top, LM, prompt[: w - 2 * LM], curses.A_DIM)
            for i, ln in enumerate(vis):
                put(scr, top + 1 + i, LM, ln)
            put(scr, h - 1, LM,
                "enter sends . esc abandons . arrows move . home/end jump"[: w - 2 * LM],
                curses.A_DIM)
            scr.move(top + 1 + cr - base, min(LM + cc, w - 2))
            scr.refresh()
            ch = scr.get_wch()
            if ch in ("\n", "\r") or ch == curses.KEY_ENTER:
                return buf
            if ch == "\x1b":
                return None
            if ch in ("\x7f", "\b") or ch == curses.KEY_BACKSPACE:
                if pos:
                    buf, pos = buf[: pos - 1] + buf[pos:], pos - 1
            elif ch == curses.KEY_DC:
                buf = buf[:pos] + buf[pos + 1:]
            elif ch == curses.KEY_LEFT:
                pos = max(0, pos - 1)
            elif ch == curses.KEY_RIGHT:
                pos = min(len(buf), pos + 1)
            elif ch == curses.KEY_UP:
                pos = max(0, pos - width)
            elif ch == curses.KEY_DOWN:
                pos = min(len(buf), pos + width)
            elif ch == curses.KEY_HOME or ch == "\x01":
                pos = (pos // width) * width
            elif ch == curses.KEY_END or ch == "\x05":
                pos = min(len(buf), (pos // width) * width + width)
            elif isinstance(ch, str) and ch.isprintable():
                buf, pos = buf[:pos] + ch + buf[pos:], pos + len(ch)
    finally:
        curses.curs_set(0)
        scr.timeout(1000)


def main(scr):
    try:
        curses.set_escdelay(25)
    except AttributeError:
        pass
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_RED, -1)
    ALERT = curses.color_pair(1) | curses.A_BOLD
    DIM, BOLD, REV = curses.A_DIM, curses.A_BOLD, curses.A_REVERSE

    view, sel, ci, wsel, scroll, flash, confirm, exkey = "home", 0, 0, 0, 0, "", None, None
    machine = None  # (Popen, started) while a summoned session is answering
    flash = login_fullscreen()
    scr.timeout(1000)  # the screen re-reads disk on its own — no restart anywhere

    while True:
        _, stmts = read_intent()
        pend = [s for s in stmts if s["pending"]]
        cards = ledger(QUEUE)
        exchanges = ledger(WORDS)
        work = ledger(WORK)
        dirty = run("git", "status", "--porcelain").strip()
        last = run("git", "log", "-1", "--format=%h %s . %cr").strip()

        awaits = [b for b in cards + exchanges
                  if b["words"] and b["words"][-1].startswith("operator (")]
        if machine and machine[0].poll() is not None:
            rc = machine[0].returncode
            flash = ("the machine has answered" if rc == 0 else
                     "the machine failed (exit %d) — .hyper-machine.log holds the story" % rc)
            machine = None

        answered = [b for b in exchanges
                    if b["words"] and b["words"][-1].startswith("machine (")]
        sent = [b for b in exchanges if b not in answered]
        entries = ([("decide", s) for s in pend]
                   + [("read", b) for b in answered]
                   + [("sent", b) for b in sent])
        sel = max(0, min(sel, len(entries) - 1))
        ci = max(0, min(ci, len(pend) - 1))
        wsel = max(0, min(wsel, len(work) - 1))
        exb, exmax = None, 0
        if view == "card" and not pend:
            view = "home"
        if view == "exchange":
            exb = next((b for b in exchanges if b["lines"][0] == exkey), None)
            if exb is None:
                view = "home"
        if view == "work" and not work:
            view = "home"

        scr.erase()
        h, w = scr.getmaxyx()
        width = min(w - 2 * LM, 76)
        top = 4
        view_h = max(1, h - top - 6)
        guarded = any(l.split()[-1] in LEDGERS for l in dirty.splitlines())

        put(scr, 0, LM, "H Y P E R C O R E", BOLD)
        waiting = len(pend) + len(answered)
        status = "%d WAITING" % waiting if waiting else "QUEUE CLEAR"
        put(scr, 0, max(LM, w - len(status) - LM), status, BOLD if waiting else DIM)
        put(scr, 1, LM, "─" * max(0, w - 2 * LM), DIM)
        mtxt = ""
        if machine:
            mtxt = "the machine is answering · %ds" % (time.time() - machine[1])
            put(scr, 2, max(LM, w - len(mtxt) - LM), mtxt, BOLD)
        elif awaits:
            mtxt = ("%d word%s the machine — m summons it"
                    % (len(awaits), " awaits" if len(awaits) == 1 else "s await"))
            put(scr, 2, max(LM, w - len(mtxt) - LM), mtxt, DIM)
        if dirty:
            files = ", ".join(l.split()[-1] for l in dirty.splitlines())
            room = w - 2 * LM - (len(mtxt) + 2 if mtxt else 0)
            put(scr, 2, LM, ("the record is behind — uncommitted: " + files)[: max(0, room)],
                ALERT)

        if view == "home":
            put(scr, top, LM, "THE QUEUE", DIM)
            y = top + 2
            if entries:
                for i, (kind, obj) in enumerate(entries):
                    if kind == "decide":
                        text = obj["text"].replace(MARKER, "")
                        tag = obj["section"] or ""
                    else:
                        text = obj["lines"][0][3:].strip()
                        tag = "answered — enter reads" if kind == "read" else "with the machine"
                    room = width - len(tag) - 3
                    if len(text) > room:
                        text = text[: max(1, room - 1)] + "…"
                    if i == sel:
                        put(scr, y, LM, (text + " " * width)[:width], REV)
                        put(scr, y, LM + width - len(tag), tag, REV)
                    else:
                        put(scr, y, LM, text, 0 if kind == "decide" else DIM)
                        put(scr, y, LM + width - len(tag), tag, DIM)
                    y += 1
            else:
                put(scr, y, LM, "nothing waits on you.", DIM)
                y += 1
            y += 1
            if work:
                acc = sum(1 for b in work
                          if "awaiting acceptance" in b["fields"].get("state", ""))
                put(scr, y, LM, ("work in flight: %d . awaiting your acceptance: %d . "
                                 "w opens the view" % (len(work), acc))[: w - 2 * LM], DIM)
                y += 1
            put(scr, y, LM, ("last  " + last)[: w - 2 * LM], DIM)

        elif view == "card":
            st = pend[ci]
            card = card_for(st, cards)
            put(scr, top, LM,
                ("%s . %d of %d" % (st["section"] or "—", ci + 1, len(pend))).upper(), DIM)
            rows = [[(LM, ln, BOLD)] for ln in wrap(st["text"].replace(MARKER, ""), width)]
            rows += [[(LM, "[machine]", DIM)], []]
            drafted = False
            if card:
                for key in ("context", "approve", "cut"):
                    val = card["fields"].get(key)
                    if not val:
                        continue
                    drafted = True
                    first = True
                    for ln in wrap(val, width - 9):
                        rows.append([(LM, "%7s" % key, DIM), (LM + 9, ln, 0)]
                                    if first else [(LM + 9, ln, 0)])
                        first = False
            if not drafted:
                rows += [[(LM, ln, BOLD)]
                         for ln in wrap("no entailments on file — context and what "
                                        "approve or cut entails is not drafted; "
                                        "e asks the machine for them.", width)]
            if card and card["words"]:
                rows += [[], [(LM, "THE EXCHANGE SO FAR", DIM)]]
                for wln in card["words"]:
                    attr = DIM if wln.startswith("operator (") else 0
                    rows.append([])
                    rows += [[(LM + 2, ln, attr)] for ln in wrap(wln, width - 2)]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "exchange":
            # the exchange reads as a chat: it opens pinned to the newest
            # words (scroll == -1) and follows them as they land; scrolling
            # up unpins, reaching the bottom pins again.
            put(scr, top, LM, exb["lines"][0][3:].strip().upper(), DIM)
            rows = []
            for wln in exb["words"]:
                attr = DIM if wln.startswith("operator (") else 0
                rows.append([])
                rows += [[(LM, ln, attr)] for ln in wrap(wln, width)]
            exmax = max(0, len(rows) - view_h)
            eff = exmax if scroll == -1 else max(0, min(scroll, exmax))
            for i, segs in enumerate(rows[eff: eff + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            if eff > 0:
                put(scr, top + 1, LM, "… %d above — ↑ scrolls" % eff, DIM)
            below = len(rows) - view_h - eff
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view == "work":
            put(scr, top, LM, "WORK IN FLIGHT", DIM)
            rows, marks = [], []
            for i, b in enumerate(work):
                name = b["lines"][0][3:].strip()
                state = b["fields"].get("state", "")
                room = width - len(state) - 2
                shown = name if len(name) <= room else name[: max(1, room - 1)] + "…"
                marks.append(len(rows))
                if i == wsel:
                    rows.append([(LM, (shown + " " * width)[:width], REV),
                                 (LM + width - len(state), state, REV)])
                else:
                    rows.append([(LM, shown, BOLD),
                                 (LM + width - len(state), state, DIM)])
                ask = b["fields"].get("ask")
                if ask:
                    rows += [[(LM + 2, ln, DIM)] for ln in wrap(ask, width - 2)]
                waits = b["fields"].get("waits on")
                if waits:
                    rows += [[(LM + 2, ln, DIM)]
                             for ln in wrap("waits on " + waits, width - 2)]
                rows.append([])
            if marks:
                mark = marks[wsel]
                nxt = marks[wsel + 1] if wsel + 1 < len(marks) else len(rows)
                if mark < scroll:
                    scroll = mark
                if nxt > scroll + view_h:
                    scroll = max(0, nxt - view_h)
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, segs in enumerate(rows[scroll: scroll + view_h]):
                for x, txt, attr in segs:
                    put(scr, top + 2 + i, x, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        elif view in ("doc", "log"):
            put(scr, top, LM, "INTENT" if view == "doc" else "THE RECORD", DIM)
            if view == "doc":
                rows, cursec = [], None
                for st in stmts:
                    if st["section"] != cursec:
                        cursec = st["section"]
                        rows += [("", 0), ((cursec or "").upper(), BOLD), ("", 0)]
                    attr = DIM if st["pending"] else 0
                    rows += [(ln, attr) for ln in wrap(st["text"], width)]
                    rows.append(("", 0))
            else:
                rows = [((e if len(e) <= width else e[: width - 1] + "…"), 0)
                        for e in run("git", "log", "-200",
                                     "--format=%h %s . %cr").splitlines()]
            scroll = max(0, min(scroll, max(0, len(rows) - view_h)))
            for i, (txt, attr) in enumerate(rows[scroll: scroll + view_h]):
                put(scr, top + 2 + i, LM, txt, attr)
            below = len(rows) - view_h - scroll
            if below > 0:
                put(scr, top + 2 + view_h, LM,
                    "… %d more below — space scrolls" % below, DIM)

        hints = {
            "home": (("enter open . ↑/↓ move . " if entries else "")
                     + ("m summon . " if awaits and not machine else "")
                     + "s speak . w work . d document . g log . q quit"),
            "card": "a approve . c cut . e explain . s speak . ←/→ statements . ↑/↓ scroll . esc back",
            "exchange": "s speak . c fold away . ↑/↓ scroll . space/b page . esc back",
            "work": "↑/↓ move . s speak on it . space/b page . esc back",
            "doc": "↑/↓ scroll . space/b page . s speak . esc back",
            "log": "↑/↓ scroll . space/b page . s speak . esc back",
        }[view]
        put(scr, h - 3, LM, "─" * max(0, w - 2 * LM), DIM)
        if confirm:
            kind = confirm[0]
            msg = {"approve": "approve — the marker drops and this statement becomes yours",
                   "cut": "cut — the words leave intent",
                   "fold": "fold this exchange away — git keeps the words"}[kind] \
                  + " . y confirm . esc keep"
            put(scr, h - 2, LM, msg[: w - 2 * LM], ALERT if kind == "cut" else BOLD)
        elif flash:
            put(scr, h - 2, LM, flash[: w - 2 * LM], BOLD)
        put(scr, h - 1, LM, hints[: w - 2 * LM], DIM)
        scr.refresh()

        ch = scr.getch()
        if ch == -1:
            continue  # the tick: re-read disk, redraw, touch nothing
        flash = ""

        if confirm:
            kind, payload = confirm
            confirm = None
            if ch in (ord("y"), ord("Y")):
                if guarded:
                    flash = GUARD
                    continue
                if kind == "fold":
                    hsh = fold_exchange(payload)
                    flash = ("that exchange is no longer on disk — refreshed" if hsh is None
                             else "folded . committed %s" % hsh)
                    view = "home"
                else:
                    card = card_for(payload, cards)
                    hsh = (approve(payload["text"], card is not None) if kind == "approve"
                           else cut(payload["text"], card))
                    flash = ("that statement is no longer on disk — refreshed" if hsh is None
                             else "%s . committed %s" % ("approved" if kind == "approve" else "cut", hsh))
            continue

        if view == "home":
            if ch == ord("q"):
                return
            elif ch == curses.KEY_DOWN:
                sel += 1
            elif ch == curses.KEY_UP:
                sel -= 1
            elif ch in (10, 13, curses.KEY_ENTER) and entries:
                kind, obj = entries[sel]
                if kind == "decide":
                    view, ci, scroll = "card", pend.index(obj), 0
                else:
                    view, exkey, scroll = "exchange", obj["lines"][0], -1
            elif ch == ord("m") and awaits and not machine:
                machine = start_machine(machine)
                flash = ("the machine is summoned" if machine else
                         "claude is not on this machine — the words wait on disk")
            elif ch == ord("w") and work:
                view, scroll = "work", 0
            elif ch == ord("d"):
                view, scroll = "doc", 0
            elif ch == ord("g"):
                view, scroll = "log", 0
            elif ch == ord("s"):
                if guarded:
                    flash = GUARD
                else:
                    wd = read_words(scr, h, w, "your words (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak("the queue", wd)
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . claude not found — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "card":
            if ch == 27:
                view = "home"
            elif ch == curses.KEY_RIGHT:
                ci, scroll = ci + 1, 0
            elif ch == curses.KEY_LEFT:
                ci, scroll = ci - 1, 0
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord(" "):
                scroll += view_h
            elif ch == ord("b"):
                scroll -= view_h
            elif ch == ord("a"):
                confirm = ("approve", pend[ci])
            elif ch == ord("c"):
                confirm = ("cut", pend[ci])
            elif ch in (ord("e"), ord("s")):
                wd = read_words(scr, h, w, "your words (enter sends . empty = just "
                                           "explain . esc abandons): ")
                if wd is not None:
                    hsh = explain(pend[ci], wd)
                    machine = start_machine(machine)
                    flash = ("on disk . committed %s . the machine is answering" % hsh
                             if machine else
                             "on disk . committed %s . claude not found — the words wait" % hsh)

        elif view == "exchange":
            if ch == 27:
                view = "home"
            elif ch == curses.KEY_DOWN:
                if scroll != -1:
                    scroll += 1
                    if scroll >= exmax:
                        scroll = -1
            elif ch == curses.KEY_UP:
                scroll = max(0, (exmax if scroll == -1 else scroll) - 1)
            elif ch == ord(" "):
                if scroll != -1:
                    scroll += view_h
                    if scroll >= exmax:
                        scroll = -1
            elif ch == ord("b"):
                scroll = max(0, (exmax if scroll == -1 else scroll) - view_h)
            elif ch == ord("c"):
                confirm = ("fold", exb)
            elif ch == ord("s"):
                if guarded:
                    flash = GUARD
                else:
                    wd = read_words(scr, h, w, "your words (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak_more(exb, wd)
                        machine = start_machine(machine)
                        scroll = -1
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . claude not found — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view == "work":
            if ch == 27:
                view = "home"
            elif ch == curses.KEY_DOWN:
                wsel += 1
            elif ch == curses.KEY_UP:
                wsel -= 1
            elif ch == ord(" "):
                scroll += view_h
            elif ch == ord("b"):
                scroll -= view_h
            elif ch == ord("s") and work:
                if guarded:
                    flash = GUARD
                else:
                    name = work[wsel]["lines"][0][3:].strip()
                    wd = read_words(scr, h, w, "your words (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak('the work view, on "%s"' % name, wd)
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . claude not found — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"

        elif view in ("doc", "log"):
            if ch in (27, ord("q"), ord("d") if view == "doc" else ord("g")):
                view = "home"
            elif ch == curses.KEY_DOWN:
                scroll += 1
            elif ch == curses.KEY_UP:
                scroll -= 1
            elif ch == ord(" "):
                scroll += view_h
            elif ch == ord("b"):
                scroll -= view_h
            elif ch == ord("s"):
                if guarded:
                    flash = GUARD
                else:
                    place = "the document" if view == "doc" else "the log"
                    wd = read_words(scr, h, w, "your words (enter sends . esc abandons): ")
                    if wd and wd.strip():
                        hsh = speak(place, wd)
                        machine = start_machine(machine)
                        flash = ("on disk . committed %s . the machine is answering" % hsh
                                 if machine else
                                 "on disk . committed %s . claude not found — the words wait" % hsh)
                    elif wd is not None:
                        flash = "no words — nothing landed"


if __name__ == "__main__":
    if not os.path.exists(INTENT):
        raise SystemExit("hyper: intent.md not found beside this file")
    locale.setlocale(locale.LC_ALL, "")
    curses.wrapper(main)
