<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="task19_browser_merge_activation_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="task19_browser_merge_activation" name="Activate OpenWiki maintainer from browser merges" isExecutable="false">
    <bpmn:startEvent id="activation_approved" name="Local activation approved">
      <bpmn:documentation>The operator approved a local browser-to-Herdr bridge and rejected polling and a public-repository self-hosted runner. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:26</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="26" />
      </bpmn:extensionElements>
      <bpmn:outgoing>flow_start_userscript</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="build_userscript" name="Build generic merge userscript">
      <bpmn:documentation>Create a Tampermonkey userscript for any GitHub pull-request page that opens a local activation URL only after the final merge confirmation. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:38</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="38" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_userscript</bpmn:incoming>
      <bpmn:outgoing>flow_userscript_handler</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="build_local_handler" name="Build validating local handler">
      <bpmn:documentation>Discover and validate the qq-linked Repository, verify the PR URL and GitHub merge facts, ignore recursive wiki merges, deduplicate merge commits, and dispatch through Herdr. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:39-42</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="39-42" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_userscript_handler</bpmn:incoming>
      <bpmn:outgoing>flow_handler_installer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="extend_installer" name="Register local protocol safely">
      <bpmn:documentation>Register the qq-openwiki protocol handler and document the one-time userscript setup while preserving unrelated desktop and MIME state. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:43</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="43" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_handler_installer</bpmn:incoming>
      <bpmn:outgoing>flow_installer_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="verification_entry" name="Verification entry">
      <bpmn:documentation>Merge initial implementation and every correction path before running the focused checks again. Evidence: skills/deliver-change/SKILL.md:30-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_installer_entry</bpmn:incoming>
      <bpmn:incoming>flow_fix_checks_entry</bpmn:incoming>
      <bpmn:incoming>flow_fix_review_entry</bpmn:incoming>
      <bpmn:incoming>flow_fix_pr_entry</bpmn:incoming>
      <bpmn:outgoing>flow_entry_checks</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="run_checks" name="Run focused bridge checks">
      <bpmn:documentation>Exercise generic Repository discovery, input refusal, GitHub verification, recursion protection, deduplication, launch, wake, userscript, and installer preservation behavior. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:44</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="44" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_entry_checks</bpmn:incoming>
      <bpmn:outgoing>flow_checks_gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="checks_green" name="Checks green?">
      <bpmn:documentation>Only locally verified bridge behavior advances to independent review. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_gate</bpmn:incoming>
      <bpmn:outgoing>flow_checks_fail</bpmn:outgoing>
      <bpmn:outgoing>flow_checks_review</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_check_failures" name="Fix check failures">
      <bpmn:documentation>Correct only in-scope failures and rerun the checks that observe them. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_fail</bpmn:incoming>
      <bpmn:outgoing>flow_fix_checks_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="fresh_context_review" name="Run fresh-context review">
      <bpmn:documentation>Give the exact verified working-tree Change to an independent read-only reviewer before commit or publication. Evidence: skills/code-review/SKILL.md:44-68</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="44-68" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_review</bpmn:incoming>
      <bpmn:outgoing>flow_review_findings</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="confirmed_findings" name="Confirmed findings?">
      <bpmn:documentation>The accountable agent verifies each reported failure path before changing the implementation. Evidence: skills/code-review/SKILL.md:70-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="70-84" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_review_findings</bpmn:incoming>
      <bpmn:outgoing>flow_findings_fix</bpmn:outgoing>
      <bpmn:outgoing>flow_findings_pr</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_review_findings" name="Fix confirmed findings">
      <bpmn:documentation>Apply the smallest in-scope correction and return through focused verification. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_findings_fix</bpmn:incoming>
      <bpmn:outgoing>flow_fix_review_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="open_activation_pr" name="Open activation PR">
      <bpmn:documentation>Commit and push the green reviewed Change and open one pull request carrying intent and Check evidence. Evidence: skills/deliver-change/SKILL.md:37-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-39" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_findings_pr</bpmn:incoming>
      <bpmn:outgoing>flow_pr_gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="pr_green" name="PR green?">
      <bpmn:documentation>The Change is ready only when its applicable GitHub checks pass. Evidence: skills/deliver-change/SKILL.md:37-45,54-58</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-45,54-58" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_pr_gate</bpmn:incoming>
      <bpmn:outgoing>flow_pr_fail</bpmn:outgoing>
      <bpmn:outgoing>flow_pr_handoff</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_pr_failures" name="Fix PR failures">
      <bpmn:documentation>Correct an in-scope handoff failure and return through local verification and review. Evidence: skills/deliver-change/SKILL.md:30-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_pr_fail</bpmn:incoming>
      <bpmn:outgoing>flow_fix_pr_entry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="green_handoff" name="Activation PR green">
      <bpmn:documentation>The local activation Change is green for operator handoff; OpenWiki BPMN generation remains the separate TASK-6 follow-on. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:45</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="45" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_pr_handoff</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_userscript" sourceRef="activation_approved" targetRef="build_userscript">
      <bpmn:documentation>Approval starts implementation of the browser-side detector. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:26,38</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="26,38" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_userscript_handler" sourceRef="build_userscript" targetRef="build_local_handler">
      <bpmn:documentation>The browser signal crosses only through the validating local protocol handler. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:38-42</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="38-42" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_handler_installer" sourceRef="build_local_handler" targetRef="extend_installer">
      <bpmn:documentation>The validated bridge is provisioned through the existing local installer surface. Evidence: backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md:42-43</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-19 - Activate-the-OpenWiki-maintainer-from-operator-merges.md" lines="42-43" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_installer_entry" sourceRef="extend_installer" targetRef="verification_entry">
      <bpmn:documentation>The complete coherent unit enters verification. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_entry_checks" sourceRef="verification_entry" targetRef="run_checks">
      <bpmn:documentation>Initial implementation and corrections use the same focused checks. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_checks_gate" sourceRef="run_checks" targetRef="checks_green">
      <bpmn:documentation>Observed results determine whether review can begin. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_checks_fail" name="no" sourceRef="checks_green" targetRef="fix_check_failures">
      <bpmn:documentation>A failing Check requires an in-scope correction. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_fix_checks_entry" sourceRef="fix_check_failures" targetRef="verification_entry">
      <bpmn:documentation>Every check fix is re-observed by the focused suite. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_checks_review" name="yes" sourceRef="checks_green" targetRef="fresh_context_review">
      <bpmn:documentation>Green local behavior advances to independent judgment. Evidence: skills/deliver-change/SKILL.md:34-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="34-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_review_findings" sourceRef="fresh_context_review" targetRef="confirmed_findings">
      <bpmn:documentation>The accountable agent verifies the review output. Evidence: skills/code-review/SKILL.md:70-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="70-84" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_findings_fix" name="yes" sourceRef="confirmed_findings" targetRef="fix_review_findings">
      <bpmn:documentation>Confirmed in-scope findings are corrected. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_fix_review_entry" sourceRef="fix_review_findings" targetRef="verification_entry">
      <bpmn:documentation>Review corrections return through verification before publication. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_findings_pr" name="no" sourceRef="confirmed_findings" targetRef="open_activation_pr">
      <bpmn:documentation>A reviewed Change with no confirmed findings can be published. Evidence: skills/deliver-change/SKILL.md:34-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="34-39" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_pr_gate" sourceRef="open_activation_pr" targetRef="pr_green">
      <bpmn:documentation>The published Change must pass applicable GitHub checks. Evidence: skills/deliver-change/SKILL.md:37-39,54-58</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-39,54-58" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_pr_fail" name="no" sourceRef="pr_green" targetRef="fix_pr_failures">
      <bpmn:documentation>An in-scope PR failure returns to local correction and verification. Evidence: skills/deliver-change/SKILL.md:30-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_fix_pr_entry" sourceRef="fix_pr_failures" targetRef="verification_entry">
      <bpmn:documentation>PR corrections are rechecked and re-reviewed before another handoff. Evidence: skills/deliver-change/SKILL.md:30-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_pr_handoff" name="yes" sourceRef="pr_green" targetRef="green_handoff">
      <bpmn:documentation>A green PR ends the planned implementation flow. Evidence: skills/bpmn-plans/SKILL.md:28-34</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="28-34" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
  </bpmn:process>
</bpmn:definitions>
