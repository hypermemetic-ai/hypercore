+
+function summaryStream(calls: Array<{ model: string; options: SimpleStreamOptions | undefined }>): StreamFn {
+	return (model, _context, options) => {
+		calls.push({ model: model.id, options });
+		const stream = createAssistantMessageEventStream();
+		queueMicrotask(() => {
+			const message = {
+				...fauxAssistantMessage("summary"),
+				api: model.api,
+				provider: model.provider,
+				model: model.id,
+			};
+			stream.push({ type: "done", reason: "stop", message });
+			stream.end(message);
+		});
+		return stream;
+	};
+}
+
+function payloadAwareSummaryStream(providerCalls: string[]): StreamFn {
+	return (model, _context, options) => {
+		const stream = createAssistantMessageEventStream();
+		queueMicrotask(async () => {
+			try {
+				await options?.onPayload?.(
+					{ model: model.id, reasoning: options.reasoning, service_tier: options.serviceClass },
+					model,
+				);
+				providerCalls.push(model.id);
+				const message = {
+					...fauxAssistantMessage("summary"),
+					api: model.api,
+					provider: model.provider,
+					model: model.id,
+					usage: structuredClone(fauxAssistantMessage("").usage),
+				};
+				stream.push({ type: "done", reason: "stop", message });
+				stream.end(message);
+			} catch (error) {
+				const message = {
+					...fauxAssistantMessage("", {
+						stopReason: "error",
+						errorMessage: error instanceof Error ? error.message : String(error),
+					}),
+					api: model.api,
+					provider: model.provider,
+					model: model.id,
+					usage: structuredClone(fauxAssistantMessage("").usage),
+				};
+				stream.push({ type: "error", reason: "error", error: message });
+				stream.end(message);
+			}
+		});
+		return stream;
+	};
