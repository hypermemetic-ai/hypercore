+import { openaiCodexProvider } from "../src/providers/openai-codex.ts";
+import type { AcknowledgedServiceClass, ExecutionProfileSelection, ExecutionProfileTelemetry } from "../src/types.ts";
+
+function responseSse(serviceTier?: "default" | "priority", tokens = 100_000): string {
+	return `data: ${JSON.stringify({
+		type: "response.completed",
+		response: {
+			status: "completed",
+			...(serviceTier ? { service_tier: serviceTier } : {}),
+			usage: {
+				input_tokens: tokens,
+				output_tokens: tokens,
+				total_tokens: tokens * 2,
+				input_tokens_details: { cached_tokens: 0 },
+			},
+		},
+	})}\n\n`;
+}
+
+function selection(overrides: Partial<ExecutionProfileSelection> = {}): Readonly<ExecutionProfileSelection> {
+	return Object.freeze({
+		provider: "openai",
+		model: "gpt-5.4",
+		effort: "high",
+		serviceClass: "priority",
+		...overrides,
+	});
+}
+
+function mockCodexToken(): string {
+	const payload = Buffer.from(
+		JSON.stringify({ "https://api.openai.com/auth": { chatgpt_account_id: "acc_test" } }),
+		"utf8",
+	).toString("base64");
+	return `aaa.${payload}.bbb`;
+}
+
+function decodeRequestBody(body: RequestInit["body"] | undefined): Record<string, unknown> {
+	if (typeof body === "string") return JSON.parse(body) as Record<string, unknown>;
+	if (body instanceof Uint8Array) {
+		return JSON.parse(Buffer.from(zstdDecompressSync(body)).toString("utf8")) as Record<string, unknown>;
+	}
+	throw new Error("Expected a JSON request body");
+}
+
+function accountedMultiplier(profile: Readonly<ExecutionProfileTelemetry> | undefined): number {
+	const serviceClass: AcknowledgedServiceClass | undefined = profile?.accountedServiceClass;
+	if (serviceClass === "flex") return 0.5;
+	if (serviceClass === "priority") return 2;
+	return 1;
+}
+
+const context = {
+	systemPrompt: "sys",
+	messages: [{ role: "user" as const, content: "hi", timestamp: 1 }],
+};
