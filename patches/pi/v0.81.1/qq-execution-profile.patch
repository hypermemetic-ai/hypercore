+++ b/packages/ai/src/execution-profile.ts
@@ -0,0 +1,15 @@
+import type { ExecutionProfileCapabilities, ServiceClass } from "./types.ts";
+
+const authoritativeCapabilities = new WeakSet<object>();
+
+export function createExecutionProfileCapabilities(serviceClasses: readonly ServiceClass[]) {
+	const capabilities = Object.freeze({ serviceClasses: Object.freeze([...serviceClasses]) });
+	authoritativeCapabilities.add(capabilities);
+	return capabilities;
+}
+
+export function isExecutionProfileCapabilities(
+	value: ExecutionProfileCapabilities | undefined,
+): value is Readonly<ExecutionProfileCapabilities> {
+	return authoritativeCapabilities.has(value as object);
+}
